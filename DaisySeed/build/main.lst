 117:synth/tr808.h ****  *  El snare original mezcla componente tonal con noise
 118:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 119:synth/tr808.h **** class Snare {
 120:synth/tr808.h **** public:
 121:synth/tr808.h ****     float decay     = 0.2f;     /* 0.1 - 0.5 s     decay total           */
 122:synth/tr808.h ****     float tone      = 0.5f;     /* 0.0 - 1.0        mezcla tono/ruido    */
 123:synth/tr808.h ****     float snappy    = 0.5f;     /* 0.0 - 1.0        cantidad de noise    */
 124:synth/tr808.h ****     float pitch     = 180.0f;   /* 100 - 300 Hz     tono fundamental     */
