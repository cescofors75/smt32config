  24:synth/demo_mode.h **** 
  25:synth/demo_mode.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  26:synth/demo_mode.h ****  *  FUNCIONES MATEM├üTICAS BASE
  27:synth/demo_mode.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  28:synth/demo_mode.h **** 
  29:synth/demo_mode.h **** namespace Demo {
  30:synth/demo_mode.h **** 
  31:synth/demo_mode.h **** /* ŌöĆŌöĆ lerp: interpolaci├│n lineal ŌöĆŌöĆŌöĆ */
  32:synth/demo_mode.h **** static inline float lerp(float a, float b, float t) {
  33:synth/demo_mode.h ****     return a + (b - a) * t;
  34:synth/demo_mode.h **** }
  35:synth/demo_mode.h **** 
  36:synth/demo_mode.h **** /* ŌöĆŌöĆ clamp01 ŌöĆŌöĆŌöĆ */
  37:synth/demo_mode.h **** static inline float clamp01(float v) {
  38:synth/demo_mode.h ****     return v < 0.0f ? 0.0f : (v > 1.0f ? 1.0f : v);
  39:synth/demo_mode.h **** }
  40:synth/demo_mode.h **** 
  41:synth/demo_mode.h **** /* ŌöĆŌöĆ Conversi├│n ms ŌåÆ samples ŌöĆŌöĆŌöĆ */
  42:synth/demo_mode.h **** static inline uint32_t msToSamples(float ms, float sr) {
  43:synth/demo_mode.h ****     return (uint32_t)(ms * sr / 1000.0f);
  44:synth/demo_mode.h **** }
  45:synth/demo_mode.h **** 
  46:synth/demo_mode.h **** /* ŌöĆŌöĆ Conversi├│n seconds ŌåÆ samples ŌöĆŌöĆŌöĆ */
  47:synth/demo_mode.h **** static inline uint32_t secToSamples(float sec, float sr) {
  48:synth/demo_mode.h ****     return (uint32_t)(sec * sr);
  49:synth/demo_mode.h **** }
  50:synth/demo_mode.h **** 
  51:synth/demo_mode.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  52:synth/demo_mode.h ****  *  AutoParam ŌĆö par├Īmetro que cambia solo en el tiempo
  53:synth/demo_mode.h ****  *  Interpola linealmente de startVal a endVal durante durationSamples
  54:synth/demo_mode.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  55:synth/demo_mode.h **** struct AutoParam {
  56:synth/demo_mode.h ****     float    startVal       = 0.0f;
  57:synth/demo_mode.h ****     float    endVal         = 1.0f;
  58:synth/demo_mode.h ****     float    currentVal     = 0.0f;
  59:synth/demo_mode.h ****     uint32_t startSample    = 0;
  60:synth/demo_mode.h ****     uint32_t durationSamples= 0;
  61:synth/demo_mode.h ****     bool     active         = false;
  62:synth/demo_mode.h **** 
  63:synth/demo_mode.h ****     void Set(float from, float to, uint32_t start, uint32_t duration) {
  64:synth/demo_mode.h ****         startVal        = from;
  65:synth/demo_mode.h ****         endVal          = to;
  66:synth/demo_mode.h ****         currentVal      = from;
  67:synth/demo_mode.h ****         startSample     = start;
  68:synth/demo_mode.h ****         durationSamples = duration;
  69:synth/demo_mode.h ****         active          = true;
  70:synth/demo_mode.h ****     }
  71:synth/demo_mode.h **** 
  72:synth/demo_mode.h ****     float Update(uint32_t now) {
  73:synth/demo_mode.h ****         if (!active) return currentVal;
  74:synth/demo_mode.h ****         if (now < startSample) { currentVal = startVal; return currentVal; }
  75:synth/demo_mode.h ****         if (durationSamples == 0) { currentVal = endVal; active = false; return currentVal; }
  76:synth/demo_mode.h ****         float t = (float)(now - startSample) / (float)durationSamples;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 435


  77:synth/demo_mode.h ****         if (t >= 1.0f) { t = 1.0f; active = false; }
  78:synth/demo_mode.h ****         currentVal = lerp(startVal, endVal, t);
  79:synth/demo_mode.h ****         return currentVal;
  80:synth/demo_mode.h ****     }
  81:synth/demo_mode.h **** };
  82:synth/demo_mode.h **** 
  83:synth/demo_mode.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  84:synth/demo_mode.h ****  *  SECUENCIA DE NOTAS 303
  85:synth/demo_mode.h ****  *  Patr├│n acid cl├Īsico: 16 steps, notas MIDI, accent/slide
  86:synth/demo_mode.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  87:synth/demo_mode.h **** struct AcidStep {
  88:synth/demo_mode.h ****     uint8_t note;       /* MIDI note (0 = rest/tie) */
  89:synth/demo_mode.h ****     bool    accent;
