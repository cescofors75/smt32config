1762:main.cpp      **** static float ApplyDist(float s, float drive, uint8_t mode){
1763:main.cpp      ****     if(drive < 0.01f) return s;
1764:main.cpp      ****     float d = 1.0f + drive * 15.0f;
1765:main.cpp      ****     s *= d;
1766:main.cpp      ****     switch(mode){
1767:main.cpp      ****         case DMODE_SOFT: s = MySoftClip(s); break;
1768:main.cpp      ****         case DMODE_HARD: s = clampF(s,-1.f,1.f); break;
1769:main.cpp      ****         case DMODE_TUBE: s = tanhf(s); break;
1770:main.cpp      ****         case DMODE_FUZZ:
1771:main.cpp      ****             while(s >  1.f || s < -1.f){
1772:main.cpp      ****                 if(s >  1.f) s =  2.f - s;
1773:main.cpp      ****                 if(s < -1.f) s = -2.f - s;
1774:main.cpp      ****             }
1775:main.cpp      ****             break;
1776:main.cpp      ****     }
1777:main.cpp      ****     return s / d * (1.f + drive * 0.5f);
1778:main.cpp      **** }
