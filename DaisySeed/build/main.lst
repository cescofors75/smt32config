1124:main.cpp      **** static inline float clampF(float v, float lo, float hi){
1125:main.cpp      ****     return v < lo ? lo : (v > hi ? hi : v);
1126:main.cpp      **** }
1127:main.cpp      **** 
1128:main.cpp      **** static inline float TriFromPhase(float ph)
1129:main.cpp      **** {
1130:main.cpp      ****     /* 0..1 -> -1..+1 */
1131:main.cpp      ****     float t = ph < 0.5f ? (ph * 2.0f) : (2.0f - ph * 2.0f);
1132:main.cpp      ****     return t * 2.0f - 1.0f;
1133:main.cpp      **** }
1134:main.cpp      **** 
