1115:main.cpp      **** static uint16_t crc16(const uint8_t* d, uint16_t len){
1116:main.cpp      ****     uint16_t crc = 0xFFFF;
1117:main.cpp      ****     for(uint16_t i = 0; i < len; i++){
1118:main.cpp      ****         crc ^= d[i];
1119:main.cpp      ****         for(uint8_t j = 0; j < 8; j++)
1120:main.cpp      ****             crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : (crc >> 1);
1121:main.cpp      ****     }
1122:main.cpp      ****     return crc;
1123:main.cpp      **** }
1124:main.cpp      **** 
1125:main.cpp      **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
