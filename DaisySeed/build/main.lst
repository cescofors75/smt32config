 383:main.cpp      ****  *  10. BiquadEQ  (Audio EQ Cookbook ŌĆō LP/HP/BP/Notch/Peak/Shelf)
 384:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 385:main.cpp      **** struct BiquadEQ {
 386:main.cpp      ****     float b0=1,b1=0,b2=0,a1=0,a2=0;
 387:main.cpp      ****     float z1=0,z2=0;
 388:main.cpp      **** 
 389:main.cpp      ****     float Process(float in){
 390:main.cpp      ****         float out = b0*in + z1;
 391:main.cpp      ****         z1 = b1*in - a1*out + z2;
 392:main.cpp      ****         z2 = b2*in - a2*out;
 393:main.cpp      ****         return out;
 394:main.cpp      ****     }
 395:main.cpp      ****     void Reset(){ z1=z2=0; }
 396:main.cpp      **** 
 397:main.cpp      ****     void SetType(uint8_t t, float freq, float q, float sr, float gainDb=0.f){
 398:main.cpp      ****         if(freq<20.f) freq=20.f;
 399:main.cpp      ****         if(freq>sr*0.45f) freq=sr*0.45f;
 400:main.cpp      ****         if(q<0.3f) q=0.3f;
 401:main.cpp      ****         float w = 2.f*(float)M_PI*freq/sr;
 402:main.cpp      ****         float s_ = sinf(w), c_ = cosf(w);
 403:main.cpp      ****         float a  = s_/(2.f*q);
 404:main.cpp      ****         float a0i;
 405:main.cpp      ****         switch(t){
 406:main.cpp      ****             case FTYPE_LOWPASS:
 407:main.cpp      ****                 a0i = 1.f/(1.f+a);
 408:main.cpp      ****                 b0 = ((1.f-c_)*0.5f)*a0i;
 409:main.cpp      ****                 b1 = (1.f-c_)*a0i;
 410:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 411:main.cpp      ****                 break;
 412:main.cpp      ****             case FTYPE_HIGHPASS:
 413:main.cpp      ****                 a0i = 1.f/(1.f+a);
 414:main.cpp      ****                 b0 = ((1.f+c_)*0.5f)*a0i;
 415:main.cpp      ****                 b1 = -(1.f+c_)*a0i;
 416:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 417:main.cpp      ****                 break;
 418:main.cpp      ****             case FTYPE_BANDPASS:
 419:main.cpp      ****                 a0i = 1.f/(1.f+a);
 420:main.cpp      ****                 b0 = a*a0i; b1=0; b2=-b0;
 421:main.cpp      ****                 a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 422:main.cpp      ****                 break;
 423:main.cpp      ****             case FTYPE_NOTCH:
 424:main.cpp      ****                 a0i = 1.f/(1.f+a);
 425:main.cpp      ****                 b0 = a0i; b1=(-2.f*c_)*a0i; b2=a0i;
 426:main.cpp      ****                 a1=b1; a2=(1.f-a)*a0i;
 427:main.cpp      ****                 break;
 428:main.cpp      ****             case FTYPE_PEAKING: {
 429:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 27


 430:main.cpp      ****                 a0i = 1.f/(1.f + a/A);
 431:main.cpp      ****                 b0 = (1.f + a*A)*a0i;
 432:main.cpp      ****                 b1 = (-2.f*c_)*a0i;
 433:main.cpp      ****                 b2 = (1.f - a*A)*a0i;
 434:main.cpp      ****                 a1 = b1; a2 = (1.f - a/A)*a0i;
 435:main.cpp      ****                 break;
 436:main.cpp      ****             }
 437:main.cpp      ****             case FTYPE_LOWSHELF: {
 438:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 439:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 440:main.cpp      ****                 a0i = 1.f/((A+1.f)+(A-1.f)*c_+sq);
 441:main.cpp      ****                 b0 = A*((A+1.f)-(A-1.f)*c_+sq)*a0i;
 442:main.cpp      ****                 b1 = 2.f*A*((A-1.f)-(A+1.f)*c_)*a0i;
 443:main.cpp      ****                 b2 = A*((A+1.f)-(A-1.f)*c_-sq)*a0i;
 444:main.cpp      ****                 a1 = -2.f*((A-1.f)+(A+1.f)*c_)*a0i;
 445:main.cpp      ****                 a2 = ((A+1.f)+(A-1.f)*c_-sq)*a0i;
 446:main.cpp      ****                 break;
 447:main.cpp      ****             }
 448:main.cpp      ****             case FTYPE_HIGHSHELF: {
 449:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 450:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 451:main.cpp      ****                 a0i = 1.f/((A+1.f)-(A-1.f)*c_+sq);
 452:main.cpp      ****                 b0 = A*((A+1.f)+(A-1.f)*c_+sq)*a0i;
 453:main.cpp      ****                 b1 = -2.f*A*((A-1.f)+(A+1.f)*c_)*a0i;
 454:main.cpp      ****                 b2 = A*((A+1.f)+(A-1.f)*c_-sq)*a0i;
 455:main.cpp      ****                 a1 = 2.f*((A-1.f)-(A+1.f)*c_)*a0i;
 456:main.cpp      ****                 a2 = ((A+1.f)-(A-1.f)*c_+sq)*a0i;
 457:main.cpp      ****                 break;
 458:main.cpp      ****             }
 459:main.cpp      ****             default: b0=1;b1=b2=a1=a2=0; break;
 460:main.cpp      ****         }
 461:main.cpp      ****     }
 462:main.cpp      **** };
