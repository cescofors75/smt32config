 720:synth/tr808.h ****  *  COWBELL 808
 721:synth/tr808.h ****  *  Dos ondas cuadradas desafinadas (540 Hz + 800 Hz)
 722:synth/tr808.h ****  *  Sonido met├Īlico caracter├Łstico
 723:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 724:synth/tr808.h **** class Cowbell {
 725:synth/tr808.h **** public:
 726:synth/tr808.h ****     float decay  = 0.08f;
 727:synth/tr808.h ****     float volume = 1.0f;
 728:synth/tr808.h **** 
 729:synth/tr808.h ****     void Init(float sampleRate) {
 730:synth/tr808.h ****         sr_ = sampleRate;
 731:synth/tr808.h ****         dt_ = 1.0f / sr_;
 732:synth/tr808.h ****         active_ = false;
 733:synth/tr808.h ****     }
 734:synth/tr808.h **** 
 735:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 736:synth/tr808.h ****         active_ = true;
 737:synth/tr808.h ****         time_ = 0.0f;
 738:synth/tr808.h ****         phase1_ = 0.0f;
 739:synth/tr808.h ****         phase2_ = 0.0f;
 740:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 741:synth/tr808.h ****     }
 742:synth/tr808.h **** 
 743:synth/tr808.h ****     float Process() {
 744:synth/tr808.h ****         if (!active_) return 0.0f;
 745:synth/tr808.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 159


 746:synth/tr808.h ****         /* Dos square waves desafinadas */
 747:synth/tr808.h ****         phase1_ += 540.0f * dt_;
 748:synth/tr808.h ****         if (phase1_ >= 1.0f) phase1_ -= 1.0f;
 749:synth/tr808.h ****         float sq1 = (phase1_ < 0.5f) ? 1.0f : -1.0f;
 750:synth/tr808.h **** 
 751:synth/tr808.h ****         phase2_ += 800.0f * dt_;
 752:synth/tr808.h ****         if (phase2_ >= 1.0f) phase2_ -= 1.0f;
 753:synth/tr808.h ****         float sq2 = (phase2_ < 0.5f) ? 1.0f : -1.0f;
 754:synth/tr808.h **** 
 755:synth/tr808.h ****         float mix = (sq1 + sq2) * 0.5f;
 756:synth/tr808.h **** 
 757:synth/tr808.h ****         /* Envelope con dos fases: attack r├Īpido, decay */
 758:synth/tr808.h ****         float env1 = expf(-time_ / 0.003f);  /* click */
 759:synth/tr808.h ****         float env2 = expf(-time_ / decay);    /* body  */
 760:synth/tr808.h ****         float env = env2 + (env1 - env2) * 0.3f;
 761:synth/tr808.h **** 
 762:synth/tr808.h ****         /* Bandpass ligero para suavizar */
 763:synth/tr808.h ****         float output = tanhf(mix * env * 1.5f);
 764:synth/tr808.h **** 
 765:synth/tr808.h ****         time_ += dt_;
 766:synth/tr808.h ****         if (env2 < 0.001f) active_ = false;
 767:synth/tr808.h **** 
 768:synth/tr808.h ****         return output * volume * vel_;
 769:synth/tr808.h ****     }
 770:synth/tr808.h **** 
 771:synth/tr808.h ****     bool IsActive() const { return active_; }
 772:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.03f, 0.5f); }
 773:synth/tr808.h **** 
 774:synth/tr808.h **** private:
 775:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 776:synth/tr808.h ****     bool  active_ = false;
 777:synth/tr808.h ****     float time_ = 0.0f;
 778:synth/tr808.h ****     float phase1_ = 0.0f, phase2_ = 0.0f;
 779:synth/tr808.h ****     float vel_ = 1.0f;
 780:synth/tr808.h **** };
