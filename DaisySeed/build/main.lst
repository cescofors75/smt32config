  27:synth/tb303.h **** namespace TB303 {
  28:synth/tb303.h **** 
  29:synth/tb303.h **** static inline float Clamp(float v, float lo, float hi) {
  30:synth/tb303.h ****     return v < lo ? lo : (v > hi ? hi : v);
  31:synth/tb303.h **** }
  32:synth/tb303.h **** 
  33:synth/tb303.h **** /* Conversi├│n MIDI ŌåÆ Hz */
  34:synth/tb303.h **** static inline float MidiToFreq(uint8_t note) {
  35:synth/tb303.h ****     return 440.0f * powf(2.0f, ((float)note - 69.0f) / 12.0f);
  36:synth/tb303.h **** }
