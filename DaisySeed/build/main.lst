1756:main.cpp      **** static float MySoftClip(float x){
1757:main.cpp      ****     if(x >  1.5f) return  1.0f;
1758:main.cpp      ****     if(x < -1.5f) return -1.0f;
1759:main.cpp      ****     return x - (x*x*x)/6.75f;
