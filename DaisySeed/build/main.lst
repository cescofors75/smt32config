 565:synth/tr909.h ****     }
 566:synth/tr909.h **** 
 567:synth/tr909.h ****     float Process() {
 568:synth/tr909.h ****         if (!active_) return 0.0f;
 569:synth/tr909.h **** 
 570:synth/tr909.h ****         float n = Noise(noiseState_);
 571:synth/tr909.h ****         float clickEnv = expf(-time_ / 0.0005f);
 572:synth/tr909.h ****         float click = n * clickEnv * 0.6f;
 573:synth/tr909.h **** 
