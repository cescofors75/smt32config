 567:synth/tr505.h **** class Kit {
 568:synth/tr505.h **** public:
 569:synth/tr505.h ****     Kick       kick;
 570:synth/tr505.h ****     Snare      snare;
 571:synth/tr505.h ****     Clap       clap;
 572:synth/tr505.h ****     HiHatClosed hihatC;
 573:synth/tr505.h ****     HiHatOpen   hihatO;
 574:synth/tr505.h ****     LowTom     lowTom;
 575:synth/tr505.h ****     MidTom     midTom;
 576:synth/tr505.h ****     HiTom      hiTom;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 335


 577:synth/tr505.h ****     Cowbell    cowbell;
 578:synth/tr505.h ****     Cymbal     cymbal;
 579:synth/tr505.h ****     RimShot    rimshot;
 580:synth/tr505.h **** 
 581:synth/tr505.h ****     void Init(float sampleRate) {
 582:synth/tr505.h ****         kick.Init(sampleRate);
 583:synth/tr505.h ****         snare.Init(sampleRate);
 584:synth/tr505.h ****         clap.Init(sampleRate);
 585:synth/tr505.h ****         hihatC.Init(sampleRate);
 586:synth/tr505.h ****         hihatO.Init(sampleRate);
 587:synth/tr505.h ****         lowTom.Init(sampleRate);
 588:synth/tr505.h ****         midTom.Init(sampleRate);
 589:synth/tr505.h ****         hiTom.Init(sampleRate);
 590:synth/tr505.h ****         cowbell.Init(sampleRate);
 591:synth/tr505.h ****         cymbal.Init(sampleRate);
 592:synth/tr505.h ****         rimshot.Init(sampleRate);
 593:synth/tr505.h ****     }
 594:synth/tr505.h **** 
 595:synth/tr505.h ****     void Trigger(uint8_t instrument, float velocity = 1.0f) {
 596:synth/tr505.h ****         switch (instrument) {
 597:synth/tr505.h ****             case INST_KICK:     kick.Trigger(velocity); break;
 598:synth/tr505.h ****             case INST_SNARE:    snare.Trigger(velocity); break;
 599:synth/tr505.h ****             case INST_CLAP:     clap.Trigger(velocity); break;
 600:synth/tr505.h ****             case INST_HIHAT_C:
 601:synth/tr505.h ****                 hihatO.Choke();
 602:synth/tr505.h ****                 hihatC.Trigger(velocity);
 603:synth/tr505.h ****                 break;
 604:synth/tr505.h ****             case INST_HIHAT_O:  hihatO.Trigger(velocity); break;
 605:synth/tr505.h ****             case INST_LOW_TOM:  lowTom.Trigger(velocity); break;
 606:synth/tr505.h ****             case INST_MID_TOM:  midTom.Trigger(velocity); break;
 607:synth/tr505.h ****             case INST_HI_TOM:   hiTom.Trigger(velocity); break;
 608:synth/tr505.h ****             case INST_COWBELL:  cowbell.Trigger(velocity); break;
 609:synth/tr505.h ****             case INST_CYMBAL:   cymbal.Trigger(velocity); break;
 610:synth/tr505.h ****             case INST_RIMSHOT:  rimshot.Trigger(velocity); break;
 611:synth/tr505.h ****         }
 612:synth/tr505.h ****     }
