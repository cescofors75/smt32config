 322:synth/tr505.h **** 
 323:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 324:synth/tr505.h ****  *  TOM 505
 325:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 326:synth/tr505.h **** class Tom505 {
 327:synth/tr505.h **** public:
 328:synth/tr505.h ****     float decay      = 0.15f;
 329:synth/tr505.h ****     float pitch      = 120.0f;
 330:synth/tr505.h ****     float pitchDecay = 0.025f;
 331:synth/tr505.h ****     float lofi       = 0.15f;
 332:synth/tr505.h ****     float volume     = 1.0f;
 333:synth/tr505.h **** 
 334:synth/tr505.h ****     void Init(float sampleRate) {
 335:synth/tr505.h ****         sr_ = sampleRate;
 336:synth/tr505.h ****         dt_ = 1.0f / sr_;
 337:synth/tr505.h ****         active_ = false;
 338:synth/tr505.h ****     }
 339:synth/tr505.h **** 
 340:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 341:synth/tr505.h ****         active_ = true;
 342:synth/tr505.h ****         time_ = 0.0f;
 343:synth/tr505.h ****         phase_ = 0.0f;
 344:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 345:synth/tr505.h ****     }
 346:synth/tr505.h **** 
 347:synth/tr505.h ****     float Process() {
 348:synth/tr505.h ****         if (!active_) return 0.0f;
 349:synth/tr505.h **** 
 350:synth/tr505.h ****         float cp = pitch + pitch * 1.5f * expf(-time_ / pitchDecay);
 351:synth/tr505.h ****         phase_ += cp * dt_;
 352:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 353:synth/tr505.h ****         float sine = sinf(TWOPI_F * phase_);
 354:synth/tr505.h **** 
 355:synth/tr505.h ****         float env = expf(-time_ / decay);
 356:synth/tr505.h ****         float output = sine * env;
 357:synth/tr505.h ****         output = LoFi(output, lofi);
 358:synth/tr505.h **** 
 359:synth/tr505.h ****         time_ += dt_;
 360:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 361:synth/tr505.h **** 
 362:synth/tr505.h ****         return output * volume * vel_;
 363:synth/tr505.h ****     }
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 383


 364:synth/tr505.h **** 
 365:synth/tr505.h ****     bool IsActive() const { return active_; }
