3889:main.cpp      ****      * D7=PG10(NSS) D8=PG11(SCK) D9=PB4(MISO) D10=PB5(MOSI)
3890:main.cpp      ****      * Mode0 (CPOL=0 CPHA=0), 8-bit, NSS hardware input               */
3891:main.cpp      ****     __HAL_RCC_SPI1_CLK_ENABLE();
3892:main.cpp      ****     __HAL_RCC_GPIOG_CLK_ENABLE();
3893:main.cpp      ****     __HAL_RCC_GPIOB_CLK_ENABLE();
3894:main.cpp      **** 
