1644:main.cpp      **** static float ApplyDist(float s, float drive, uint8_t mode){
1645:main.cpp      ****     if(drive < 0.01f) return s;
1646:main.cpp      ****     float d = 1.0f + drive * 15.0f;
1647:main.cpp      ****     s *= d;
1648:main.cpp      ****     switch(mode){
1649:main.cpp      ****         case DMODE_SOFT: s = MySoftClip(s); break;
1650:main.cpp      ****         case DMODE_HARD: s = clampF(s,-1.f,1.f); break;
1651:main.cpp      ****         case DMODE_TUBE: s = tanhf(s); break;
1652:main.cpp      ****         case DMODE_FUZZ:
1653:main.cpp      ****             while(s >  1.f || s < -1.f){
1654:main.cpp      ****                 if(s >  1.f) s =  2.f - s;
1655:main.cpp      ****                 if(s < -1.f) s = -2.f - s;
1656:main.cpp      ****             }
1657:main.cpp      ****             break;
1658:main.cpp      ****     }
1659:main.cpp      ****     return s / d * (1.f + drive * 0.5f);
1660:main.cpp      **** }
