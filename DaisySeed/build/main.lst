3698:main.cpp      **** static bool LoadFirstWavFromFolderToPad(const char* folderPath, uint8_t padIdx)
3699:main.cpp      **** {
3700:main.cpp      ****     DIR dir;
3701:main.cpp      ****     FILINFO fno;
3702:main.cpp      ****     char bestName[64] = {};
3703:main.cpp      ****     bool found = false;
3704:main.cpp      **** 
3705:main.cpp      ****     if(f_opendir(&dir, folderPath) != FR_OK)
3706:main.cpp      ****         return false;
3707:main.cpp      **** 
3708:main.cpp      ****     while(f_readdir(&dir, &fno) == FR_OK && fno.fname[0]){
3709:main.cpp      ****         if(fno.fattrib & AM_DIR) continue;
3710:main.cpp      ****         if(!isWavFile(fno.fname)) continue;
3711:main.cpp      **** 
3712:main.cpp      ****         if(!found || compareCI(fno.fname, bestName) < 0){
3713:main.cpp      ****             strncpy(bestName, fno.fname, sizeof(bestName) - 1);
3714:main.cpp      ****             bestName[sizeof(bestName) - 1] = 0;
3715:main.cpp      ****             found = true;
3716:main.cpp      ****         }
3717:main.cpp      ****     }
3718:main.cpp      ****     f_closedir(&dir);
3719:main.cpp      **** 
3720:main.cpp      ****     if(!found)
3721:main.cpp      ****         return false;
3722:main.cpp      **** 
3723:main.cpp      ****     char fpath[192];
3724:main.cpp      ****     snprintf(fpath, sizeof(fpath), "%s/%s", folderPath, bestName);
3725:main.cpp      ****     return LoadWavToPad(fpath, padIdx);
3726:main.cpp      **** }
