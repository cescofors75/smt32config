1128:main.cpp      **** static inline float clampF(float v, float lo, float hi){
1129:main.cpp      ****     return v < lo ? lo : (v > hi ? hi : v);
1130:main.cpp      **** }
1131:main.cpp      **** 
1132:main.cpp      **** static inline float VolumeByteToGain(uint8_t volumePct)
1133:main.cpp      **** {
1134:main.cpp      ****     return clampF((float)volumePct, 0.0f, 150.0f) / 100.0f;
1135:main.cpp      **** }
1136:main.cpp      **** 
1137:main.cpp      **** static inline float SoftClipKnee(float x)
1138:main.cpp      **** {
1139:main.cpp      ****     const float knee = 0.9f;
1140:main.cpp      ****     if(x > knee)
1141:main.cpp      ****     {
1142:main.cpp      ****         float t = x - knee;
1143:main.cpp      ****         return knee + t / (1.0f + t * t);
1144:main.cpp      ****     }
1145:main.cpp      ****     if(x < -knee)
1146:main.cpp      ****     {
1147:main.cpp      ****         float t = x + knee;
1148:main.cpp      ****         return -knee + t / (1.0f + t * t);
1149:main.cpp      ****     }
1150:main.cpp      ****     return x;
1151:main.cpp      **** }
1152:main.cpp      **** 
1153:main.cpp      **** static inline float TriFromPhase(float ph)
1154:main.cpp      **** {
1155:main.cpp      ****     /* 0..1 -> -1..+1 */
1156:main.cpp      ****     float t = ph < 0.5f ? (ph * 2.0f) : (2.0f - ph * 2.0f);
1157:main.cpp      ****     return t * 2.0f - 1.0f;
1158:main.cpp      **** }
1159:main.cpp      **** 
1160:main.cpp      **** static inline float AdDecayCoefFromMs(float decayMs)
1161:main.cpp      **** {
1162:main.cpp      ****     float samples = clampF(decayMs, 1.0f, 8000.0f) * (float)SAMPLE_RATE * 0.001f;
1163:main.cpp      ****     return expf(-1.0f / samples);
1164:main.cpp      **** }
