3637:main.cpp      **** static bool LoadWavToPad(const char* filepath, uint8_t padIdx)
3638:main.cpp      **** {
3639:main.cpp      ****     if(padIdx >= MAX_PADS) return false;
3640:main.cpp      ****     FIL fil;
3641:main.cpp      ****     if(f_open(&fil, filepath, FA_READ) != FR_OK) return false;
3642:main.cpp      **** 
3643:main.cpp      ****     /* Simple WAV header parse: find "data" chunk */
3644:main.cpp      ****     uint8_t hdr[44];
3645:main.cpp      ****     UINT br;
3646:main.cpp      ****     if(f_read(&fil, hdr, 44, &br) != FR_OK || br < 44){
3647:main.cpp      ****         f_close(&fil); return false;
3648:main.cpp      ****     }
3649:main.cpp      ****     if(memcmp(hdr, "RIFF", 4) != 0 || memcmp(hdr+8, "WAVE", 4) != 0){
3650:main.cpp      ****         f_close(&fil); return false;
3651:main.cpp      ****     }
3652:main.cpp      **** 
3653:main.cpp      ****     uint16_t ch  = hdr[22] | (hdr[23]<<8);
3654:main.cpp      ****     uint32_t sr  = hdr[24]|(hdr[25]<<8)|(hdr[26]<<16)|(hdr[27]<<24);
3655:main.cpp      ****     uint16_t bps = hdr[34] | (hdr[35]<<8);
3656:main.cpp      ****     (void)sr;
3657:main.cpp      **** 
3658:main.cpp      ****     /* Skip to data chunk */
3659:main.cpp      ****     uint32_t pos = 12;
3660:main.cpp      ****     f_lseek(&fil, 12);
3661:main.cpp      ****     uint32_t dataSize = 0;
3662:main.cpp      ****     while(pos < f_size(&fil) - 8){
3663:main.cpp      ****         uint8_t ck[8];
3664:main.cpp      ****         if(f_read(&fil, ck, 8, &br) != FR_OK || br < 8) break;
3665:main.cpp      ****         uint32_t ckSz = ck[4]|(ck[5]<<8)|(ck[6]<<16)|(ck[7]<<24);
3666:main.cpp      ****         if(memcmp(ck, "data", 4) == 0){
3667:main.cpp      ****             dataSize = ckSz;
3668:main.cpp      ****             break;
3669:main.cpp      ****         }
3670:main.cpp      ****         f_lseek(&fil, f_tell(&fil) + ckSz);
3671:main.cpp      ****         pos += 8 + ckSz;
3672:main.cpp      ****     }
3673:main.cpp      ****     if(dataSize == 0){ f_close(&fil); return false; }
3674:main.cpp      **** 
3675:main.cpp      ****     uint32_t bytesPerFrame = (bps/8) * ch;
3676:main.cpp      ****     if(bytesPerFrame == 0){ f_close(&fil); return false; }
3677:main.cpp      ****     uint32_t totalFrames = dataSize / bytesPerFrame;
3678:main.cpp      ****     if(totalFrames > MAX_SAMPLE_BYTES / 2) totalFrames = MAX_SAMPLE_BYTES / 2;
