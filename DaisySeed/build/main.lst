 782:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 783:synth/tr808.h ****  *  CYMBAL 808
 784:synth/tr808.h ****  *  Metallic noise (6 square waves) + bandpass largo
 785:synth/tr808.h ****  *  Como el hihat pero con decay mucho m├Īs largo
 786:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 787:synth/tr808.h **** class Cymbal : public HiHatBase {
 788:synth/tr808.h **** public:
 789:synth/tr808.h ****     float decay  = 0.8f;    /* 0.3 - 3.0 s */
 790:synth/tr808.h ****     float tone   = 0.6f;
 791:synth/tr808.h ****     float volume = 1.0f;
 792:synth/tr808.h **** 
 793:synth/tr808.h ****     void Init(float sampleRate) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 165


 794:synth/tr808.h ****         sr_ = sampleRate;
 795:synth/tr808.h ****         dt_ = 1.0f / sr_;
 796:synth/tr808.h ****         active_ = false;
 797:synth/tr808.h ****     }
 798:synth/tr808.h **** 
 799:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 800:synth/tr808.h ****         active_ = true;
 801:synth/tr808.h ****         time_ = 0.0f;
 802:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 803:synth/tr808.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 804:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 805:synth/tr808.h ****     }
 806:synth/tr808.h **** 
 807:synth/tr808.h ****     float Process() {
 808:synth/tr808.h ****         if (!active_) return 0.0f;
 809:synth/tr808.h **** 
 810:synth/tr808.h ****         float metal = MetallicNoise();
 811:synth/tr808.h ****         float hp = Highpass(metal);
 812:synth/tr808.h **** 
 813:synth/tr808.h ****         /* Decay largo con onset r├Īpido */
 814:synth/tr808.h ****         float env = expf(-time_ / decay);
 815:synth/tr808.h ****         float attack = 1.0f - expf(-time_ / 0.002f);
 816:synth/tr808.h **** 
 817:synth/tr808.h ****         float output = hp * env * attack * (0.4f + tone * 0.6f);
 818:synth/tr808.h ****         output = tanhf(output * 1.8f);
 819:synth/tr808.h **** 
 820:synth/tr808.h ****         time_ += dt_;
 821:synth/tr808.h ****         if (env < 0.0005f) active_ = false;
 822:synth/tr808.h **** 
 823:synth/tr808.h ****         return output * volume * vel_;
 824:synth/tr808.h ****     }
 825:synth/tr808.h **** 
 826:synth/tr808.h ****     bool IsActive() const { return active_; }
 827:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.1f, 5.0f); }
 828:synth/tr808.h **** };
