  93:synth/demo_mode.h **** 
  94:synth/demo_mode.h **** /* Patr├│n acid cl├Īsico en Am */
  95:synth/demo_mode.h **** static const AcidStep ACID_PATTERN[16] = {
  96:synth/demo_mode.h ****     { 36, false, false, false },   /* C2  */
  97:synth/demo_mode.h ****     {  0, false, false, false },   /* tie */
  98:synth/demo_mode.h ****     { 36, false, false, true  },   /* C2  corto */
  99:synth/demo_mode.h ****     { 39, true,  false, false },   /* Eb2 accent */
 100:synth/demo_mode.h ****     { 36, false, true,  false },   /* C2  slide from Eb */
 101:synth/demo_mode.h ****     {  0, false, false, false },   /* tie */
 102:synth/demo_mode.h ****     { 48, true,  false, true  },   /* C3  accent corto */
 103:synth/demo_mode.h ****     { 36, false, false, false },   /* C2  */
 104:synth/demo_mode.h ****     { 43, false, false, false },   /* G2  */
 105:synth/demo_mode.h ****     {  0, false, false, false },   /* tie */
 106:synth/demo_mode.h ****     { 41, true,  true,  false },   /* F2  accent slide */
 107:synth/demo_mode.h ****     { 36, false, true,  false },   /* C2  slide from F */
 108:synth/demo_mode.h ****     {  0, false, false, true  },   /* rest + noteOff */
 109:synth/demo_mode.h ****     { 36, false, false, false },   /* C2  */
 110:synth/demo_mode.h ****     { 44, true,  false, true  },   /* Ab2 accent corto */
 111:synth/demo_mode.h ****     { 36, false, false, false },   /* C2  */
 112:synth/demo_mode.h **** };
