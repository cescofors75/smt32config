 599:synth/tr808.h ****     bool  active_ = false;
 600:synth/tr808.h ****     float time_ = 0.0f;
 601:synth/tr808.h ****     float phase_ = 0.0f;
 602:synth/tr808.h ****     float vel_ = 1.0f;
 603:synth/tr808.h **** };
