 213:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 214:synth/tr505.h ****  *  HIHAT 505 ŌĆö M├Īs simple, solo noise filtrado
 215:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 216:synth/tr505.h **** class HiHatClosed {
 217:synth/tr505.h **** public:
 218:synth/tr505.h ****     float decay  = 0.03f;
 219:synth/tr505.h ****     float tone   = 0.5f;
 220:synth/tr505.h ****     float lofi   = 0.2f;
 221:synth/tr505.h ****     float volume = 1.0f;
 222:synth/tr505.h **** 
 223:synth/tr505.h ****     void Init(float sampleRate) {
 224:synth/tr505.h ****         sr_ = sampleRate;
 225:synth/tr505.h ****         dt_ = 1.0f / sr_;
 226:synth/tr505.h ****         active_ = false;
 227:synth/tr505.h ****         noiseState_ = 0x505AA01;
 228:synth/tr505.h ****     }
 229:synth/tr505.h **** 
 230:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 231:synth/tr505.h ****         active_ = true;
 232:synth/tr505.h ****         time_ = 0.0f;
 233:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 234:synth/tr505.h ****         hpZ1_ = hpOut_ = 0.0f;
 235:synth/tr505.h ****     }
 236:synth/tr505.h **** 
 237:synth/tr505.h ****     float Process() {
 238:synth/tr505.h ****         if (!active_) return 0.0f;
 239:synth/tr505.h **** 
 240:synth/tr505.h ****         float n = Noise(noiseState_);
 241:synth/tr505.h **** 
 242:synth/tr505.h ****         /* Highpass ~5kHz */
 243:synth/tr505.h ****         float fc = 4000.0f + tone * 4000.0f;
 244:synth/tr505.h ****         float rc = 1.0f / (TWOPI_F * fc);
 245:synth/tr505.h ****         float alpha = rc / (rc + dt_);
 246:synth/tr505.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 247:synth/tr505.h ****         hpZ1_ = n;
 248:synth/tr505.h **** 
 249:synth/tr505.h ****         float env = expf(-time_ / decay);
 250:synth/tr505.h ****         float output = hpOut_ * env;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 336


 251:synth/tr505.h ****         output = LoFi(output, lofi);
 252:synth/tr505.h **** 
 253:synth/tr505.h ****         time_ += dt_;
 254:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 255:synth/tr505.h **** 
 256:synth/tr505.h ****         return output * volume * vel_;
 257:synth/tr505.h ****     }
 258:synth/tr505.h **** 
 259:synth/tr505.h ****     bool IsActive() const { return active_; }
 260:synth/tr505.h **** 
 261:synth/tr505.h **** private:
 262:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 263:synth/tr505.h ****     bool  active_ = false;
 264:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 265:synth/tr505.h ****     uint32_t noiseState_ = 0x505AA01;
 266:synth/tr505.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 267:synth/tr505.h **** };
 268:synth/tr505.h **** 
 269:synth/tr505.h **** class HiHatOpen {
 270:synth/tr505.h **** public:
 271:synth/tr505.h ****     float decay  = 0.2f;
 272:synth/tr505.h ****     float tone   = 0.5f;
 273:synth/tr505.h ****     float lofi   = 0.2f;
 274:synth/tr505.h ****     float volume = 1.0f;
 275:synth/tr505.h **** 
 276:synth/tr505.h ****     void Init(float sampleRate) {
 277:synth/tr505.h ****         sr_ = sampleRate;
 278:synth/tr505.h ****         dt_ = 1.0f / sr_;
 279:synth/tr505.h ****         active_ = false;
 280:synth/tr505.h ****         noiseState_ = 0x505BB02;
 281:synth/tr505.h ****     }
 282:synth/tr505.h **** 
 283:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 284:synth/tr505.h ****         active_ = true;
 285:synth/tr505.h ****         time_ = 0.0f;
 286:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 287:synth/tr505.h ****         hpZ1_ = hpOut_ = 0.0f;
 288:synth/tr505.h ****     }
 289:synth/tr505.h **** 
 290:synth/tr505.h ****     void Choke() { active_ = false; }
 291:synth/tr505.h **** 
 292:synth/tr505.h ****     float Process() {
 293:synth/tr505.h ****         if (!active_) return 0.0f;
 294:synth/tr505.h **** 
 295:synth/tr505.h ****         float n = Noise(noiseState_);
 296:synth/tr505.h **** 
 297:synth/tr505.h ****         float fc = 4000.0f + tone * 4000.0f;
 298:synth/tr505.h ****         float rc = 1.0f / (TWOPI_F * fc);
 299:synth/tr505.h ****         float alpha = rc / (rc + dt_);
 300:synth/tr505.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 301:synth/tr505.h ****         hpZ1_ = n;
 302:synth/tr505.h **** 
 303:synth/tr505.h ****         float env = expf(-time_ / decay);
 304:synth/tr505.h ****         float output = hpOut_ * env;
 305:synth/tr505.h ****         output = LoFi(output, lofi);
 306:synth/tr505.h **** 
 307:synth/tr505.h ****         time_ += dt_;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 337


 308:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 309:synth/tr505.h **** 
 310:synth/tr505.h ****         return output * volume * vel_;
 311:synth/tr505.h ****     }
 312:synth/tr505.h **** 
 313:synth/tr505.h ****     bool IsActive() const { return active_; }
 314:synth/tr505.h **** 
 315:synth/tr505.h **** private:
 316:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 317:synth/tr505.h ****     bool  active_ = false;
 318:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 319:synth/tr505.h ****     uint32_t noiseState_ = 0x505BB02;
 320:synth/tr505.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 321:synth/tr505.h **** };
