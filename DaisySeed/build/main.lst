 887:main.cpp      **** struct __attribute__((packed)) NotifyEvent {
 888:main.cpp      ****     uint8_t  type;          /* EVT_SD_* */
 889:main.cpp      ****     uint8_t  padCount;      /* cu├Īntos pads afectados */
 890:main.cpp      ****     uint8_t  padMaskLo;     /* bitmask pads 0-7  loaded */
 891:main.cpp      ****     uint8_t  padMaskHi;     /* bitmask pads 8-15 loaded */
 892:main.cpp      ****     uint8_t  padMaskXtra;   /* bitmask pads 16-23 loaded */
 893:main.cpp      ****     uint8_t  reserved[3];
 894:main.cpp      ****     char     name[24];      /* kit name / sample name */
 895:main.cpp      **** };  /* 32 bytes */
 896:main.cpp      **** 
 897:main.cpp      **** #define EVT_QUEUE_SIZE 8
 898:main.cpp      **** static NotifyEvent evtQueue[EVT_QUEUE_SIZE];
 899:main.cpp      **** static volatile uint8_t evtHead = 0;  /* next write position  */
 900:main.cpp      **** static volatile uint8_t evtTail = 0;  /* next read  position  */
 901:main.cpp      **** static volatile uint8_t evtCount = 0; /* events in queue      */
 902:main.cpp      **** 
 903:main.cpp      **** static void PushEvent(uint8_t type, uint8_t padCount,
 904:main.cpp      ****                       uint32_t padMask24, const char* name)
 905:main.cpp      **** {
 906:main.cpp      ****     if(evtCount >= EVT_QUEUE_SIZE){
 907:main.cpp      ****         /* Queue full ŌĆö overwrite oldest */
 908:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 909:main.cpp      ****         evtCount--;
 910:main.cpp      ****     }
 911:main.cpp      ****     NotifyEvent& e = evtQueue[evtHead];
 912:main.cpp      ****     memset(&e, 0, sizeof(e));
 913:main.cpp      ****     e.type       = type;
 914:main.cpp      ****     e.padCount   = padCount;
 915:main.cpp      ****     e.padMaskLo  = (uint8_t)(padMask24 & 0xFF);
 916:main.cpp      ****     e.padMaskHi  = (uint8_t)((padMask24 >> 8) & 0xFF);
 917:main.cpp      ****     e.padMaskXtra= (uint8_t)((padMask24 >> 16) & 0xFF);
 918:main.cpp      ****     if(name) strncpy(e.name, name, 23);
 919:main.cpp      ****     evtHead = (evtHead + 1) % EVT_QUEUE_SIZE;
 920:main.cpp      ****     evtCount++;
 921:main.cpp      **** }
 922:main.cpp      **** 
 923:main.cpp      **** static uint8_t PopEvents(NotifyEvent* dst, uint8_t maxEvents)
 924:main.cpp      **** {
 925:main.cpp      ****     uint8_t count = 0;
 926:main.cpp      ****     while(evtCount > 0 && count < maxEvents){
 927:main.cpp      ****         dst[count++] = evtQueue[evtTail];
 928:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 929:main.cpp      ****         evtCount--;
 930:main.cpp      ****     }
 931:main.cpp      ****     return count;
 932:main.cpp      **** }
