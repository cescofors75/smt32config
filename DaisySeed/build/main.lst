1662:main.cpp      **** static float BitCrush(float s, uint8_t bits){
1663:main.cpp      ****     if(bits >= 16) return s;
1664:main.cpp      ****     float levels = (float)(1 << bits);
1665:main.cpp      ****     return roundf(s * levels) / levels;
1666:main.cpp      **** }
