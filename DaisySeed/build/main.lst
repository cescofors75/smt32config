1638:main.cpp      **** static float MySoftClip(float x){
1639:main.cpp      ****     if(x >  1.5f) return  1.0f;
1640:main.cpp      ****     if(x < -1.5f) return -1.0f;
1641:main.cpp      ****     return x - (x*x*x)/6.75f;
