3411:main.cpp      ****  *  24. UART RX ŌĆö 100% byte-a-byte, DMA target SIEMPRE en rxBuf
3412:main.cpp      ****  *      IMPORTANTE: En STM32H750 el DMA NO puede acceder a DTCM SRAM.
3413:main.cpp      ****  *      Variables static pueden caer en DTCM. rxBuf est├Ī en D2-SRAM
3414:main.cpp      ****  *      (accesible por DMA). Por eso recibimos SIEMPRE dentro de rxBuf.
3415:main.cpp      ****  *      El "piu piu piu" funcion├│ porque usaba rxBuf como target.
3416:main.cpp      ****  *
3417:main.cpp      ****  *      M├Īquina de estados:
3418:main.cpp      ****  *        SCAN    ŌåÆ DMA 1 byte a rxBuf[0], buscando 0xA5
3419:main.cpp      ****  *        HEADER  ŌåÆ DMA 1 byte a rxBuf[idx], acumulando header
3420:main.cpp      ****  *        PAYLOAD ŌåÆ DMA 1 byte a rxBuf[idx], acumulando payload
3421:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
3422:main.cpp      **** 
3423:main.cpp      **** /* NO usamos variable separada ŌĆö DMA siempre escribe en rxBuf[pos] */
3424:main.cpp      **** static volatile uint16_t uartAccumIdx;    /* siguiente posici├│n en rxBuf */
3425:main.cpp      **** static volatile uint16_t uartExpectedLen; /* bytes totales a acumular    */
3426:main.cpp      **** 
3427:main.cpp      **** enum UartRxState { UART_ST_SCAN, UART_ST_HEADER, UART_ST_PAYLOAD };
3428:main.cpp      **** static volatile UartRxState uartRxState = UART_ST_SCAN;
3429:main.cpp      **** 
3430:main.cpp      **** static void UartRxByteCb(void* ctx, UartHandler::Result res);
3431:main.cpp      **** 
3432:main.cpp      **** static void UartStartScan()
3433:main.cpp      **** {
3434:main.cpp      ****     uartRxState = UART_ST_SCAN;
3435:main.cpp      ****     /* DMA escribe directo en rxBuf[0] ŌĆö zona accesible por DMA */
3436:main.cpp      ****     uart_slave.DmaReceive(rxBuf, 1, nullptr, UartRxByteCb, nullptr);
3437:main.cpp      **** }
3438:main.cpp      **** 
3439:main.cpp      **** /* Callback ŌĆö se llama cada vez que llega 1 byte (en rxBuf) */
3440:main.cpp      **** static void UartRxByteCb(void* ctx, UartHandler::Result res)
3441:main.cpp      **** {
3442:main.cpp      ****     if(res != UartHandler::Result::OK){
3443:main.cpp      ****         spiErrCnt++;
3444:main.cpp      ****         UartStartScan();
3445:main.cpp      ****         return;
3446:main.cpp      ****     }
3447:main.cpp      **** 
3448:main.cpp      ****     uint32_t now = hw.system.GetNow();
