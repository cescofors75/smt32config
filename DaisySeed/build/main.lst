 498:synth/tr505.h **** class RimShot {
 499:synth/tr505.h **** public:
 500:synth/tr505.h ****     float decay  = 0.02f;
 501:synth/tr505.h ****     float lofi   = 0.15f;
 502:synth/tr505.h ****     float volume = 1.0f;
 503:synth/tr505.h **** 
 504:synth/tr505.h ****     void Init(float sampleRate) {
 505:synth/tr505.h ****         sr_ = sampleRate;
 506:synth/tr505.h ****         dt_ = 1.0f / sr_;
 507:synth/tr505.h ****         active_ = false;
 508:synth/tr505.h ****         noiseState_ = 0x505DD04;
 509:synth/tr505.h ****     }
 510:synth/tr505.h **** 
 511:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 512:synth/tr505.h ****         active_ = true;
 513:synth/tr505.h ****         time_ = 0.0f;
 514:synth/tr505.h ****         phase_ = 0.0f;
 515:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 516:synth/tr505.h ****     }
 517:synth/tr505.h **** 
 518:synth/tr505.h ****     float Process() {
 519:synth/tr505.h ****         if (!active_) return 0.0f;
 520:synth/tr505.h **** 
 521:synth/tr505.h ****         float n = Noise(noiseState_);
 522:synth/tr505.h ****         float clickEnv = expf(-time_ / 0.0008f);
 523:synth/tr505.h ****         float click = n * clickEnv * 0.4f;
 524:synth/tr505.h **** 
 525:synth/tr505.h ****         phase_ += 750.0f * dt_;
 526:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 527:synth/tr505.h ****         float sine = sinf(TWOPI_F * phase_);
 528:synth/tr505.h ****         float toneEnv = expf(-time_ / decay);
 529:synth/tr505.h **** 
 530:synth/tr505.h ****         float output = click + sine * toneEnv;
 531:synth/tr505.h ****         output = tanhf(output * 1.5f);
 532:synth/tr505.h ****         output = LoFi(output, lofi);
 533:synth/tr505.h **** 
 534:synth/tr505.h ****         time_ += dt_;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 386


 535:synth/tr505.h ****         if (toneEnv < 0.001f) active_ = false;
 536:synth/tr505.h **** 
 537:synth/tr505.h ****         return output * volume * vel_;
 538:synth/tr505.h ****     }
 539:synth/tr505.h **** 
 540:synth/tr505.h ****     bool IsActive() const { return active_; }
 541:synth/tr505.h **** 
 542:synth/tr505.h **** private:
 543:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 544:synth/tr505.h ****     bool  active_ = false;
 545:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 546:synth/tr505.h ****     uint32_t noiseState_ = 0x505DD04;
 547:synth/tr505.h **** };
