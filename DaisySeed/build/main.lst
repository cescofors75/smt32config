 258:synth/tr909.h **** 
 259:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 260:synth/tr909.h ****  *  HIHAT 909 BASE
 261:synth/tr909.h ****  *  6 pulsos met├Īlicos ŌĆö frecuencias diferentes a la 808
 262:synth/tr909.h ****  *  M├Īs brillante, m├Īs "digital" en car├Īcter
 263:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 264:synth/tr909.h **** class HiHat909Base {
 265:synth/tr909.h **** protected:
 266:synth/tr909.h ****     static constexpr float METAL_FREQS[6] = {
 267:synth/tr909.h ****         263.5f, 400.0f, 531.0f, 588.0f, 678.0f, 1043.0f
 268:synth/tr909.h ****     };
 269:synth/tr909.h **** 
 270:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 271:synth/tr909.h ****     bool  active_ = false;
 272:synth/tr909.h ****     float time_ = 0.0f, vel_ = 1.0f;
 273:synth/tr909.h ****     float phase_[6] = {};
 274:synth/tr909.h ****     uint32_t noiseState_ = 0x909AA01;
 275:synth/tr909.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 276:synth/tr909.h **** 
 277:synth/tr909.h ****     float MetallicNoise() {
 278:synth/tr909.h ****         float sum = 0.0f;
 279:synth/tr909.h ****         for (int i = 0; i < 6; i++) {
 280:synth/tr909.h ****             phase_[i] += METAL_FREQS[i] * dt_;
 281:synth/tr909.h ****             if (phase_[i] >= 1.0f) phase_[i] -= 1.0f;
 282:synth/tr909.h ****             sum += (phase_[i] < 0.5f) ? 1.0f : -1.0f;
 283:synth/tr909.h ****         }
 284:synth/tr909.h ****         float n = Noise(noiseState_) * 0.2f;
 285:synth/tr909.h ****         return (sum / 6.0f + n);
 286:synth/tr909.h ****     }
 287:synth/tr909.h **** 
 288:synth/tr909.h ****     float Highpass(float in) {
 289:synth/tr909.h ****         float rc = 1.0f / (TWOPI_F * 7500.0f); /* m├Īs alto que 808 */
 290:synth/tr909.h ****         float alpha = rc / (rc + dt_);
 291:synth/tr909.h ****         hpOut_ = alpha * (hpOut_ + in - hpZ1_);
 292:synth/tr909.h ****         hpZ1_ = in;
 293:synth/tr909.h ****         return hpOut_;
 294:synth/tr909.h ****     }
 295:synth/tr909.h **** };
 296:synth/tr909.h **** 
 297:synth/tr909.h **** constexpr float HiHat909Base::METAL_FREQS[6];
 298:synth/tr909.h **** 
 299:synth/tr909.h **** class HiHatClosed : public HiHat909Base {
 300:synth/tr909.h **** public:
 301:synth/tr909.h ****     float decay  = 0.03f;
 302:synth/tr909.h ****     float tone   = 0.6f;
 303:synth/tr909.h ****     float volume = 1.0f;
 304:synth/tr909.h **** 
 305:synth/tr909.h ****     void Init(float sampleRate) {
 306:synth/tr909.h ****         sr_ = sampleRate;
 307:synth/tr909.h ****         dt_ = 1.0f / sr_;
 308:synth/tr909.h ****         active_ = false;
 309:synth/tr909.h ****         noiseState_ = 0x909AAAA;
 310:synth/tr909.h ****     }
 311:synth/tr909.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 284


 312:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 313:synth/tr909.h ****         active_ = true;
 314:synth/tr909.h ****         time_ = 0.0f;
 315:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 316:synth/tr909.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 317:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 318:synth/tr909.h ****     }
 319:synth/tr909.h **** 
 320:synth/tr909.h ****     float Process() {
 321:synth/tr909.h ****         if (!active_) return 0.0f;
 322:synth/tr909.h **** 
 323:synth/tr909.h ****         float metal = MetallicNoise();
 324:synth/tr909.h ****         float hp = Highpass(metal);
 325:synth/tr909.h ****         float env = expf(-time_ / decay);
 326:synth/tr909.h **** 
 327:synth/tr909.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 328:synth/tr909.h ****         output = tanhf(output * 2.5f);
 329:synth/tr909.h **** 
 330:synth/tr909.h ****         time_ += dt_;
 331:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 332:synth/tr909.h **** 
 333:synth/tr909.h ****         return output * volume * vel_;
 334:synth/tr909.h ****     }
 335:synth/tr909.h **** 
 336:synth/tr909.h ****     bool IsActive() const { return active_; }
 337:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.01f, 0.2f); }
 338:synth/tr909.h **** };
 339:synth/tr909.h **** 
