 227:synth/tb303.h **** 
 228:synth/tb303.h ****     /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
 229:synth/tb303.h ****      *  LADDER FILTER ŌĆö 4 polos en cascada (24 dB/octava)
 230:synth/tb303.h ****      *  ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 231:synth/tb303.h ****      *  Cada stage = filtro de 1 polo (6dB/oct)
 232:synth/tb303.h ****      *  4 stages en cascada = 24dB/oct
 233:synth/tb303.h ****      *  Retroalimentaci├│n de la salida = resonancia
 234:synth/tb303.h ****      *  
 235:synth/tb303.h ****      *  Es la misma topolog├Ła del Moog ladder original,
 236:synth/tb303.h ****      *  adaptada para la 303 (diode ladder).
 237:synth/tb303.h ****      *  La diferencia es que la 303 usa diodos en vez de
 238:synth/tb303.h ****      *  transistores, dando un car├Īcter m├Īs "chirpy".
 239:synth/tb303.h ****      * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
 240:synth/tb303.h ****     float LadderFilter(float input, float fc, float res) {
 241:synth/tb303.h ****         /* Frecuencia normalizada */
 242:synth/tb303.h ****         float f = 2.0f * fc / sr_;
 243:synth/tb303.h ****         if (f > 0.99f) f = 0.99f;
 244:synth/tb303.h **** 
 245:synth/tb303.h ****         /* Coeficiente del filtro (tuning) */
 246:synth/tb303.h ****         /* Aproximaci├│n: compensar la desviaci├│n no-lineal */
 247:synth/tb303.h ****         float g = f * (1.0f + f * (-0.25f));
 248:synth/tb303.h **** 
 249:synth/tb303.h ****         /* Retroalimentaci├│n = resonancia ├Ś 4 (4 polos) */
 250:synth/tb303.h ****         float fb = res * 4.0f;
 251:synth/tb303.h **** 
 252:synth/tb303.h ****         /* Compensaci├│n de ganancia para resonancia alta */
 253:synth/tb303.h ****         float comp = 1.0f / (1.0f + fb * 0.25f);
 254:synth/tb303.h **** 
 255:synth/tb303.h ****         /* Entrada con retroalimentaci├│n */
 256:synth/tb303.h ****         float fbSig = delay_[3];
 257:synth/tb303.h ****         float in = (input - fb * fbSig) * comp;
 258:synth/tb303.h **** 
 259:synth/tb303.h ****         /* Saturaci├│n suave en la entrada (car├Īcter diodo 303) */
 260:synth/tb303.h ****         in = tanhf(in);
 261:synth/tb303.h **** 
 262:synth/tb303.h ****         /* 4 stages de filtro en cascada */
 263:synth/tb303.h ****         for (int i = 0; i < 4; i++) {
 264:synth/tb303.h ****             float prev = (i == 0) ? in : stage_[i - 1];
 265:synth/tb303.h ****             stage_[i] = delay_[i] + g * (tanhf(prev) - tanhf(delay_[i]));
 266:synth/tb303.h ****             delay_[i] = stage_[i];
 267:synth/tb303.h ****         }
 268:synth/tb303.h **** 
 269:synth/tb303.h ****         return stage_[3];
 270:synth/tb303.h ****     }
 271:synth/tb303.h **** 
 272:synth/tb303.h ****     /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
