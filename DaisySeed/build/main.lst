 400:main.cpp      **** /* 4-byte step descriptor (used in SPI upload packets) */
 401:main.cpp      **** struct __attribute__((packed)) DsqStepPkt {
 402:main.cpp      ****     uint8_t active;       /* 0 or 1                          */
 403:main.cpp      ****     uint8_t velocity;     /* 1-127                           */
 404:main.cpp      ****     uint8_t noteLenDiv;   /* 0=full,2=half,4=qtr,8=eighth   */
 405:main.cpp      ****     uint8_t probability;  /* 0-100 (100 = always fire)      */
 406:main.cpp      **** };
 407:main.cpp      **** 
 408:main.cpp      **** /* Full step state (stored in SDRAM, includes param-locks) */
 409:main.cpp      **** struct DsqStepFull {
 410:main.cpp      ****     uint8_t  active;
 411:main.cpp      ****     uint8_t  velocity;
 412:main.cpp      ****     uint8_t  noteLenDiv;
 413:main.cpp      ****     uint8_t  probability;
 414:main.cpp      ****     /* param locks */
 415:main.cpp      ****     bool     cutoffEn;
 416:main.cpp      ****     uint16_t cutoffHz;
 417:main.cpp      ****     bool     reverbEn;
 418:main.cpp      ****     uint8_t  reverbSend;  /* 0-100 */
 419:main.cpp      ****     bool     volEn;
 420:main.cpp      ****     uint8_t  volume;      /* 0-150 */
 421:main.cpp      ****     uint8_t  _pad[1];     /* align to 12 bytes */
 422:main.cpp      **** };  /* 12 bytes */
 423:main.cpp      **** 
 424:main.cpp      **** /* 8 patterns ├Ś 16 tracks ├Ś 64 steps ├Ś 12B = ~98 KB ŌåÆ SDRAM */
 425:main.cpp      **** DSY_SDRAM_BSS static DsqStepFull dsqSteps[DSQ_PATTERNS][DSQ_TRACKS][DSQ_MAX_STEPS];
 426:main.cpp      **** 
