 891:synth/tr808.h ****     void Trigger(uint8_t instrument, float velocity = 1.0f) {
 892:synth/tr808.h ****         switch (instrument) {
 893:synth/tr808.h ****             case INST_KICK:       kick.Trigger(velocity); break;
 894:synth/tr808.h ****             case INST_SNARE:      snare.Trigger(velocity); break;
 895:synth/tr808.h ****             case INST_CLAP:       clap.Trigger(velocity); break;
 896:synth/tr808.h ****             case INST_HIHAT_C:
 897:synth/tr808.h ****                 hihatO.Choke();  /* cerrar el open al tocar closed */
 898:synth/tr808.h ****                 hihatC.Trigger(velocity);
 899:synth/tr808.h ****                 break;
 900:synth/tr808.h ****             case INST_HIHAT_O:   hihatO.Trigger(velocity); break;
