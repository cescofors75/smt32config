 910:synth/tr808.h ****             case INST_COWBELL:   cowbell.Trigger(velocity); break;
 911:synth/tr808.h ****             case INST_CYMBAL:    cymbal.Trigger(velocity); break;
 912:synth/tr808.h ****         }
 913:synth/tr808.h ****     }
