 387:synth/tr505.h ****  *  COWBELL 505
 388:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 389:synth/tr505.h **** class Cowbell {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 342


 390:synth/tr505.h **** public:
 391:synth/tr505.h ****     float decay  = 0.06f;
 392:synth/tr505.h ****     float lofi   = 0.2f;
 393:synth/tr505.h ****     float volume = 1.0f;
 394:synth/tr505.h **** 
 395:synth/tr505.h ****     void Init(float sampleRate) {
 396:synth/tr505.h ****         sr_ = sampleRate;
 397:synth/tr505.h ****         dt_ = 1.0f / sr_;
 398:synth/tr505.h ****         active_ = false;
 399:synth/tr505.h ****     }
 400:synth/tr505.h **** 
 401:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 402:synth/tr505.h ****         active_ = true;
 403:synth/tr505.h ****         time_ = 0.0f;
 404:synth/tr505.h ****         phase1_ = phase2_ = 0.0f;
 405:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 406:synth/tr505.h ****     }
 407:synth/tr505.h **** 
 408:synth/tr505.h ****     float Process() {
 409:synth/tr505.h ****         if (!active_) return 0.0f;
 410:synth/tr505.h **** 
 411:synth/tr505.h ****         phase1_ += 560.0f * dt_;
 412:synth/tr505.h ****         if (phase1_ >= 1.0f) phase1_ -= 1.0f;
 413:synth/tr505.h ****         float sq1 = (phase1_ < 0.5f) ? 1.0f : -1.0f;
 414:synth/tr505.h **** 
 415:synth/tr505.h ****         phase2_ += 845.0f * dt_;
 416:synth/tr505.h ****         if (phase2_ >= 1.0f) phase2_ -= 1.0f;
 417:synth/tr505.h ****         float sq2 = (phase2_ < 0.5f) ? 1.0f : -1.0f;
 418:synth/tr505.h **** 
 419:synth/tr505.h ****         float mix = (sq1 + sq2) * 0.5f;
 420:synth/tr505.h ****         float env = expf(-time_ / decay);
 421:synth/tr505.h **** 
 422:synth/tr505.h ****         float output = tanhf(mix * 1.3f) * env;
 423:synth/tr505.h ****         output = LoFi(output, lofi);
 424:synth/tr505.h **** 
 425:synth/tr505.h ****         time_ += dt_;
 426:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 427:synth/tr505.h **** 
 428:synth/tr505.h ****         return output * volume * vel_;
 429:synth/tr505.h ****     }
 430:synth/tr505.h **** 
 431:synth/tr505.h ****     bool IsActive() const { return active_; }
 432:synth/tr505.h **** 
 433:synth/tr505.h **** private:
 434:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 435:synth/tr505.h ****     bool  active_ = false;
 436:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 437:synth/tr505.h ****     float phase1_ = 0.0f, phase2_ = 0.0f;
 438:synth/tr505.h **** };
 439:synth/tr505.h **** 
 440:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 441:synth/tr505.h ****  *  CYMBAL 505
 442:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 443:synth/tr505.h **** class Cymbal {
 444:synth/tr505.h **** public:
 445:synth/tr505.h ****     float decay  = 0.6f;
 446:synth/tr505.h ****     float lofi   = 0.2f;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 343


 447:synth/tr505.h ****     float volume = 1.0f;
 448:synth/tr505.h **** 
 449:synth/tr505.h ****     void Init(float sampleRate) {
 450:synth/tr505.h ****         sr_ = sampleRate;
 451:synth/tr505.h ****         dt_ = 1.0f / sr_;
 452:synth/tr505.h ****         active_ = false;
 453:synth/tr505.h ****         noiseState_ = 0x505CC03;
 454:synth/tr505.h ****     }
 455:synth/tr505.h **** 
 456:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 457:synth/tr505.h ****         active_ = true;
 458:synth/tr505.h ****         time_ = 0.0f;
 459:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 460:synth/tr505.h ****         hpZ1_ = hpOut_ = 0.0f;
 461:synth/tr505.h ****     }
 462:synth/tr505.h **** 
 463:synth/tr505.h ****     float Process() {
 464:synth/tr505.h ****         if (!active_) return 0.0f;
 465:synth/tr505.h **** 
 466:synth/tr505.h ****         float n = Noise(noiseState_);
 467:synth/tr505.h **** 
 468:synth/tr505.h ****         float rc = 1.0f / (TWOPI_F * 5000.0f);
 469:synth/tr505.h ****         float alpha = rc / (rc + dt_);
 470:synth/tr505.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 471:synth/tr505.h ****         hpZ1_ = n;
 472:synth/tr505.h **** 
 473:synth/tr505.h ****         float attack = 1.0f - expf(-time_ / 0.003f);
 474:synth/tr505.h ****         float env = expf(-time_ / decay);
 475:synth/tr505.h **** 
 476:synth/tr505.h ****         float output = hpOut_ * env * attack;
 477:synth/tr505.h ****         output = LoFi(output, lofi);
 478:synth/tr505.h **** 
 479:synth/tr505.h ****         time_ += dt_;
 480:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 481:synth/tr505.h **** 
 482:synth/tr505.h ****         return output * volume * vel_;
 483:synth/tr505.h ****     }
 484:synth/tr505.h **** 
 485:synth/tr505.h ****     bool IsActive() const { return active_; }
 486:synth/tr505.h **** 
 487:synth/tr505.h **** private:
 488:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 489:synth/tr505.h ****     bool  active_ = false;
 490:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 491:synth/tr505.h ****     uint32_t noiseState_ = 0x505CC03;
 492:synth/tr505.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 493:synth/tr505.h **** };
 494:synth/tr505.h **** 
 495:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 496:synth/tr505.h ****  *  RIMSHOT 505
 497:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 498:synth/tr505.h **** class RimShot {
 499:synth/tr505.h **** public:
 500:synth/tr505.h ****     float decay  = 0.02f;
 501:synth/tr505.h ****     float lofi   = 0.15f;
 502:synth/tr505.h ****     float volume = 1.0f;
 503:synth/tr505.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 344


 504:synth/tr505.h ****     void Init(float sampleRate) {
 505:synth/tr505.h ****         sr_ = sampleRate;
 506:synth/tr505.h ****         dt_ = 1.0f / sr_;
 507:synth/tr505.h ****         active_ = false;
 508:synth/tr505.h ****         noiseState_ = 0x505DD04;
 509:synth/tr505.h ****     }
 510:synth/tr505.h **** 
 511:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 512:synth/tr505.h ****         active_ = true;
 513:synth/tr505.h ****         time_ = 0.0f;
 514:synth/tr505.h ****         phase_ = 0.0f;
 515:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 516:synth/tr505.h ****     }
 517:synth/tr505.h **** 
 518:synth/tr505.h ****     float Process() {
 519:synth/tr505.h ****         if (!active_) return 0.0f;
 520:synth/tr505.h **** 
 521:synth/tr505.h ****         float n = Noise(noiseState_);
 522:synth/tr505.h ****         float clickEnv = expf(-time_ / 0.0008f);
 523:synth/tr505.h ****         float click = n * clickEnv * 0.4f;
 524:synth/tr505.h **** 
 525:synth/tr505.h ****         phase_ += 750.0f * dt_;
 526:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 527:synth/tr505.h ****         float sine = sinf(TWOPI_F * phase_);
 528:synth/tr505.h ****         float toneEnv = expf(-time_ / decay);
 529:synth/tr505.h **** 
 530:synth/tr505.h ****         float output = click + sine * toneEnv;
 531:synth/tr505.h ****         output = tanhf(output * 1.5f);
 532:synth/tr505.h ****         output = LoFi(output, lofi);
 533:synth/tr505.h **** 
 534:synth/tr505.h ****         time_ += dt_;
 535:synth/tr505.h ****         if (toneEnv < 0.001f) active_ = false;
 536:synth/tr505.h **** 
 537:synth/tr505.h ****         return output * volume * vel_;
 538:synth/tr505.h ****     }
 539:synth/tr505.h **** 
 540:synth/tr505.h ****     bool IsActive() const { return active_; }
 541:synth/tr505.h **** 
 542:synth/tr505.h **** private:
 543:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 544:synth/tr505.h ****     bool  active_ = false;
 545:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 546:synth/tr505.h ****     uint32_t noiseState_ = 0x505DD04;
 547:synth/tr505.h **** };
