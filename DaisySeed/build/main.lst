 605:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 606:synth/tr808.h ****  *  MARACAS 808
 607:synth/tr808.h ****  *  Burst de ruido corto highpass-filtered
 608:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 609:synth/tr808.h **** class Maracas {
 610:synth/tr808.h **** public:
 611:synth/tr808.h ****     float decay  = 0.035f;
 612:synth/tr808.h ****     float tone   = 0.7f;
 613:synth/tr808.h ****     float volume = 1.0f;
 614:synth/tr808.h **** 
 615:synth/tr808.h ****     void Init(float sampleRate) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 150


 616:synth/tr808.h ****         sr_ = sampleRate;
 617:synth/tr808.h ****         dt_ = 1.0f / sr_;
 618:synth/tr808.h ****         active_ = false;
 619:synth/tr808.h ****         noiseState_ = 0xF00DFACE;
 620:synth/tr808.h ****     }
 621:synth/tr808.h **** 
 622:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 623:synth/tr808.h ****         active_ = true;
 624:synth/tr808.h ****         time_ = 0.0f;
 625:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 626:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 627:synth/tr808.h ****     }
 628:synth/tr808.h **** 
 629:synth/tr808.h ****     float Process() {
 630:synth/tr808.h ****         if (!active_) return 0.0f;
 631:synth/tr808.h **** 
 632:synth/tr808.h ****         float n = Noise(noiseState_);
 633:synth/tr808.h **** 
 634:synth/tr808.h ****         /* Highpass ~7kHz */
 635:synth/tr808.h ****         float fc = 5000.0f + tone * 5000.0f;
 636:synth/tr808.h ****         float rc = 1.0f / (TWOPI_F * fc);
 637:synth/tr808.h ****         float alpha = rc / (rc + dt_);
 638:synth/tr808.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 639:synth/tr808.h ****         hpZ1_ = n;
 640:synth/tr808.h **** 
 641:synth/tr808.h ****         float env = expf(-time_ / decay);
 642:synth/tr808.h ****         float output = hpOut_ * env;
 643:synth/tr808.h **** 
 644:synth/tr808.h ****         time_ += dt_;
 645:synth/tr808.h ****         if (env < 0.001f) active_ = false;
 646:synth/tr808.h **** 
 647:synth/tr808.h ****         return output * volume * vel_;
 648:synth/tr808.h ****     }
 649:synth/tr808.h **** 
 650:synth/tr808.h ****     bool IsActive() const { return active_; }
 651:synth/tr808.h **** 
 652:synth/tr808.h **** private:
 653:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 654:synth/tr808.h ****     bool  active_ = false;
 655:synth/tr808.h ****     float time_ = 0.0f;
 656:synth/tr808.h ****     float vel_ = 1.0f;
 657:synth/tr808.h ****     uint32_t noiseState_ = 0xF00DFACE;
 658:synth/tr808.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 659:synth/tr808.h **** };
 660:synth/tr808.h **** 
 661:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 662:synth/tr808.h ****  *  RIMSHOT 808
 663:synth/tr808.h ****  *  Click agudo + tono corto (~820 Hz)
 664:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 665:synth/tr808.h **** class RimShot {
 666:synth/tr808.h **** public:
 667:synth/tr808.h ****     float decay  = 0.025f;
 668:synth/tr808.h ****     float pitch  = 820.0f;
 669:synth/tr808.h ****     float volume = 1.0f;
 670:synth/tr808.h **** 
 671:synth/tr808.h ****     void Init(float sampleRate) {
 672:synth/tr808.h ****         sr_ = sampleRate;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 151


 673:synth/tr808.h ****         dt_ = 1.0f / sr_;
 674:synth/tr808.h ****         active_ = false;
 675:synth/tr808.h ****         noiseState_ = 0xABCDEF01;
 676:synth/tr808.h ****     }
 677:synth/tr808.h **** 
 678:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 679:synth/tr808.h ****         active_ = true;
 680:synth/tr808.h ****         time_ = 0.0f;
 681:synth/tr808.h ****         phase_ = 0.0f;
 682:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 683:synth/tr808.h ****     }
 684:synth/tr808.h **** 
 685:synth/tr808.h ****     float Process() {
 686:synth/tr808.h ****         if (!active_) return 0.0f;
 687:synth/tr808.h **** 
 688:synth/tr808.h ****         /* Click: burst de ruido HP muy corto */
 689:synth/tr808.h ****         float n = Noise(noiseState_);
 690:synth/tr808.h ****         float clickEnv = expf(-time_ / 0.0008f);
 691:synth/tr808.h ****         float click = n * clickEnv * 0.5f;
 692:synth/tr808.h **** 
 693:synth/tr808.h ****         /* Tono */
 694:synth/tr808.h ****         phase_ += pitch * dt_;
 695:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 696:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
 697:synth/tr808.h ****         float toneEnv = expf(-time_ / decay);
 698:synth/tr808.h **** 
 699:synth/tr808.h ****         float output = click + sine * toneEnv;
 700:synth/tr808.h ****         output = tanhf(output * 1.8f);
 701:synth/tr808.h **** 
 702:synth/tr808.h ****         time_ += dt_;
 703:synth/tr808.h ****         if (toneEnv < 0.001f && clickEnv < 0.001f) active_ = false;
 704:synth/tr808.h **** 
 705:synth/tr808.h ****         return output * volume * vel_;
 706:synth/tr808.h ****     }
 707:synth/tr808.h **** 
 708:synth/tr808.h ****     bool IsActive() const { return active_; }
 709:synth/tr808.h **** 
 710:synth/tr808.h **** private:
 711:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 712:synth/tr808.h ****     bool  active_ = false;
 713:synth/tr808.h ****     float time_ = 0.0f;
 714:synth/tr808.h ****     float phase_ = 0.0f;
 715:synth/tr808.h ****     float vel_ = 1.0f;
 716:synth/tr808.h ****     uint32_t noiseState_ = 0xABCDEF01;
 717:synth/tr808.h **** };
 718:synth/tr808.h **** 
 719:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 720:synth/tr808.h ****  *  COWBELL 808
 721:synth/tr808.h ****  *  Dos ondas cuadradas desafinadas (540 Hz + 800 Hz)
 722:synth/tr808.h ****  *  Sonido met├Īlico caracter├Łstico
 723:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 724:synth/tr808.h **** class Cowbell {
 725:synth/tr808.h **** public:
 726:synth/tr808.h ****     float decay  = 0.08f;
 727:synth/tr808.h ****     float volume = 1.0f;
 728:synth/tr808.h **** 
 729:synth/tr808.h ****     void Init(float sampleRate) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 152


 730:synth/tr808.h ****         sr_ = sampleRate;
 731:synth/tr808.h ****         dt_ = 1.0f / sr_;
 732:synth/tr808.h ****         active_ = false;
 733:synth/tr808.h ****     }
 734:synth/tr808.h **** 
 735:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 736:synth/tr808.h ****         active_ = true;
 737:synth/tr808.h ****         time_ = 0.0f;
 738:synth/tr808.h ****         phase1_ = 0.0f;
 739:synth/tr808.h ****         phase2_ = 0.0f;
 740:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 741:synth/tr808.h ****     }
 742:synth/tr808.h **** 
 743:synth/tr808.h ****     float Process() {
 744:synth/tr808.h ****         if (!active_) return 0.0f;
 745:synth/tr808.h **** 
 746:synth/tr808.h ****         /* Dos square waves desafinadas */
 747:synth/tr808.h ****         phase1_ += 540.0f * dt_;
 748:synth/tr808.h ****         if (phase1_ >= 1.0f) phase1_ -= 1.0f;
 749:synth/tr808.h ****         float sq1 = (phase1_ < 0.5f) ? 1.0f : -1.0f;
 750:synth/tr808.h **** 
 751:synth/tr808.h ****         phase2_ += 800.0f * dt_;
 752:synth/tr808.h ****         if (phase2_ >= 1.0f) phase2_ -= 1.0f;
 753:synth/tr808.h ****         float sq2 = (phase2_ < 0.5f) ? 1.0f : -1.0f;
 754:synth/tr808.h **** 
 755:synth/tr808.h ****         float mix = (sq1 + sq2) * 0.5f;
 756:synth/tr808.h **** 
 757:synth/tr808.h ****         /* Envelope con dos fases: attack r├Īpido, decay */
 758:synth/tr808.h ****         float env1 = expf(-time_ / 0.003f);  /* click */
 759:synth/tr808.h ****         float env2 = expf(-time_ / decay);    /* body  */
 760:synth/tr808.h ****         float env = env2 + (env1 - env2) * 0.3f;
 761:synth/tr808.h **** 
 762:synth/tr808.h ****         /* Bandpass ligero para suavizar */
 763:synth/tr808.h ****         float output = tanhf(mix * env * 1.5f);
 764:synth/tr808.h **** 
 765:synth/tr808.h ****         time_ += dt_;
 766:synth/tr808.h ****         if (env2 < 0.001f) active_ = false;
 767:synth/tr808.h **** 
 768:synth/tr808.h ****         return output * volume * vel_;
 769:synth/tr808.h ****     }
 770:synth/tr808.h **** 
 771:synth/tr808.h ****     bool IsActive() const { return active_; }
 772:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.03f, 0.5f); }
 773:synth/tr808.h **** 
 774:synth/tr808.h **** private:
 775:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 776:synth/tr808.h ****     bool  active_ = false;
 777:synth/tr808.h ****     float time_ = 0.0f;
 778:synth/tr808.h ****     float phase1_ = 0.0f, phase2_ = 0.0f;
 779:synth/tr808.h ****     float vel_ = 1.0f;
 780:synth/tr808.h **** };
 781:synth/tr808.h **** 
 782:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 783:synth/tr808.h ****  *  CYMBAL 808
 784:synth/tr808.h ****  *  Metallic noise (6 square waves) + bandpass largo
 785:synth/tr808.h ****  *  Como el hihat pero con decay mucho m├Īs largo
 786:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 153


 787:synth/tr808.h **** class Cymbal : public HiHatBase {
 788:synth/tr808.h **** public:
 789:synth/tr808.h ****     float decay  = 0.8f;    /* 0.3 - 3.0 s */
 790:synth/tr808.h ****     float tone   = 0.6f;
 791:synth/tr808.h ****     float volume = 1.0f;
 792:synth/tr808.h **** 
 793:synth/tr808.h ****     void Init(float sampleRate) {
 794:synth/tr808.h ****         sr_ = sampleRate;
 795:synth/tr808.h ****         dt_ = 1.0f / sr_;
 796:synth/tr808.h ****         active_ = false;
 797:synth/tr808.h ****     }
 798:synth/tr808.h **** 
 799:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 800:synth/tr808.h ****         active_ = true;
 801:synth/tr808.h ****         time_ = 0.0f;
 802:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 803:synth/tr808.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 804:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 805:synth/tr808.h ****     }
 806:synth/tr808.h **** 
 807:synth/tr808.h ****     float Process() {
 808:synth/tr808.h ****         if (!active_) return 0.0f;
 809:synth/tr808.h **** 
 810:synth/tr808.h ****         float metal = MetallicNoise();
 811:synth/tr808.h ****         float hp = Highpass(metal);
 812:synth/tr808.h **** 
 813:synth/tr808.h ****         /* Decay largo con onset r├Īpido */
 814:synth/tr808.h ****         float env = expf(-time_ / decay);
 815:synth/tr808.h ****         float attack = 1.0f - expf(-time_ / 0.002f);
 816:synth/tr808.h **** 
 817:synth/tr808.h ****         float output = hp * env * attack * (0.4f + tone * 0.6f);
 818:synth/tr808.h ****         output = tanhf(output * 1.8f);
 819:synth/tr808.h **** 
 820:synth/tr808.h ****         time_ += dt_;
 821:synth/tr808.h ****         if (env < 0.0005f) active_ = false;
 822:synth/tr808.h **** 
 823:synth/tr808.h ****         return output * volume * vel_;
 824:synth/tr808.h ****     }
 825:synth/tr808.h **** 
 826:synth/tr808.h ****     bool IsActive() const { return active_; }
 827:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.1f, 5.0f); }
 828:synth/tr808.h **** };
 829:synth/tr808.h **** 
