 150:synth/tb303.h **** 
 151:synth/tb303.h ****         /* ŌöĆŌöĆ 3. ENVELOPES ŌöĆŌöĆ */
 152:synth/tb303.h ****         /* Filter envelope: decay exponencial */
 153:synth/tb303.h ****         float envDecay = accent_ ? decay * 0.7f : decay;
 154:synth/tb303.h ****         filterEnv_ *= expf(-dt_ / envDecay);
 155:synth/tb303.h **** 
 156:synth/tb303.h ****         /* Amp envelope */
 157:synth/tb303.h ****         if (gateOn_) {
 158:synth/tb303.h ****             /* Attack r├Īpido */
 159:synth/tb303.h ****             ampEnv_ += (1.0f - ampEnv_) * 0.05f;
 160:synth/tb303.h ****         } else {
 161:synth/tb303.h ****             /* Release */
 162:synth/tb303.h ****             float relTime = accent_ ? 0.01f : 0.005f;
 163:synth/tb303.h ****             ampEnv_ *= expf(-dt_ / relTime);
 164:synth/tb303.h ****             if (ampEnv_ < 0.001f) {
 165:synth/tb303.h ****                 active_ = false;
 166:synth/tb303.h ****                 return 0.0f;
 167:synth/tb303.h ****             }
 168:synth/tb303.h ****         }
 169:synth/tb303.h **** 
 170:synth/tb303.h ****         /* ŌöĆŌöĆ 4. FILTRO LADDER (el coraz├│n del acid) ŌöĆŌöĆ */
 171:synth/tb303.h ****         /* Calcular cutoff modulado por envelope */
 172:synth/tb303.h ****         float accentBoost = accent_ ? accentAmt * 6000.0f : 0.0f;
 173:synth/tb303.h ****         float envAmount = envMod * 10000.0f * filterEnv_;
 174:synth/tb303.h ****         float fc = cutoff + envAmount + accentBoost;
 175:synth/tb303.h ****         fc = Clamp(fc, 20.0f, sr_ * 0.45f);
 176:synth/tb303.h **** 
 177:synth/tb303.h ****         /* Resonancia: accent la aumenta */
 178:synth/tb303.h ****         float res = resonance;
 179:synth/tb303.h ****         if (accent_) res = Clamp(res + accentAmt * 0.3f, 0.0f, 0.95f);
 180:synth/tb303.h **** 
 181:synth/tb303.h ****         float filtered = LadderFilter(osc, fc, res);
 182:synth/tb303.h **** 
 183:synth/tb303.h ****         /* ŌöĆŌöĆ 5. VCA ŌöĆŌöĆ */
 184:synth/tb303.h ****         float accentGain = accent_ ? 1.0f + accentAmt * 0.4f : 1.0f;
 185:synth/tb303.h ****         float output = filtered * ampEnv_ * volume * accentGain;
 186:synth/tb303.h **** 
 187:synth/tb303.h ****         /* Soft clip final */
 188:synth/tb303.h ****         output = tanhf(output * 1.5f);
 189:synth/tb303.h **** 
 190:synth/tb303.h ****         return output;
 191:synth/tb303.h ****     }
 192:synth/tb303.h **** 
 193:synth/tb303.h ****     bool IsActive() const { return active_; }
 194:synth/tb303.h ****     bool IsGateOn() const { return gateOn_; }
 195:synth/tb303.h **** 
 196:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ Setters para control en vivo ŌöĆŌöĆŌöĆ */
 197:synth/tb303.h ****     void SetCutoff(float c)     { cutoff = Clamp(c, 20.0f, 20000.0f); }
 198:synth/tb303.h ****     void SetResonance(float r)  { resonance = Clamp(r, 0.0f, 0.95f); }
 199:synth/tb303.h ****     void SetEnvMod(float e)     { envMod = Clamp(e, 0.0f, 1.0f); }
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 401


 200:synth/tb303.h ****     void SetDecay(float d)      { decay = Clamp(d, 0.02f, 3.0f); }
 201:synth/tb303.h ****     void SetAccent(float a)     { accentAmt = Clamp(a, 0.0f, 1.0f); }
 202:synth/tb303.h ****     void SetSlide(float s)      { slideTime = Clamp(s, 0.01f, 0.5f); }
 203:synth/tb303.h ****     void SetWaveform(Waveform w){ waveform = w; }
