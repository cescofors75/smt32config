 384:synth/tr909.h ****  *  TOM 909
 385:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 386:synth/tr909.h **** class Tom909 {
 387:synth/tr909.h **** public:
 388:synth/tr909.h ****     float decay      = 0.2f;
 389:synth/tr909.h ****     float pitch      = 150.0f;
 390:synth/tr909.h ****     float pitchDecay = 0.03f;
 391:synth/tr909.h ****     float attack     = 0.4f;   /* click amount */
 392:synth/tr909.h ****     float volume     = 1.0f;
 393:synth/tr909.h **** 
 394:synth/tr909.h ****     void Init(float sampleRate) {
 395:synth/tr909.h ****         sr_ = sampleRate;
 396:synth/tr909.h ****         dt_ = 1.0f / sr_;
 397:synth/tr909.h ****         active_ = false;
 398:synth/tr909.h ****     }
 399:synth/tr909.h **** 
 400:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 401:synth/tr909.h ****         active_ = true;
 402:synth/tr909.h ****         time_ = 0.0f;
 403:synth/tr909.h ****         phase_ = 0.0f;
 404:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 405:synth/tr909.h ****     }
 406:synth/tr909.h **** 
 407:synth/tr909.h ****     float Process() {
 408:synth/tr909.h ****         if (!active_) return 0.0f;
 409:synth/tr909.h **** 
 410:synth/tr909.h ****         float cp = pitch + pitch * 3.0f * expf(-time_ / pitchDecay);
 411:synth/tr909.h ****         phase_ += cp * dt_;
 412:synth/tr909.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 413:synth/tr909.h ****         float sine = sinf(TWOPI_F * phase_);
 414:synth/tr909.h **** 
 415:synth/tr909.h ****         /* Click transitorio */
 416:synth/tr909.h ****         float clickEnv = expf(-time_ / 0.001f);
 417:synth/tr909.h ****         float click = clickEnv * sinf(TWOPI_F * 1500.0f * time_) * attack;
 418:synth/tr909.h **** 
 419:synth/tr909.h ****         float env = expf(-time_ / decay);
 420:synth/tr909.h ****         float output = tanhf((sine + click * 0.3f) * 1.4f) * env;
 421:synth/tr909.h **** 
 422:synth/tr909.h ****         time_ += dt_;
 423:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 424:synth/tr909.h **** 
 425:synth/tr909.h ****         return output * volume * vel_;
 426:synth/tr909.h ****     }
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 241


 427:synth/tr909.h **** 
 428:synth/tr909.h ****     bool IsActive() const { return active_; }
 429:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 0.8f); }
 430:synth/tr909.h ****     void SetPitch(float p) { pitch = Clamp(p, 60.0f, 400.0f); }
 431:synth/tr909.h **** 
 432:synth/tr909.h **** private:
 433:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 434:synth/tr909.h ****     bool  active_ = false;
 435:synth/tr909.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 436:synth/tr909.h **** };
