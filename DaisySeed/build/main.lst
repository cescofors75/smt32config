3565:main.cpp      **** static bool LoadWavToPad(const char* filepath, uint8_t padIdx)
3566:main.cpp      **** {
3567:main.cpp      ****     if(padIdx >= MAX_PADS) return false;
3568:main.cpp      ****     FIL fil;
3569:main.cpp      ****     if(f_open(&fil, filepath, FA_READ) != FR_OK) return false;
3570:main.cpp      **** 
3571:main.cpp      ****     /* Simple WAV header parse: find "data" chunk */
3572:main.cpp      ****     uint8_t hdr[44];
3573:main.cpp      ****     UINT br;
3574:main.cpp      ****     if(f_read(&fil, hdr, 44, &br) != FR_OK || br < 44){
3575:main.cpp      ****         f_close(&fil); return false;
3576:main.cpp      ****     }
3577:main.cpp      ****     if(memcmp(hdr, "RIFF", 4) != 0 || memcmp(hdr+8, "WAVE", 4) != 0){
3578:main.cpp      ****         f_close(&fil); return false;
3579:main.cpp      ****     }
3580:main.cpp      **** 
3581:main.cpp      ****     uint16_t ch  = hdr[22] | (hdr[23]<<8);
3582:main.cpp      ****     uint32_t sr  = hdr[24]|(hdr[25]<<8)|(hdr[26]<<16)|(hdr[27]<<24);
3583:main.cpp      ****     uint16_t bps = hdr[34] | (hdr[35]<<8);
3584:main.cpp      ****     (void)sr;
3585:main.cpp      **** 
3586:main.cpp      ****     /* Skip to data chunk */
3587:main.cpp      ****     uint32_t pos = 12;
3588:main.cpp      ****     f_lseek(&fil, 12);
3589:main.cpp      ****     uint32_t dataSize = 0;
3590:main.cpp      ****     while(pos < f_size(&fil) - 8){
3591:main.cpp      ****         uint8_t ck[8];
3592:main.cpp      ****         if(f_read(&fil, ck, 8, &br) != FR_OK || br < 8) break;
3593:main.cpp      ****         uint32_t ckSz = ck[4]|(ck[5]<<8)|(ck[6]<<16)|(ck[7]<<24);
3594:main.cpp      ****         if(memcmp(ck, "data", 4) == 0){
3595:main.cpp      ****             dataSize = ckSz;
3596:main.cpp      ****             break;
3597:main.cpp      ****         }
3598:main.cpp      ****         f_lseek(&fil, f_tell(&fil) + ckSz);
3599:main.cpp      ****         pos += 8 + ckSz;
3600:main.cpp      ****     }
3601:main.cpp      ****     if(dataSize == 0){ f_close(&fil); return false; }
3602:main.cpp      **** 
3603:main.cpp      ****     uint32_t bytesPerFrame = (bps/8) * ch;
3604:main.cpp      ****     if(bytesPerFrame == 0){ f_close(&fil); return false; }
3605:main.cpp      ****     uint32_t totalFrames = dataSize / bytesPerFrame;
3606:main.cpp      ****     if(totalFrames > MAX_SAMPLE_BYTES / 2) totalFrames = MAX_SAMPLE_BYTES / 2;
3607:main.cpp      **** 
3608:main.cpp      ****     /* Read and convert to mono 16-bit */
3609:main.cpp      ****     if(bps == 16 && ch == 1){
3610:main.cpp      ****         /* Optimal: direct read */
3611:main.cpp      ****         f_read(&fil, sampleStorage[padIdx], totalFrames * 2, &br);
3612:main.cpp      ****         sampleLength[padIdx] = br / 2;
3613:main.cpp      ****     } else {
3614:main.cpp      ****         /* Convert: read in chunks */
3615:main.cpp      ****         uint8_t buf[512];
3616:main.cpp      ****         uint32_t frames = 0;
3617:main.cpp      ****         while(frames < totalFrames){
3618:main.cpp      ****             uint32_t want = (totalFrames - frames) * bytesPerFrame;
3619:main.cpp      ****             if(want > sizeof(buf)) want = sizeof(buf);
3620:main.cpp      ****             if(f_read(&fil, buf, want, &br) != FR_OK || br == 0) break;
3621:main.cpp      ****             uint32_t got = br / bytesPerFrame;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 83


3622:main.cpp      ****             for(uint32_t i = 0; i < got && frames < totalFrames; i++){
3623:main.cpp      ****                 const uint8_t* s = buf + i * bytesPerFrame;
3624:main.cpp      ****                 int32_t sample = 0;
3625:main.cpp      ****                 if(bps == 16){
3626:main.cpp      ****                     sample = (int16_t)(s[0]|(s[1]<<8));
3627:main.cpp      ****                     if(ch == 2) sample = (sample + (int16_t)(s[2]|(s[3]<<8))) / 2;
3628:main.cpp      ****                 } else if(bps == 24){
3629:main.cpp      ****                     sample = (int32_t)(((uint32_t)s[0]<<8)|((uint32_t)s[1]<<16)|((uint32_t)s[2]<<24
3630:main.cpp      ****                     sample >>= 16;
3631:main.cpp      ****                     if(ch == 2){
3632:main.cpp      ****                         int32_t s2 = (int32_t)(((uint32_t)s[3]<<8)|((uint32_t)s[4]<<16)|((uint32_t)
3633:main.cpp      ****                         sample = (sample + (s2>>16)) / 2;
3634:main.cpp      ****                     }
3635:main.cpp      ****                 } else if(bps == 8){
3636:main.cpp      ****                     sample = ((int32_t)s[0] - 128) * 256;
3637:main.cpp      ****                     if(ch == 2) sample = (sample + ((int32_t)s[1]-128)*256) / 2;
3638:main.cpp      ****                 }
3639:main.cpp      ****                 sampleStorage[padIdx][frames++] =
3640:main.cpp      ****                     (int16_t)(sample < -32768 ? -32768 : (sample > 32767 ? 32767 : sample));
3641:main.cpp      ****             }
3642:main.cpp      ****         }
3643:main.cpp      ****         sampleLength[padIdx] = frames;
3644:main.cpp      ****     }
3645:main.cpp      **** 
3646:main.cpp      ****     sampleLoaded[padIdx] = (sampleLength[padIdx] > 0);
3647:main.cpp      ****     f_close(&fil);
3648:main.cpp      ****     return sampleLoaded[padIdx];
3649:main.cpp      **** }
