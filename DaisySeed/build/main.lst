1124:main.cpp      **** static inline float clampF(float v, float lo, float hi){
1125:main.cpp      ****     return v < lo ? lo : (v > hi ? hi : v);
1126:main.cpp      **** }
1127:main.cpp      **** 
1128:main.cpp      **** static inline float VolumeByteToGain(uint8_t volumePct)
1129:main.cpp      **** {
1130:main.cpp      ****     return clampF((float)volumePct, 0.0f, 150.0f) / 100.0f;
1131:main.cpp      **** }
1132:main.cpp      **** 
1133:main.cpp      **** static inline float SoftClipKnee(float x)
1134:main.cpp      **** {
1135:main.cpp      ****     const float knee = 0.9f;
1136:main.cpp      ****     if(x > knee)
1137:main.cpp      ****     {
1138:main.cpp      ****         float t = x - knee;
1139:main.cpp      ****         return knee + t / (1.0f + t * t);
1140:main.cpp      ****     }
1141:main.cpp      ****     if(x < -knee)
1142:main.cpp      ****     {
1143:main.cpp      ****         float t = x + knee;
1144:main.cpp      ****         return -knee + t / (1.0f + t * t);
1145:main.cpp      ****     }
1146:main.cpp      ****     return x;
1147:main.cpp      **** }
1148:main.cpp      **** 
1149:main.cpp      **** static inline float TriFromPhase(float ph)
1150:main.cpp      **** {
1151:main.cpp      ****     /* 0..1 -> -1..+1 */
1152:main.cpp      ****     float t = ph < 0.5f ? (ph * 2.0f) : (2.0f - ph * 2.0f);
1153:main.cpp      ****     return t * 2.0f - 1.0f;
1154:main.cpp      **** }
1155:main.cpp      **** 
1156:main.cpp      **** static inline float AdDecayCoefFromMs(float decayMs)
1157:main.cpp      **** {
1158:main.cpp      ****     float samples = clampF(decayMs, 1.0f, 8000.0f) * (float)SR * 0.001f;
1159:main.cpp      ****     return expf(-1.0f / samples);
1160:main.cpp      **** }
