   2:synth/tr808.h ****  *  TR808 ŌĆö Roland TR-808 Drum Synthesis Library
   3:synth/tr808.h ****  * ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
   4:synth/tr808.h ****  *  S├Łntesis anal├│gica matem├Ītica: sin(), exp(), tanh(), noise
   5:synth/tr808.h ****  *  Cada instrumento = clase independiente con Trigger() + Process()
   6:synth/tr808.h ****  *  48 kHz ┬Ę float32 ┬Ę header-only
   7:synth/tr808.h ****  *
   8:synth/tr808.h ****  *  Instrumentos:
   9:synth/tr808.h ****  *    Kick, Snare, Clap, HiHatClosed, HiHatOpen,
  10:synth/tr808.h ****  *    LowTom, MidTom, HiTom, LowConga, MidConga, HiConga,
  11:synth/tr808.h ****  *    Claves, Maracas, RimShot, Cowbell, Cymbal
  12:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  13:synth/tr808.h **** #pragma once
  14:synth/tr808.h **** 
  15:synth/tr808.h **** #include <math.h>
  16:synth/tr808.h **** #include <stdint.h>
  17:synth/tr808.h **** 
  18:synth/tr808.h **** #ifndef TWOPI_F
  19:synth/tr808.h **** #define TWOPI_F 6.283185307f
  20:synth/tr808.h **** #endif
  21:synth/tr808.h **** 
  22:synth/tr808.h **** namespace TR808 {
  23:synth/tr808.h **** 
  24:synth/tr808.h **** /* ŌöĆŌöĆ PRNG r├Īpido para ruido ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
  25:synth/tr808.h **** static inline float Noise(uint32_t& state) {
  26:synth/tr808.h ****     state ^= state << 13;
  27:synth/tr808.h ****     state ^= state >> 17;
  28:synth/tr808.h ****     state ^= state << 5;
  29:synth/tr808.h ****     return ((float)(int32_t)state) / 2147483648.0f;
  30:synth/tr808.h **** }
  31:synth/tr808.h **** 
  32:synth/tr808.h **** /* ŌöĆŌöĆ Clamp helper ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  33:synth/tr808.h **** static inline float Clamp(float v, float lo, float hi) {
  34:synth/tr808.h ****     return v < lo ? lo : (v > hi ? hi : v);
  35:synth/tr808.h **** }
  36:synth/tr808.h **** 
