1229:main.cpp      **** static inline float SoftClipKnee(float x)
1230:main.cpp      **** {
1231:main.cpp      ****     const float knee = 0.9f;
1232:main.cpp      ****     if(x > knee)
1233:main.cpp      ****     {
1234:main.cpp      ****         float t = x - knee;
1235:main.cpp      ****         return knee + t / (1.0f + t * t);
1236:main.cpp      ****     }
1237:main.cpp      ****     if(x < -knee)
1238:main.cpp      ****     {
1239:main.cpp      ****         float t = x + knee;
1240:main.cpp      ****         return -knee + t / (1.0f + t * t);
1241:main.cpp      ****     }
1242:main.cpp      ****     return x;
1243:main.cpp      **** }
1244:main.cpp      **** 
1245:main.cpp      **** static inline float TriFromPhase(float ph)
1246:main.cpp      **** {
1247:main.cpp      ****     /* 0..1 -> -1..+1 */
1248:main.cpp      ****     float t = ph < 0.5f ? (ph * 2.0f) : (2.0f - ph * 2.0f);
1249:main.cpp      ****     return t * 2.0f - 1.0f;
1250:main.cpp      **** }
