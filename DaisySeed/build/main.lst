3687:main.cpp      **** static int compareCI(const char* a, const char* b)
3688:main.cpp      **** {
3689:main.cpp      ****     while(*a && *b){
3690:main.cpp      ****         int da = toupper((uint8_t)*a);
3691:main.cpp      ****         int db = toupper((uint8_t)*b);
3692:main.cpp      ****         if(da != db) return da - db;
3693:main.cpp      ****         a++; b++;
3694:main.cpp      ****     }
3695:main.cpp      ****     return (int)((uint8_t)*a) - (int)((uint8_t)*b);
3696:main.cpp      **** }
