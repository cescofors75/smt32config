3705:main.cpp      ****                         sample = (sample + (s2>>16)) / 2;
3706:main.cpp      ****                     }
3707:main.cpp      ****                 } else if(bps == 8){
3708:main.cpp      ****                     sample = ((int32_t)s[0] - 128) * 256;
3709:main.cpp      ****                     if(ch == 2) sample = (sample + ((int32_t)s[1]-128)*256) / 2;
3710:main.cpp      ****                 }
3711:main.cpp      ****                 sampleStorage[padIdx][frames++] =
