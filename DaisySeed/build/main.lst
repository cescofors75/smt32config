 890:main.cpp      **** struct __attribute__((packed)) NotifyEvent {
 891:main.cpp      ****     uint8_t  type;          /* EVT_SD_* */
 892:main.cpp      ****     uint8_t  padCount;      /* cu├Īntos pads afectados */
 893:main.cpp      ****     uint8_t  padMaskLo;     /* bitmask pads 0-7  loaded */
 894:main.cpp      ****     uint8_t  padMaskHi;     /* bitmask pads 8-15 loaded */
 895:main.cpp      ****     uint8_t  padMaskXtra;   /* bitmask pads 16-23 loaded */
 896:main.cpp      ****     uint8_t  reserved[3];
 897:main.cpp      ****     char     name[24];      /* kit name / sample name */
 898:main.cpp      **** };  /* 32 bytes */
 899:main.cpp      **** 
 900:main.cpp      **** #define EVT_QUEUE_SIZE 8
 901:main.cpp      **** static NotifyEvent evtQueue[EVT_QUEUE_SIZE];
 902:main.cpp      **** static volatile uint8_t evtHead = 0;  /* next write position  */
 903:main.cpp      **** static volatile uint8_t evtTail = 0;  /* next read  position  */
 904:main.cpp      **** static volatile uint8_t evtCount = 0; /* events in queue      */
 905:main.cpp      **** 
 906:main.cpp      **** static void PushEvent(uint8_t type, uint8_t padCount,
 907:main.cpp      ****                       uint32_t padMask24, const char* name)
 908:main.cpp      **** {
 909:main.cpp      ****     if(evtCount >= EVT_QUEUE_SIZE){
 910:main.cpp      ****         /* Queue full ŌĆö overwrite oldest */
 911:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 912:main.cpp      ****         evtCount--;
 913:main.cpp      ****     }
 914:main.cpp      ****     NotifyEvent& e = evtQueue[evtHead];
 915:main.cpp      ****     memset(&e, 0, sizeof(e));
 916:main.cpp      ****     e.type       = type;
 917:main.cpp      ****     e.padCount   = padCount;
 918:main.cpp      ****     e.padMaskLo  = (uint8_t)(padMask24 & 0xFF);
 919:main.cpp      ****     e.padMaskHi  = (uint8_t)((padMask24 >> 8) & 0xFF);
 920:main.cpp      ****     e.padMaskXtra= (uint8_t)((padMask24 >> 16) & 0xFF);
 921:main.cpp      ****     if(name) strncpy(e.name, name, 23);
 922:main.cpp      ****     evtHead = (evtHead + 1) % EVT_QUEUE_SIZE;
 923:main.cpp      ****     evtCount++;
 924:main.cpp      **** }
 925:main.cpp      **** 
 926:main.cpp      **** static uint8_t PopEvents(NotifyEvent* dst, uint8_t maxEvents)
 927:main.cpp      **** {
 928:main.cpp      ****     uint8_t count = 0;
 929:main.cpp      ****     while(evtCount > 0 && count < maxEvents){
 930:main.cpp      ****         dst[count++] = evtQueue[evtTail];
 931:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 932:main.cpp      ****         evtCount--;
 933:main.cpp      ****     }
 934:main.cpp      ****     return count;
 935:main.cpp      **** }
