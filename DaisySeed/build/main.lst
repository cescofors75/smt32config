   2:synth/tr505.h ****  *  TR505 ŌĆö Roland TR-505 Drum Synthesis Library
   3:synth/tr505.h ****  * ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
   4:synth/tr505.h ****  *  Sonido m├Īs digital y lo-fi que 808/909.
   5:synth/tr505.h ****  *  La 505 ten├Ła samples PCM de 8 bits ŌĆö aqu├Ł recreamos
   6:synth/tr505.h ****  *  su car├Īcter con s├Łntesis simplificada + bit reduction.
   7:synth/tr505.h ****  *  Sonido new wave, synth-pop, electro temprano.
   8:synth/tr505.h ****  *
   9:synth/tr505.h ****  *  48 kHz ┬Ę float32 ┬Ę header-only
  10:synth/tr505.h ****  *
  11:synth/tr505.h ****  *  Instrumentos:
  12:synth/tr505.h ****  *    Kick, Snare, Clap, HiHatClosed, HiHatOpen,
  13:synth/tr505.h ****  *    LowTom, MidTom, HiTom, Cowbell, Cymbal, RimShot
  14:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  15:synth/tr505.h **** #pragma once
  16:synth/tr505.h **** 
  17:synth/tr505.h **** #include <math.h>
  18:synth/tr505.h **** #include <stdint.h>
  19:synth/tr505.h **** 
  20:synth/tr505.h **** #ifndef TWOPI_F
  21:synth/tr505.h **** #define TWOPI_F 6.283185307f
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 377


  22:synth/tr505.h **** #endif
  23:synth/tr505.h **** 
  24:synth/tr505.h **** namespace TR505 {
  25:synth/tr505.h **** 
  26:synth/tr505.h **** static inline float Noise(uint32_t& state) {
  27:synth/tr505.h ****     state ^= state << 13;
  28:synth/tr505.h ****     state ^= state >> 17;
  29:synth/tr505.h ****     state ^= state << 5;
  30:synth/tr505.h ****     return ((float)(int32_t)state) / 2147483648.0f;
  31:synth/tr505.h **** }
  32:synth/tr505.h **** 
  33:synth/tr505.h **** static inline float Clamp(float v, float lo, float hi) {
  34:synth/tr505.h ****     return v < lo ? lo : (v > hi ? hi : v);
  35:synth/tr505.h **** }
  36:synth/tr505.h **** 
  37:synth/tr505.h **** /* Car├Īcter lo-fi de la 505: reduce resoluci├│n */
  38:synth/tr505.h **** static inline float LoFi(float s, float amount) {
  39:synth/tr505.h ****     if (amount < 0.01f) return s;
  40:synth/tr505.h ****     float levels = 256.0f / (1.0f + amount * 240.0f); /* 256 ŌåÆ 16 levels */
  41:synth/tr505.h ****     return roundf(s * levels) / levels;
  42:synth/tr505.h **** }
  43:synth/tr505.h **** 
  44:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  45:synth/tr505.h ****  *  KICK 505
  46:synth/tr505.h ****  *  M├Īs corto y menos profundo que 808, car├Īcter punchy digital
  47:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  48:synth/tr505.h **** class Kick {
  49:synth/tr505.h **** public:
  50:synth/tr505.h ****     float decay      = 0.25f;
  51:synth/tr505.h ****     float pitch      = 60.0f;
  52:synth/tr505.h ****     float pitchDecay = 0.03f;
  53:synth/tr505.h ****     float lofi       = 0.15f;   /* cantidad de lo-fi */
  54:synth/tr505.h ****     float volume     = 1.0f;
  55:synth/tr505.h **** 
  56:synth/tr505.h ****     void Init(float sampleRate) {
  57:synth/tr505.h ****         sr_ = sampleRate;
  58:synth/tr505.h ****         dt_ = 1.0f / sr_;
  59:synth/tr505.h ****         active_ = false;
  60:synth/tr505.h ****     }
  61:synth/tr505.h **** 
  62:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
  63:synth/tr505.h ****         active_ = true;
  64:synth/tr505.h ****         time_ = 0.0f;
  65:synth/tr505.h ****         phase_ = 0.0f;
  66:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
  67:synth/tr505.h ****     }
  68:synth/tr505.h **** 
  69:synth/tr505.h ****     float Process() {
  70:synth/tr505.h ****         if (!active_) return 0.0f;
  71:synth/tr505.h **** 
  72:synth/tr505.h ****         float cp = pitch + pitch * 5.0f * expf(-time_ / pitchDecay);
  73:synth/tr505.h ****         phase_ += cp * dt_;
  74:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
  75:synth/tr505.h ****         float sine = sinf(TWOPI_F * phase_);
  76:synth/tr505.h **** 
  77:synth/tr505.h ****         float env = expf(-time_ / decay);
  78:synth/tr505.h ****         float output = tanhf(sine * 1.3f) * env;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 378


  79:synth/tr505.h ****         output = LoFi(output, lofi);
  80:synth/tr505.h **** 
  81:synth/tr505.h ****         time_ += dt_;
  82:synth/tr505.h ****         if (env < 0.001f) active_ = false;
  83:synth/tr505.h **** 
  84:synth/tr505.h ****         return output * volume * vel_;
  85:synth/tr505.h ****     }
  86:synth/tr505.h **** 
  87:synth/tr505.h ****     bool IsActive() const { return active_; }
  88:synth/tr505.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 0.8f); }
  89:synth/tr505.h **** 
  90:synth/tr505.h **** private:
  91:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
  92:synth/tr505.h ****     bool  active_ = false;
  93:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
  94:synth/tr505.h **** };
  95:synth/tr505.h **** 
  96:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  97:synth/tr505.h ****  *  SNARE 505
  98:synth/tr505.h ****  *  M├Īs digital, tono m├Īs agudo, noise m├Īs suave
  99:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 100:synth/tr505.h **** class Snare {
 101:synth/tr505.h **** public:
 102:synth/tr505.h ****     float decay   = 0.15f;
 103:synth/tr505.h ****     float tone    = 0.4f;
 104:synth/tr505.h ****     float snappy  = 0.6f;
 105:synth/tr505.h ****     float pitch   = 220.0f;
 106:synth/tr505.h ****     float lofi    = 0.15f;
 107:synth/tr505.h ****     float volume  = 1.0f;
 108:synth/tr505.h **** 
 109:synth/tr505.h ****     void Init(float sampleRate) {
 110:synth/tr505.h ****         sr_ = sampleRate;
 111:synth/tr505.h ****         dt_ = 1.0f / sr_;
 112:synth/tr505.h ****         active_ = false;
 113:synth/tr505.h ****         noiseState_ = 0x505BEEF;
 114:synth/tr505.h ****     }
 115:synth/tr505.h **** 
 116:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 117:synth/tr505.h ****         active_ = true;
 118:synth/tr505.h ****         time_ = 0.0f;
 119:synth/tr505.h ****         phase_ = 0.0f;
 120:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 121:synth/tr505.h ****     }
 122:synth/tr505.h **** 
 123:synth/tr505.h ****     float Process() {
 124:synth/tr505.h ****         if (!active_) return 0.0f;
 125:synth/tr505.h **** 
 126:synth/tr505.h ****         phase_ += pitch * dt_;
 127:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 128:synth/tr505.h ****         float t = sinf(TWOPI_F * phase_);
 129:synth/tr505.h ****         float toneEnv = expf(-time_ / (decay * 0.5f));
 130:synth/tr505.h ****         float toneOut = t * toneEnv * tone;
 131:synth/tr505.h **** 
 132:synth/tr505.h ****         float n = Noise(noiseState_);
 133:synth/tr505.h ****         float noiseEnv = expf(-time_ / decay);
 134:synth/tr505.h ****         float noiseOut = n * noiseEnv * snappy;
 135:synth/tr505.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 379


 136:synth/tr505.h ****         float output = toneOut + noiseOut;
 137:synth/tr505.h ****         output = tanhf(output * 1.5f);
 138:synth/tr505.h ****         output = LoFi(output, lofi);
 139:synth/tr505.h **** 
 140:synth/tr505.h ****         time_ += dt_;
 141:synth/tr505.h ****         if (noiseEnv < 0.001f) active_ = false;
 142:synth/tr505.h **** 
 143:synth/tr505.h ****         return output * volume * vel_;
 144:synth/tr505.h ****     }
 145:synth/tr505.h **** 
 146:synth/tr505.h ****     bool IsActive() const { return active_; }
 147:synth/tr505.h **** 
 148:synth/tr505.h **** private:
 149:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 150:synth/tr505.h ****     bool  active_ = false;
 151:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 152:synth/tr505.h ****     uint32_t noiseState_ = 0x505BEEF;
 153:synth/tr505.h **** };
 154:synth/tr505.h **** 
 155:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 156:synth/tr505.h ****  *  CLAP 505
 157:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 158:synth/tr505.h **** class Clap {
 159:synth/tr505.h **** public:
 160:synth/tr505.h ****     float decay  = 0.2f;
 161:synth/tr505.h ****     float lofi   = 0.15f;
 162:synth/tr505.h ****     float volume = 1.0f;
 163:synth/tr505.h **** 
 164:synth/tr505.h ****     void Init(float sampleRate) {
 165:synth/tr505.h ****         sr_ = sampleRate;
 166:synth/tr505.h ****         dt_ = 1.0f / sr_;
 167:synth/tr505.h ****         active_ = false;
 168:synth/tr505.h ****         noiseState_ = 0x505C1A9;
 169:synth/tr505.h ****     }
 170:synth/tr505.h **** 
 171:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 172:synth/tr505.h ****         active_ = true;
 173:synth/tr505.h ****         time_ = 0.0f;
 174:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 175:synth/tr505.h ****     }
 176:synth/tr505.h **** 
 177:synth/tr505.h ****     float Process() {
 178:synth/tr505.h ****         if (!active_) return 0.0f;
 179:synth/tr505.h **** 
 180:synth/tr505.h ****         float n = Noise(noiseState_);
 181:synth/tr505.h **** 
 182:synth/tr505.h ****         /* 3 r├Īfagas (simpler que 808/909) */
 183:synth/tr505.h ****         float burstT = 0.008f;
 184:synth/tr505.h ****         float env = 0.0f;
 185:synth/tr505.h ****         for (int i = 0; i < 3; i++) {
 186:synth/tr505.h ****             float t = time_ - i * burstT;
 187:synth/tr505.h ****             if (t >= 0.0f && t < burstT)
 188:synth/tr505.h ****                 env += expf(-t / 0.002f) * 0.5f;
 189:synth/tr505.h ****         }
 190:synth/tr505.h ****         float tailStart = 3.0f * burstT;
 191:synth/tr505.h ****         if (time_ >= tailStart)
 192:synth/tr505.h ****             env += expf(-(time_ - tailStart) / decay);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 380


 193:synth/tr505.h **** 
 194:synth/tr505.h ****         float output = n * env;
 195:synth/tr505.h ****         output = tanhf(output * 1.8f);
 196:synth/tr505.h ****         output = LoFi(output, lofi);
 197:synth/tr505.h **** 
 198:synth/tr505.h ****         time_ += dt_;
 199:synth/tr505.h ****         if (time_ > decay + 0.05f && env < 0.001f) active_ = false;
 200:synth/tr505.h **** 
 201:synth/tr505.h ****         return output * volume * vel_;
 202:synth/tr505.h ****     }
 203:synth/tr505.h **** 
 204:synth/tr505.h ****     bool IsActive() const { return active_; }
 205:synth/tr505.h **** 
 206:synth/tr505.h **** private:
 207:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 208:synth/tr505.h ****     bool  active_ = false;
 209:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 210:synth/tr505.h ****     uint32_t noiseState_ = 0x505C1A9;
 211:synth/tr505.h **** };
 212:synth/tr505.h **** 
 213:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 214:synth/tr505.h ****  *  HIHAT 505 ŌĆö M├Īs simple, solo noise filtrado
 215:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 216:synth/tr505.h **** class HiHatClosed {
 217:synth/tr505.h **** public:
 218:synth/tr505.h ****     float decay  = 0.03f;
 219:synth/tr505.h ****     float tone   = 0.5f;
 220:synth/tr505.h ****     float lofi   = 0.2f;
 221:synth/tr505.h ****     float volume = 1.0f;
 222:synth/tr505.h **** 
 223:synth/tr505.h ****     void Init(float sampleRate) {
 224:synth/tr505.h ****         sr_ = sampleRate;
 225:synth/tr505.h ****         dt_ = 1.0f / sr_;
 226:synth/tr505.h ****         active_ = false;
 227:synth/tr505.h ****         noiseState_ = 0x505AA01;
 228:synth/tr505.h ****     }
 229:synth/tr505.h **** 
 230:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 231:synth/tr505.h ****         active_ = true;
 232:synth/tr505.h ****         time_ = 0.0f;
 233:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 234:synth/tr505.h ****         hpZ1_ = hpOut_ = 0.0f;
 235:synth/tr505.h ****     }
 236:synth/tr505.h **** 
 237:synth/tr505.h ****     float Process() {
 238:synth/tr505.h ****         if (!active_) return 0.0f;
 239:synth/tr505.h **** 
 240:synth/tr505.h ****         float n = Noise(noiseState_);
 241:synth/tr505.h **** 
 242:synth/tr505.h ****         /* Highpass ~5kHz */
 243:synth/tr505.h ****         float fc = 4000.0f + tone * 4000.0f;
 244:synth/tr505.h ****         float rc = 1.0f / (TWOPI_F * fc);
 245:synth/tr505.h ****         float alpha = rc / (rc + dt_);
 246:synth/tr505.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 247:synth/tr505.h ****         hpZ1_ = n;
 248:synth/tr505.h **** 
 249:synth/tr505.h ****         float env = expf(-time_ / decay);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 381


 250:synth/tr505.h ****         float output = hpOut_ * env;
 251:synth/tr505.h ****         output = LoFi(output, lofi);
 252:synth/tr505.h **** 
 253:synth/tr505.h ****         time_ += dt_;
 254:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 255:synth/tr505.h **** 
 256:synth/tr505.h ****         return output * volume * vel_;
 257:synth/tr505.h ****     }
 258:synth/tr505.h **** 
 259:synth/tr505.h ****     bool IsActive() const { return active_; }
 260:synth/tr505.h **** 
 261:synth/tr505.h **** private:
 262:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 263:synth/tr505.h ****     bool  active_ = false;
 264:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 265:synth/tr505.h ****     uint32_t noiseState_ = 0x505AA01;
 266:synth/tr505.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 267:synth/tr505.h **** };
