  19:synth/tr808.h **** #define TWOPI_F 6.283185307f
  20:synth/tr808.h **** #endif
  21:synth/tr808.h **** 
  22:synth/tr808.h **** namespace TR808 {
  23:synth/tr808.h **** 
  24:synth/tr808.h **** /* ŌöĆŌöĆ PRNG r├Īpido para ruido ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
  25:synth/tr808.h **** static inline float Noise(uint32_t& state) {
  26:synth/tr808.h ****     state ^= state << 13;
  27:synth/tr808.h ****     state ^= state >> 17;
  28:synth/tr808.h ****     state ^= state << 5;
  29:synth/tr808.h ****     return ((float)(int32_t)state) / 2147483648.0f;
  30:synth/tr808.h **** }
  31:synth/tr808.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 142


  32:synth/tr808.h **** /* ŌöĆŌöĆ Clamp helper ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  33:synth/tr808.h **** static inline float Clamp(float v, float lo, float hi) {
  34:synth/tr808.h ****     return v < lo ? lo : (v > hi ? hi : v);
  35:synth/tr808.h **** }
  36:synth/tr808.h **** 
  37:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  38:synth/tr808.h ****  *  KICK 808
  39:synth/tr808.h ****  *  Sine + pitch envelope exponencial + saturaci├│n tanh
  40:synth/tr808.h ****  *  El sonido m├Īs ic├│nico: "boom" profundo con ca├Łda de pitch
  41:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  42:synth/tr808.h **** class Kick {
  43:synth/tr808.h **** public:
  44:synth/tr808.h ****     /* Par├Īmetros (knobs) */
  45:synth/tr808.h ****     float decay      = 0.45f;   /* 0.1 - 0.8 s    duraci├│n del boom     */
  46:synth/tr808.h ****     float pitch      = 55.0f;   /* 40  - 80 Hz     frecuencia base       */
  47:synth/tr808.h ****     float pitchDecay = 0.08f;   /* 0.02 - 0.5 s    ca├Łda del pitch       */
  48:synth/tr808.h ****     float attack     = 0.005f;  /* 0.001 - 0.02 s  click inicial         */
  49:synth/tr808.h ****     float saturation = 0.3f;    /* 0.0 - 1.0       suciedad anal├│gica    */
  50:synth/tr808.h ****     float volume     = 1.0f;    /* 0.0 - 1.0       nivel de salida       */
  51:synth/tr808.h **** 
  52:synth/tr808.h ****     void Init(float sampleRate) {
  53:synth/tr808.h ****         sr_ = sampleRate;
  54:synth/tr808.h ****         dt_ = 1.0f / sr_;
  55:synth/tr808.h ****         active_ = false;
  56:synth/tr808.h ****         time_ = 0.0f;
  57:synth/tr808.h ****         phase_ = 0.0f;
  58:synth/tr808.h ****     }
  59:synth/tr808.h **** 
  60:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
  61:synth/tr808.h ****         active_ = true;
  62:synth/tr808.h ****         time_ = 0.0f;
  63:synth/tr808.h ****         phase_ = 0.0f;
  64:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
  65:synth/tr808.h ****     }
  66:synth/tr808.h **** 
  67:synth/tr808.h ****     float Process() {
  68:synth/tr808.h ****         if (!active_) return 0.0f;
  69:synth/tr808.h **** 
  70:synth/tr808.h ****         /* 1. Pitch actual: cae exponencialmente */
  71:synth/tr808.h ****         float currentPitch = pitch + pitch * 8.0f * expf(-time_ / pitchDecay);
  72:synth/tr808.h **** 
  73:synth/tr808.h ****         /* 2. Avanzar fase del oscilador sine */
  74:synth/tr808.h ****         phase_ += currentPitch * dt_;
  75:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
  76:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
  77:synth/tr808.h **** 
  78:synth/tr808.h ****         /* 3. Click de ataque (transitorio) */
  79:synth/tr808.h ****         float clickEnv = expf(-time_ / attack);
  80:synth/tr808.h ****         float click = clickEnv * sinf(TWOPI_F * 1200.0f * time_) * 0.3f;
  81:synth/tr808.h **** 
  82:synth/tr808.h ****         /* 4. Envelope de amplitud */
  83:synth/tr808.h ****         float amp = expf(-time_ / decay);
  84:synth/tr808.h **** 
  85:synth/tr808.h ****         /* 5. Mezclar sine + click */
  86:synth/tr808.h ****         float output = sine + click;
  87:synth/tr808.h **** 
  88:synth/tr808.h ****         /* 6. Saturaci├│n suave (car├Īcter anal├│gico) */
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 143


  89:synth/tr808.h ****         output = tanhf(output * (1.0f + saturation * 3.0f));
  90:synth/tr808.h **** 
  91:synth/tr808.h ****         /* 7. Avanzar tiempo */
  92:synth/tr808.h ****         time_ += dt_;
  93:synth/tr808.h **** 
  94:synth/tr808.h ****         /* 8. Desactivar cuando es inaudible */
  95:synth/tr808.h ****         if (amp < 0.001f) active_ = false;
  96:synth/tr808.h **** 
  97:synth/tr808.h ****         return output * amp * volume * vel_;
  98:synth/tr808.h ****     }
  99:synth/tr808.h **** 
 100:synth/tr808.h ****     bool IsActive() const { return active_; }
 101:synth/tr808.h **** 
 102:synth/tr808.h ****     void SetDecay(float d)  { decay = Clamp(d, 0.05f, 2.0f); }
 103:synth/tr808.h ****     void SetPitch(float p)  { pitch = Clamp(p, 30.0f, 120.0f); }
 104:synth/tr808.h **** 
 105:synth/tr808.h **** private:
 106:synth/tr808.h ****     float sr_ = 48000.0f;
 107:synth/tr808.h ****     float dt_ = 1.0f / 48000.0f;
 108:synth/tr808.h ****     bool  active_ = false;
 109:synth/tr808.h ****     float time_ = 0.0f;
 110:synth/tr808.h ****     float phase_ = 0.0f;
 111:synth/tr808.h ****     float vel_ = 1.0f;
 112:synth/tr808.h **** };
