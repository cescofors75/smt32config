 388:main.cpp      ****  *  10. BiquadEQ  (Audio EQ Cookbook ŌĆō LP/HP/BP/Notch/Peak/Shelf)
 389:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 390:main.cpp      **** struct BiquadEQ {
 391:main.cpp      ****     float b0=1,b1=0,b2=0,a1=0,a2=0;
 392:main.cpp      ****     float z1=0,z2=0;
 393:main.cpp      **** 
 394:main.cpp      ****     float Process(float in){
 395:main.cpp      ****         float out = b0*in + z1;
 396:main.cpp      ****         z1 = b1*in - a1*out + z2;
 397:main.cpp      ****         z2 = b2*in - a2*out;
 398:main.cpp      ****         return out;
 399:main.cpp      ****     }
 400:main.cpp      ****     void Reset(){ z1=z2=0; }
 401:main.cpp      **** 
 402:main.cpp      ****     void SetType(uint8_t t, float freq, float q, float sr, float gainDb=0.f){
 403:main.cpp      ****         if(freq<20.f) freq=20.f;
 404:main.cpp      ****         if(freq>sr*0.45f) freq=sr*0.45f;
 405:main.cpp      ****         if(q<0.3f) q=0.3f;
 406:main.cpp      ****         float w = 2.f*(float)M_PI*freq/sr;
 407:main.cpp      ****         float s_ = sinf(w), c_ = cosf(w);
 408:main.cpp      ****         float a  = s_/(2.f*q);
 409:main.cpp      ****         float a0i;
 410:main.cpp      ****         switch(t){
 411:main.cpp      ****             case FTYPE_LOWPASS:
 412:main.cpp      ****                 a0i = 1.f/(1.f+a);
 413:main.cpp      ****                 b0 = ((1.f-c_)*0.5f)*a0i;
 414:main.cpp      ****                 b1 = (1.f-c_)*a0i;
 415:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 416:main.cpp      ****                 break;
 417:main.cpp      ****             case FTYPE_HIGHPASS:
 418:main.cpp      ****                 a0i = 1.f/(1.f+a);
 419:main.cpp      ****                 b0 = ((1.f+c_)*0.5f)*a0i;
 420:main.cpp      ****                 b1 = -(1.f+c_)*a0i;
 421:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 422:main.cpp      ****                 break;
 423:main.cpp      ****             case FTYPE_BANDPASS:
 424:main.cpp      ****                 a0i = 1.f/(1.f+a);
 425:main.cpp      ****                 b0 = a*a0i; b1=0; b2=-b0;
 426:main.cpp      ****                 a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 427:main.cpp      ****                 break;
 428:main.cpp      ****             case FTYPE_NOTCH:
 429:main.cpp      ****                 a0i = 1.f/(1.f+a);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 27


 430:main.cpp      ****                 b0 = a0i; b1=(-2.f*c_)*a0i; b2=a0i;
 431:main.cpp      ****                 a1=b1; a2=(1.f-a)*a0i;
 432:main.cpp      ****                 break;
 433:main.cpp      ****             case FTYPE_PEAKING: {
 434:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 435:main.cpp      ****                 a0i = 1.f/(1.f + a/A);
 436:main.cpp      ****                 b0 = (1.f + a*A)*a0i;
 437:main.cpp      ****                 b1 = (-2.f*c_)*a0i;
 438:main.cpp      ****                 b2 = (1.f - a*A)*a0i;
 439:main.cpp      ****                 a1 = b1; a2 = (1.f - a/A)*a0i;
 440:main.cpp      ****                 break;
 441:main.cpp      ****             }
 442:main.cpp      ****             case FTYPE_LOWSHELF: {
 443:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 444:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 445:main.cpp      ****                 a0i = 1.f/((A+1.f)+(A-1.f)*c_+sq);
 446:main.cpp      ****                 b0 = A*((A+1.f)-(A-1.f)*c_+sq)*a0i;
 447:main.cpp      ****                 b1 = 2.f*A*((A-1.f)-(A+1.f)*c_)*a0i;
 448:main.cpp      ****                 b2 = A*((A+1.f)-(A-1.f)*c_-sq)*a0i;
 449:main.cpp      ****                 a1 = -2.f*((A-1.f)+(A+1.f)*c_)*a0i;
 450:main.cpp      ****                 a2 = ((A+1.f)+(A-1.f)*c_-sq)*a0i;
 451:main.cpp      ****                 break;
 452:main.cpp      ****             }
 453:main.cpp      ****             case FTYPE_HIGHSHELF: {
 454:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 455:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 456:main.cpp      ****                 a0i = 1.f/((A+1.f)-(A-1.f)*c_+sq);
 457:main.cpp      ****                 b0 = A*((A+1.f)+(A-1.f)*c_+sq)*a0i;
 458:main.cpp      ****                 b1 = -2.f*A*((A-1.f)+(A+1.f)*c_)*a0i;
 459:main.cpp      ****                 b2 = A*((A+1.f)+(A-1.f)*c_-sq)*a0i;
 460:main.cpp      ****                 a1 = 2.f*((A-1.f)-(A+1.f)*c_)*a0i;
 461:main.cpp      ****                 a2 = ((A+1.f)-(A-1.f)*c_+sq)*a0i;
 462:main.cpp      ****                 break;
 463:main.cpp      ****             }
 464:main.cpp      ****             default: b0=1;b1=b2=a1=a2=0; break;
 465:main.cpp      ****         }
 466:main.cpp      ****     }
 467:main.cpp      **** };
