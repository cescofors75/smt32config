 545:synth/tr909.h ****  *  RIMSHOT 909
 546:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 547:synth/tr909.h **** class RimShot {
 548:synth/tr909.h **** public:
 549:synth/tr909.h ****     float decay  = 0.02f;
 550:synth/tr909.h ****     float pitch  = 880.0f;
 551:synth/tr909.h ****     float volume = 1.0f;
 552:synth/tr909.h **** 
 553:synth/tr909.h ****     void Init(float sampleRate) {
 554:synth/tr909.h ****         sr_ = sampleRate;
 555:synth/tr909.h ****         dt_ = 1.0f / sr_;
 556:synth/tr909.h ****         active_ = false;
 557:synth/tr909.h ****         noiseState_ = 0x909E1A5;
 558:synth/tr909.h ****     }
 559:synth/tr909.h **** 
 560:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 561:synth/tr909.h ****         active_ = true;
 562:synth/tr909.h ****         time_ = 0.0f;
 563:synth/tr909.h ****         phase_ = 0.0f;
 564:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 565:synth/tr909.h ****     }
 566:synth/tr909.h **** 
 567:synth/tr909.h ****     float Process() {
 568:synth/tr909.h ****         if (!active_) return 0.0f;
 569:synth/tr909.h **** 
 570:synth/tr909.h ****         float n = Noise(noiseState_);
 571:synth/tr909.h ****         float clickEnv = expf(-time_ / 0.0005f);
 572:synth/tr909.h ****         float click = n * clickEnv * 0.6f;
 573:synth/tr909.h **** 
 574:synth/tr909.h ****         phase_ += pitch * dt_;
 575:synth/tr909.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 576:synth/tr909.h ****         float sine = sinf(TWOPI_F * phase_);
 577:synth/tr909.h ****         float toneEnv = expf(-time_ / decay);
 578:synth/tr909.h **** 
 579:synth/tr909.h ****         float output = click + sine * toneEnv;
 580:synth/tr909.h ****         output = tanhf(output * 2.0f);
 581:synth/tr909.h **** 
 582:synth/tr909.h ****         time_ += dt_;
 583:synth/tr909.h ****         if (toneEnv < 0.001f) active_ = false;
 584:synth/tr909.h **** 
 585:synth/tr909.h ****         return output * volume * vel_;
 586:synth/tr909.h ****     }
 587:synth/tr909.h **** 
 588:synth/tr909.h ****     bool IsActive() const { return active_; }
 589:synth/tr909.h **** 
 590:synth/tr909.h **** private:
 591:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 592:synth/tr909.h ****     bool  active_ = false;
 593:synth/tr909.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 594:synth/tr909.h ****     uint32_t noiseState_ = 0x909E1A5;
 595:synth/tr909.h **** };
