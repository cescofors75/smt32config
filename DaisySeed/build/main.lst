 259:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 260:synth/tr909.h ****  *  HIHAT 909 BASE
 261:synth/tr909.h ****  *  6 pulsos met├Īlicos ŌĆö frecuencias diferentes a la 808
 262:synth/tr909.h ****  *  M├Īs brillante, m├Īs "digital" en car├Īcter
 263:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 264:synth/tr909.h **** class HiHat909Base {
 265:synth/tr909.h **** protected:
 266:synth/tr909.h ****     static constexpr float METAL_FREQS[6] = {
 267:synth/tr909.h ****         263.5f, 400.0f, 531.0f, 588.0f, 678.0f, 1043.0f
 268:synth/tr909.h ****     };
 269:synth/tr909.h **** 
 270:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 271:synth/tr909.h ****     bool  active_ = false;
 272:synth/tr909.h ****     float time_ = 0.0f, vel_ = 1.0f;
 273:synth/tr909.h ****     float phase_[6] = {};
 274:synth/tr909.h ****     uint32_t noiseState_ = 0x909AA01;
 275:synth/tr909.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 276:synth/tr909.h **** 
 277:synth/tr909.h ****     float MetallicNoise() {
 278:synth/tr909.h ****         float sum = 0.0f;
 279:synth/tr909.h ****         for (int i = 0; i < 6; i++) {
 280:synth/tr909.h ****             phase_[i] += METAL_FREQS[i] * dt_;
 281:synth/tr909.h ****             if (phase_[i] >= 1.0f) phase_[i] -= 1.0f;
 282:synth/tr909.h ****             sum += (phase_[i] < 0.5f) ? 1.0f : -1.0f;
 283:synth/tr909.h ****         }
 284:synth/tr909.h ****         float n = Noise(noiseState_) * 0.2f;
 285:synth/tr909.h ****         return (sum / 6.0f + n);
 286:synth/tr909.h ****     }
 287:synth/tr909.h **** 
 288:synth/tr909.h ****     float Highpass(float in) {
 289:synth/tr909.h ****         float rc = 1.0f / (TWOPI_F * 7500.0f); /* m├Īs alto que 808 */
 290:synth/tr909.h ****         float alpha = rc / (rc + dt_);
 291:synth/tr909.h ****         hpOut_ = alpha * (hpOut_ + in - hpZ1_);
 292:synth/tr909.h ****         hpZ1_ = in;
 293:synth/tr909.h ****         return hpOut_;
 294:synth/tr909.h ****     }
 295:synth/tr909.h **** };
 296:synth/tr909.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 232


 297:synth/tr909.h **** constexpr float HiHat909Base::METAL_FREQS[6];
 298:synth/tr909.h **** 
 299:synth/tr909.h **** class HiHatClosed : public HiHat909Base {
 300:synth/tr909.h **** public:
 301:synth/tr909.h ****     float decay  = 0.03f;
 302:synth/tr909.h ****     float tone   = 0.6f;
 303:synth/tr909.h ****     float volume = 1.0f;
 304:synth/tr909.h **** 
 305:synth/tr909.h ****     void Init(float sampleRate) {
 306:synth/tr909.h ****         sr_ = sampleRate;
 307:synth/tr909.h ****         dt_ = 1.0f / sr_;
 308:synth/tr909.h ****         active_ = false;
 309:synth/tr909.h ****         noiseState_ = 0x909AAAA;
 310:synth/tr909.h ****     }
 311:synth/tr909.h **** 
 312:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 313:synth/tr909.h ****         active_ = true;
 314:synth/tr909.h ****         time_ = 0.0f;
 315:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 316:synth/tr909.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 317:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 318:synth/tr909.h ****     }
 319:synth/tr909.h **** 
 320:synth/tr909.h ****     float Process() {
 321:synth/tr909.h ****         if (!active_) return 0.0f;
 322:synth/tr909.h **** 
 323:synth/tr909.h ****         float metal = MetallicNoise();
 324:synth/tr909.h ****         float hp = Highpass(metal);
 325:synth/tr909.h ****         float env = expf(-time_ / decay);
 326:synth/tr909.h **** 
 327:synth/tr909.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 328:synth/tr909.h ****         output = tanhf(output * 2.5f);
 329:synth/tr909.h **** 
 330:synth/tr909.h ****         time_ += dt_;
 331:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 332:synth/tr909.h **** 
 333:synth/tr909.h ****         return output * volume * vel_;
 334:synth/tr909.h ****     }
 335:synth/tr909.h **** 
 336:synth/tr909.h ****     bool IsActive() const { return active_; }
 337:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.01f, 0.2f); }
 338:synth/tr909.h **** };
 339:synth/tr909.h **** 
 340:synth/tr909.h **** class HiHatOpen : public HiHat909Base {
 341:synth/tr909.h **** public:
 342:synth/tr909.h ****     float decay  = 0.3f;
 343:synth/tr909.h ****     float tone   = 0.6f;
 344:synth/tr909.h ****     float volume = 1.0f;
 345:synth/tr909.h **** 
 346:synth/tr909.h ****     void Init(float sampleRate) {
 347:synth/tr909.h ****         sr_ = sampleRate;
 348:synth/tr909.h ****         dt_ = 1.0f / sr_;
 349:synth/tr909.h ****         active_ = false;
 350:synth/tr909.h ****         noiseState_ = 0x909BBBB;
 351:synth/tr909.h ****     }
 352:synth/tr909.h **** 
 353:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 233


 354:synth/tr909.h ****         active_ = true;
 355:synth/tr909.h ****         time_ = 0.0f;
 356:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 357:synth/tr909.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 358:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 359:synth/tr909.h ****     }
 360:synth/tr909.h **** 
 361:synth/tr909.h ****     void Choke() { active_ = false; }
 362:synth/tr909.h **** 
 363:synth/tr909.h ****     float Process() {
 364:synth/tr909.h ****         if (!active_) return 0.0f;
 365:synth/tr909.h **** 
 366:synth/tr909.h ****         float metal = MetallicNoise();
 367:synth/tr909.h ****         float hp = Highpass(metal);
 368:synth/tr909.h ****         float env = expf(-time_ / decay);
 369:synth/tr909.h **** 
 370:synth/tr909.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 371:synth/tr909.h ****         output = tanhf(output * 2.5f);
 372:synth/tr909.h **** 
 373:synth/tr909.h ****         time_ += dt_;
 374:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 375:synth/tr909.h **** 
 376:synth/tr909.h ****         return output * volume * vel_;
 377:synth/tr909.h ****     }
 378:synth/tr909.h **** 
 379:synth/tr909.h ****     bool IsActive() const { return active_; }
 380:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 2.0f); }
 381:synth/tr909.h **** };
 382:synth/tr909.h **** 
 383:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 384:synth/tr909.h ****  *  TOM 909
 385:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 386:synth/tr909.h **** class Tom909 {
 387:synth/tr909.h **** public:
 388:synth/tr909.h ****     float decay      = 0.2f;
 389:synth/tr909.h ****     float pitch      = 150.0f;
 390:synth/tr909.h ****     float pitchDecay = 0.03f;
 391:synth/tr909.h ****     float attack     = 0.4f;   /* click amount */
 392:synth/tr909.h ****     float volume     = 1.0f;
 393:synth/tr909.h **** 
 394:synth/tr909.h ****     void Init(float sampleRate) {
 395:synth/tr909.h ****         sr_ = sampleRate;
 396:synth/tr909.h ****         dt_ = 1.0f / sr_;
 397:synth/tr909.h ****         active_ = false;
 398:synth/tr909.h ****     }
 399:synth/tr909.h **** 
 400:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 401:synth/tr909.h ****         active_ = true;
 402:synth/tr909.h ****         time_ = 0.0f;
 403:synth/tr909.h ****         phase_ = 0.0f;
 404:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 405:synth/tr909.h ****     }
 406:synth/tr909.h **** 
 407:synth/tr909.h ****     float Process() {
 408:synth/tr909.h ****         if (!active_) return 0.0f;
 409:synth/tr909.h **** 
 410:synth/tr909.h ****         float cp = pitch + pitch * 3.0f * expf(-time_ / pitchDecay);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 234


 411:synth/tr909.h ****         phase_ += cp * dt_;
 412:synth/tr909.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 413:synth/tr909.h ****         float sine = sinf(TWOPI_F * phase_);
 414:synth/tr909.h **** 
 415:synth/tr909.h ****         /* Click transitorio */
 416:synth/tr909.h ****         float clickEnv = expf(-time_ / 0.001f);
 417:synth/tr909.h ****         float click = clickEnv * sinf(TWOPI_F * 1500.0f * time_) * attack;
 418:synth/tr909.h **** 
 419:synth/tr909.h ****         float env = expf(-time_ / decay);
 420:synth/tr909.h ****         float output = tanhf((sine + click * 0.3f) * 1.4f) * env;
 421:synth/tr909.h **** 
 422:synth/tr909.h ****         time_ += dt_;
 423:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 424:synth/tr909.h **** 
 425:synth/tr909.h ****         return output * volume * vel_;
 426:synth/tr909.h ****     }
 427:synth/tr909.h **** 
 428:synth/tr909.h ****     bool IsActive() const { return active_; }
 429:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 0.8f); }
 430:synth/tr909.h ****     void SetPitch(float p) { pitch = Clamp(p, 60.0f, 400.0f); }
 431:synth/tr909.h **** 
 432:synth/tr909.h **** private:
 433:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 434:synth/tr909.h ****     bool  active_ = false;
 435:synth/tr909.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 436:synth/tr909.h **** };
 437:synth/tr909.h **** 
 438:synth/tr909.h **** class LowTom : public Tom909 {
 439:synth/tr909.h **** public:
 440:synth/tr909.h ****     LowTom()  { pitch = 90.0f;  decay = 0.3f;  }
 441:synth/tr909.h **** };
 442:synth/tr909.h **** class MidTom : public Tom909 {
 443:synth/tr909.h **** public:
 444:synth/tr909.h ****     MidTom()  { pitch = 140.0f; decay = 0.25f; }
 445:synth/tr909.h **** };
 446:synth/tr909.h **** class HiTom : public Tom909 {
 447:synth/tr909.h **** public:
 448:synth/tr909.h ****     HiTom()   { pitch = 210.0f; decay = 0.2f;  }
 449:synth/tr909.h **** };
