3682:main.cpp      ****         /* Optimal: direct read */
3683:main.cpp      ****         f_read(&fil, sampleStorage[padIdx], totalFrames * 2, &br);
3684:main.cpp      ****         sampleLength[padIdx] = br / 2;
3685:main.cpp      ****     } else {
