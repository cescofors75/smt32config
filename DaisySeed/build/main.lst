 452:synth/tr909.h ****  *  RIDE 909 ŌĆö Metallic noise largo con shimmer
 453:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 454:synth/tr909.h **** class Ride : public HiHat909Base {
 455:synth/tr909.h **** public:
 456:synth/tr909.h ****     float decay  = 1.5f;
 457:synth/tr909.h ****     float tone   = 0.5f;
 458:synth/tr909.h ****     float volume = 1.0f;
 459:synth/tr909.h **** 
 460:synth/tr909.h ****     void Init(float sampleRate) {
 461:synth/tr909.h ****         sr_ = sampleRate;
 462:synth/tr909.h ****         dt_ = 1.0f / sr_;
 463:synth/tr909.h ****         active_ = false;
 464:synth/tr909.h ****         noiseState_ = 0x909A1DE;
 465:synth/tr909.h ****     }
 466:synth/tr909.h **** 
 467:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 468:synth/tr909.h ****         active_ = true;
 469:synth/tr909.h ****         time_ = 0.0f;
 470:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 471:synth/tr909.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 472:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 473:synth/tr909.h ****     }
 474:synth/tr909.h **** 
 475:synth/tr909.h ****     float Process() {
 476:synth/tr909.h ****         if (!active_) return 0.0f;
 477:synth/tr909.h **** 
 478:synth/tr909.h ****         float metal = MetallicNoise();
 479:synth/tr909.h ****         float hp = Highpass(metal);
 480:synth/tr909.h **** 
 481:synth/tr909.h ****         float attack = 1.0f - expf(-time_ / 0.001f);
 482:synth/tr909.h ****         float env = expf(-time_ / decay);
 483:synth/tr909.h **** 
 484:synth/tr909.h ****         float output = hp * env * attack * (0.3f + tone * 0.4f);
 485:synth/tr909.h ****         output = tanhf(output * 1.5f);
 486:synth/tr909.h **** 
 487:synth/tr909.h ****         time_ += dt_;
 488:synth/tr909.h ****         if (env < 0.0005f) active_ = false;
 489:synth/tr909.h **** 
 490:synth/tr909.h ****         return output * volume * vel_;
 491:synth/tr909.h ****     }
 492:synth/tr909.h **** 
 493:synth/tr909.h ****     bool IsActive() const { return active_; }
 494:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.5f, 4.0f); }
 495:synth/tr909.h **** };
 496:synth/tr909.h **** 
 497:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 498:synth/tr909.h ****  *  CRASH 909 ŌĆö Cymbal largo y brillante
 499:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 500:synth/tr909.h **** class Crash : public HiHat909Base {
 501:synth/tr909.h **** public:
 502:synth/tr909.h ****     float decay  = 2.5f;
 503:synth/tr909.h ****     float tone   = 0.7f;
 504:synth/tr909.h ****     float volume = 1.0f;
 505:synth/tr909.h **** 
 506:synth/tr909.h ****     void Init(float sampleRate) {
 507:synth/tr909.h ****         sr_ = sampleRate;
 508:synth/tr909.h ****         dt_ = 1.0f / sr_;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 246


 509:synth/tr909.h ****         active_ = false;
 510:synth/tr909.h ****         noiseState_ = 0x909CA5E;
 511:synth/tr909.h ****     }
 512:synth/tr909.h **** 
 513:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 514:synth/tr909.h ****         active_ = true;
 515:synth/tr909.h ****         time_ = 0.0f;
 516:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 517:synth/tr909.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 518:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 519:synth/tr909.h ****     }
 520:synth/tr909.h **** 
 521:synth/tr909.h ****     float Process() {
 522:synth/tr909.h ****         if (!active_) return 0.0f;
 523:synth/tr909.h **** 
 524:synth/tr909.h ****         float metal = MetallicNoise();
 525:synth/tr909.h ****         float hp = Highpass(metal);
 526:synth/tr909.h ****         float n = Noise(noiseState_) * 0.2f;  /* extra noise para brillo */
 527:synth/tr909.h **** 
 528:synth/tr909.h ****         float attack = 1.0f - expf(-time_ / 0.003f);
 529:synth/tr909.h ****         float env = expf(-time_ / decay);
 530:synth/tr909.h **** 
 531:synth/tr909.h ****         float output = (hp + n) * env * attack * (0.3f + tone * 0.5f);
 532:synth/tr909.h ****         output = tanhf(output * 2.0f);
 533:synth/tr909.h **** 
 534:synth/tr909.h ****         time_ += dt_;
 535:synth/tr909.h ****         if (env < 0.0005f) active_ = false;
 536:synth/tr909.h **** 
 537:synth/tr909.h ****         return output * volume * vel_;
 538:synth/tr909.h ****     }
 539:synth/tr909.h **** 
 540:synth/tr909.h ****     bool IsActive() const { return active_; }
 541:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.5f, 6.0f); }
 542:synth/tr909.h **** };
