   2:synth/tb303.h ****  *  TB303 ŌĆö Roland TB-303 Acid Bass Synthesizer Library
   3:synth/tb303.h ****  * ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
   4:synth/tb303.h ****  *  El coraz├│n del acid house: oscilador SAW/SQUARE ŌåÆ filtro ladder
   5:synth/tb303.h ****  *  resonante 24dB/oct ŌåÆ VCA con accent y slide (portamento).
   6:synth/tb303.h ****  *
   7:synth/tb303.h ****  *  La magia est├Ī en el filtro: 4 polos en cascada con
   8:synth/tb303.h ****  *  retroalimentaci├│n = resonancia que grita.
   9:synth/tb303.h ****  *
  10:synth/tb303.h ****  *  48 kHz ┬Ę float32 ┬Ę header-only
  11:synth/tb303.h ****  *
  12:synth/tb303.h ****  *  Uso t├Łpico:
  13:synth/tb303.h ****  *    TB303::Synth acid;
  14:synth/tb303.h ****  *    acid.Init(48000);
  15:synth/tb303.h ****  *    acid.NoteOn(midiToFreq(36), true, false);
  16:synth/tb303.h ****  *    float sample = acid.Process(); // en AudioCallback
  17:synth/tb303.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  18:synth/tb303.h **** #pragma once
  19:synth/tb303.h **** 
  20:synth/tb303.h **** #include <math.h>
  21:synth/tb303.h **** #include <stdint.h>
  22:synth/tb303.h **** 
  23:synth/tb303.h **** #ifndef TWOPI_F
  24:synth/tb303.h **** #define TWOPI_F 6.283185307f
  25:synth/tb303.h **** #endif
  26:synth/tb303.h **** 
  27:synth/tb303.h **** namespace TB303 {
  28:synth/tb303.h **** 
  29:synth/tb303.h **** static inline float Clamp(float v, float lo, float hi) {
  30:synth/tb303.h ****     return v < lo ? lo : (v > hi ? hi : v);
  31:synth/tb303.h **** }
  32:synth/tb303.h **** 
  33:synth/tb303.h **** /* Conversi├│n MIDI ŌåÆ Hz */
  34:synth/tb303.h **** static inline float MidiToFreq(uint8_t note) {
  35:synth/tb303.h ****     return 440.0f * powf(2.0f, ((float)note - 69.0f) / 12.0f);
  36:synth/tb303.h **** }
  37:synth/tb303.h **** 
  38:synth/tb303.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  39:synth/tb303.h ****  *  Waveform selection
  40:synth/tb303.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  41:synth/tb303.h **** enum Waveform {
  42:synth/tb303.h ****     WAVE_SAW = 0,
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 407


  43:synth/tb303.h ****     WAVE_SQUARE = 1
  44:synth/tb303.h **** };
  45:synth/tb303.h **** 
  46:synth/tb303.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  47:synth/tb303.h ****  *  SYNTH 303 ŌĆö Monofon├Ła completa
  48:synth/tb303.h ****  *
  49:synth/tb303.h ****  *  Signal flow:
  50:synth/tb303.h ****  *    OSC (saw/square) ŌåÆ LADDER FILTER (24dB/oct) ŌåÆ VCA
  51:synth/tb303.h ****  *          Ōåæ                    Ōåæ                    Ōåæ
  52:synth/tb303.h ****  *      slide/pitch          env + accent          env + accent
  53:synth/tb303.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  54:synth/tb303.h **** class Synth {
  55:synth/tb303.h **** public:
  56:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ PAR├üMETROS (los knobs de la 303) ŌöĆŌöĆŌöĆ */
  57:synth/tb303.h ****     float    cutoff     = 800.0f;   /* 20 Hz  - 20 kHz  freq del filtro    */
  58:synth/tb303.h ****     float    resonance  = 0.5f;     /* 0.0    - 0.95    (cerca de 1 = acid)*/
  59:synth/tb303.h ****     float    envMod     = 0.5f;     /* 0.0    - 1.0     cu├Īnto envŌåÆcutoff  */
  60:synth/tb303.h ****     float    decay      = 0.3f;     /* 0.05   - 2.0 s   decay del filtro   */
  61:synth/tb303.h ****     float    accentAmt  = 0.5f;     /* 0.0    - 1.0     intensidad accent  */
  62:synth/tb303.h ****     float    slideTime  = 0.06f;    /* 0.02   - 0.2 s   portamento         */
  63:synth/tb303.h ****     Waveform waveform   = WAVE_SAW; /* SAW / SQUARE                        */
  64:synth/tb303.h ****     float    volume     = 0.7f;     /* 0.0    - 1.0                        */
  65:synth/tb303.h **** 
  66:synth/tb303.h ****     void Init(float sampleRate) {
  67:synth/tb303.h ****         sr_ = sampleRate;
  68:synth/tb303.h ****         dt_ = 1.0f / sr_;
  69:synth/tb303.h ****         active_ = false;
  70:synth/tb303.h ****         phase_ = 0.0f;
  71:synth/tb303.h ****         currentFreq_ = 220.0f;
  72:synth/tb303.h ****         targetFreq_ = 220.0f;
  73:synth/tb303.h ****         /* Reset filtro ladder */
  74:synth/tb303.h ****         for (int i = 0; i < 4; i++) stage_[i] = 0.0f;
  75:synth/tb303.h ****         delay_[0] = delay_[1] = delay_[2] = delay_[3] = 0.0f;
  76:synth/tb303.h ****         filterEnv_ = 0.0f;
  77:synth/tb303.h ****         ampEnv_ = 0.0f;
  78:synth/tb303.h ****         gateOn_ = false;
  79:synth/tb303.h ****         accent_ = false;
  80:synth/tb303.h ****         sliding_ = false;
  81:synth/tb303.h ****     }
  82:synth/tb303.h **** 
  83:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ NoteOn: dispara una nota ŌöĆŌöĆŌöĆ */
  84:synth/tb303.h ****     void NoteOn(float freq, bool accent = false, bool slide = false) {
  85:synth/tb303.h ****         targetFreq_ = Clamp(freq, 20.0f, 5000.0f);
  86:synth/tb303.h ****         accent_ = accent;
  87:synth/tb303.h **** 
  88:synth/tb303.h ****         if (slide && active_) {
  89:synth/tb303.h ****             /* Slide: suaviza la transici├│n de nota */
  90:synth/tb303.h ****             sliding_ = true;
  91:synth/tb303.h ****         } else {
  92:synth/tb303.h ****             /* Nota nueva sin slide */
  93:synth/tb303.h ****             sliding_ = false;
  94:synth/tb303.h ****             currentFreq_ = targetFreq_;
  95:synth/tb303.h ****             /* Reset envelope del filtro */
  96:synth/tb303.h ****             filterEnv_ = 1.0f;
  97:synth/tb303.h ****         }
  98:synth/tb303.h **** 
  99:synth/tb303.h ****         gateOn_ = true;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 408


 100:synth/tb303.h ****         active_ = true;
 101:synth/tb303.h **** 
 102:synth/tb303.h ****         /* Accent aumenta la velocidad del envelope */
 103:synth/tb303.h ****         if (accent_) {
 104:synth/tb303.h ****             filterEnv_ = 1.2f; /* m├Īs excursi├│n */
 105:synth/tb303.h ****         }
 106:synth/tb303.h ****     }
 107:synth/tb303.h **** 
 108:synth/tb303.h ****     void NoteOn(uint8_t midiNote, bool accent = false, bool slide = false) {
 109:synth/tb303.h ****         NoteOn(MidiToFreq(midiNote), accent, slide);
 110:synth/tb303.h ****     }
 111:synth/tb303.h **** 
 112:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ NoteOff: libera la nota ŌöĆŌöĆŌöĆ */
 113:synth/tb303.h ****     void NoteOff() {
 114:synth/tb303.h ****         gateOn_ = false;
 115:synth/tb303.h ****     }
 116:synth/tb303.h **** 
