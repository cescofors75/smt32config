3599:main.cpp      ****      * D7=PG10(NSS) D8=PG11(SCK) D9=PB4(MISO) D10=PB5(MOSI)
3600:main.cpp      ****      * Mode0 (CPOL=0 CPHA=0), 8-bit, NSS hardware input               */
