 388:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 389:synth/tr505.h **** class Cowbell {
 390:synth/tr505.h **** public:
 391:synth/tr505.h ****     float decay  = 0.06f;
 392:synth/tr505.h ****     float lofi   = 0.2f;
 393:synth/tr505.h ****     float volume = 1.0f;
 394:synth/tr505.h **** 
 395:synth/tr505.h ****     void Init(float sampleRate) {
 396:synth/tr505.h ****         sr_ = sampleRate;
 397:synth/tr505.h ****         dt_ = 1.0f / sr_;
 398:synth/tr505.h ****         active_ = false;
 399:synth/tr505.h ****     }
 400:synth/tr505.h **** 
 401:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 402:synth/tr505.h ****         active_ = true;
 403:synth/tr505.h ****         time_ = 0.0f;
 404:synth/tr505.h ****         phase1_ = phase2_ = 0.0f;
 405:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 406:synth/tr505.h ****     }
 407:synth/tr505.h **** 
 408:synth/tr505.h ****     float Process() {
 409:synth/tr505.h ****         if (!active_) return 0.0f;
 410:synth/tr505.h **** 
 411:synth/tr505.h ****         phase1_ += 560.0f * dt_;
 412:synth/tr505.h ****         if (phase1_ >= 1.0f) phase1_ -= 1.0f;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 344


 413:synth/tr505.h ****         float sq1 = (phase1_ < 0.5f) ? 1.0f : -1.0f;
 414:synth/tr505.h **** 
 415:synth/tr505.h ****         phase2_ += 845.0f * dt_;
 416:synth/tr505.h ****         if (phase2_ >= 1.0f) phase2_ -= 1.0f;
 417:synth/tr505.h ****         float sq2 = (phase2_ < 0.5f) ? 1.0f : -1.0f;
 418:synth/tr505.h **** 
 419:synth/tr505.h ****         float mix = (sq1 + sq2) * 0.5f;
 420:synth/tr505.h ****         float env = expf(-time_ / decay);
 421:synth/tr505.h **** 
 422:synth/tr505.h ****         float output = tanhf(mix * 1.3f) * env;
 423:synth/tr505.h ****         output = LoFi(output, lofi);
 424:synth/tr505.h **** 
 425:synth/tr505.h ****         time_ += dt_;
 426:synth/tr505.h ****         if (env < 0.001f) active_ = false;
 427:synth/tr505.h **** 
 428:synth/tr505.h ****         return output * volume * vel_;
 429:synth/tr505.h ****     }
 430:synth/tr505.h **** 
 431:synth/tr505.h ****     bool IsActive() const { return active_; }
 432:synth/tr505.h **** 
 433:synth/tr505.h **** private:
 434:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 435:synth/tr505.h ****     bool  active_ = false;
 436:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 437:synth/tr505.h ****     float phase1_ = 0.0f, phase2_ = 0.0f;
 438:synth/tr505.h **** };
