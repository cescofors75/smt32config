 605:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 606:synth/tr808.h ****  *  MARACAS 808
 607:synth/tr808.h ****  *  Burst de ruido corto highpass-filtered
 608:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 609:synth/tr808.h **** class Maracas {
 610:synth/tr808.h **** public:
 611:synth/tr808.h ****     float decay  = 0.035f;
 612:synth/tr808.h ****     float tone   = 0.7f;
 613:synth/tr808.h ****     float volume = 1.0f;
 614:synth/tr808.h **** 
 615:synth/tr808.h ****     void Init(float sampleRate) {
 616:synth/tr808.h ****         sr_ = sampleRate;
 617:synth/tr808.h ****         dt_ = 1.0f / sr_;
 618:synth/tr808.h ****         active_ = false;
 619:synth/tr808.h ****         noiseState_ = 0xF00DFACE;
 620:synth/tr808.h ****     }
 621:synth/tr808.h **** 
 622:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 623:synth/tr808.h ****         active_ = true;
 624:synth/tr808.h ****         time_ = 0.0f;
 625:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 626:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 627:synth/tr808.h ****     }
 628:synth/tr808.h **** 
 629:synth/tr808.h ****     float Process() {
 630:synth/tr808.h ****         if (!active_) return 0.0f;
 631:synth/tr808.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 157


 632:synth/tr808.h ****         float n = Noise(noiseState_);
 633:synth/tr808.h **** 
 634:synth/tr808.h ****         /* Highpass ~7kHz */
 635:synth/tr808.h ****         float fc = 5000.0f + tone * 5000.0f;
 636:synth/tr808.h ****         float rc = 1.0f / (TWOPI_F * fc);
 637:synth/tr808.h ****         float alpha = rc / (rc + dt_);
 638:synth/tr808.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 639:synth/tr808.h ****         hpZ1_ = n;
 640:synth/tr808.h **** 
 641:synth/tr808.h ****         float env = expf(-time_ / decay);
 642:synth/tr808.h ****         float output = hpOut_ * env;
 643:synth/tr808.h **** 
 644:synth/tr808.h ****         time_ += dt_;
 645:synth/tr808.h ****         if (env < 0.001f) active_ = false;
 646:synth/tr808.h **** 
 647:synth/tr808.h ****         return output * volume * vel_;
 648:synth/tr808.h ****     }
 649:synth/tr808.h **** 
 650:synth/tr808.h ****     bool IsActive() const { return active_; }
 651:synth/tr808.h **** 
 652:synth/tr808.h **** private:
 653:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 654:synth/tr808.h ****     bool  active_ = false;
 655:synth/tr808.h ****     float time_ = 0.0f;
 656:synth/tr808.h ****     float vel_ = 1.0f;
 657:synth/tr808.h ****     uint32_t noiseState_ = 0xF00DFACE;
 658:synth/tr808.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 659:synth/tr808.h **** };
