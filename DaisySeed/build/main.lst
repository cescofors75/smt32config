 430:main.cpp      ****     uint8_t  patternLength;    /* 16, 32, or 64         */
 431:main.cpp      ****     int16_t  currentStep;      /* -1 = not started      */
 432:main.cpp      ****     float    tempo;            /* BPM                   */
 433:main.cpp      ****     uint8_t  swingAmount;      /* 0-100                 */
 434:main.cpp      ****     bool     trackMuted[DSQ_TRACKS];
 435:main.cpp      ****     /* BPM clock (sample counter, updated inside AudioCallback) */
 436:main.cpp      ****     uint32_t samplesElapsed;
 437:main.cpp      ****     uint32_t samplesPerStep;
 438:main.cpp      **** };
 439:main.cpp      **** static DaisySeqState dseq;
 440:main.cpp      **** 
 441:main.cpp      **** /* Track ŌåÆ synth engine mapping  (-1 = sampler, 0=808, 1=909, 2=505, 3=303)
 442:main.cpp      ****  * Updated via CMD_DSQ_SET_TRACK_ENGINE.  Default: all tracks use sampler. */
 443:main.cpp      **** static int8_t dsqTrackEngine[DSQ_TRACKS];
 444:main.cpp      **** 
 445:main.cpp      **** static void DsqUpdateSamplesPerStep() {
 446:main.cpp      ****     float t = (dseq.tempo > 1.0f) ? dseq.tempo : 120.0f;
 447:main.cpp      ****     /* 16th note = 60/(bpm├Ś4) seconds */
 448:main.cpp      ****     float stepSec = 60.0f / (t * 4.0f);
 449:main.cpp      ****     dseq.samplesPerStep = (uint32_t)(stepSec * (float)SAMPLE_RATE);
 450:main.cpp      ****     if(dseq.samplesPerStep < 64) dseq.samplesPerStep = 64;
 451:main.cpp      **** }
 452:main.cpp      **** 
 453:main.cpp      **** static void DsqInit() {
 454:main.cpp      ****     /* dsqSteps est├Ī en SDRAM (DSY_SDRAM_BSS) que NO se zero-inicializa
 455:main.cpp      ****      * al boot en STM32H7. Sin este memset, volEn/reverbEn/cutoffEn pueden
 456:main.cpp      ****      * tener basura (=true) con volume/cutoffHz/reverbSend=0, haciendo que
 457:main.cpp      ****      * DsqFireStep ponga trackGain[t]=0 al disparar el primer step y
 458:main.cpp      ****      * silenciando todos los live pads permanentemente. */
 459:main.cpp      ****     memset(dsqSteps, 0, sizeof(dsqSteps));
 460:main.cpp      ****     memset(&dseq, 0, sizeof(dseq));
 461:main.cpp      ****     /* -1 (0xFF) = todos los tracks en modo sampler por defecto */
 462:main.cpp      ****     memset(dsqTrackEngine, (uint8_t)0xFF, sizeof(dsqTrackEngine));
 463:main.cpp      ****     dseq.tempo        = 120.0f;
 464:main.cpp      ****     dseq.patternLength = 16;
 465:main.cpp      ****     dseq.currentStep  = -1;
 466:main.cpp      ****     DsqUpdateSamplesPerStep();
 467:main.cpp      **** }
 468:main.cpp      **** 
