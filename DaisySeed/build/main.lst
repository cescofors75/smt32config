  96:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  97:synth/tr505.h ****  *  SNARE 505
  98:synth/tr505.h ****  *  M├Īs digital, tono m├Īs agudo, noise m├Īs suave
  99:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 100:synth/tr505.h **** class Snare {
 101:synth/tr505.h **** public:
 102:synth/tr505.h ****     float decay   = 0.15f;
 103:synth/tr505.h ****     float tone    = 0.4f;
 104:synth/tr505.h ****     float snappy  = 0.6f;
 105:synth/tr505.h ****     float pitch   = 220.0f;
 106:synth/tr505.h ****     float lofi    = 0.15f;
 107:synth/tr505.h ****     float volume  = 1.0f;
 108:synth/tr505.h **** 
 109:synth/tr505.h ****     void Init(float sampleRate) {
 110:synth/tr505.h ****         sr_ = sampleRate;
 111:synth/tr505.h ****         dt_ = 1.0f / sr_;
 112:synth/tr505.h ****         active_ = false;
 113:synth/tr505.h ****         noiseState_ = 0x505BEEF;
 114:synth/tr505.h ****     }
 115:synth/tr505.h **** 
 116:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 117:synth/tr505.h ****         active_ = true;
 118:synth/tr505.h ****         time_ = 0.0f;
 119:synth/tr505.h ****         phase_ = 0.0f;
 120:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 121:synth/tr505.h ****     }
 122:synth/tr505.h **** 
 123:synth/tr505.h ****     float Process() {
 124:synth/tr505.h ****         if (!active_) return 0.0f;
 125:synth/tr505.h **** 
 126:synth/tr505.h ****         phase_ += pitch * dt_;
 127:synth/tr505.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 128:synth/tr505.h ****         float t = sinf(TWOPI_F * phase_);
 129:synth/tr505.h ****         float toneEnv = expf(-time_ / (decay * 0.5f));
 130:synth/tr505.h ****         float toneOut = t * toneEnv * tone;
 131:synth/tr505.h **** 
 132:synth/tr505.h ****         float n = Noise(noiseState_);
 133:synth/tr505.h ****         float noiseEnv = expf(-time_ / decay);
 134:synth/tr505.h ****         float noiseOut = n * noiseEnv * snappy;
 135:synth/tr505.h **** 
 136:synth/tr505.h ****         float output = toneOut + noiseOut;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 334


 137:synth/tr505.h ****         output = tanhf(output * 1.5f);
 138:synth/tr505.h ****         output = LoFi(output, lofi);
 139:synth/tr505.h **** 
 140:synth/tr505.h ****         time_ += dt_;
 141:synth/tr505.h ****         if (noiseEnv < 0.001f) active_ = false;
 142:synth/tr505.h **** 
 143:synth/tr505.h ****         return output * volume * vel_;
 144:synth/tr505.h ****     }
 145:synth/tr505.h **** 
 146:synth/tr505.h ****     bool IsActive() const { return active_; }
 147:synth/tr505.h **** 
 148:synth/tr505.h **** private:
 149:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 150:synth/tr505.h ****     bool  active_ = false;
 151:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 152:synth/tr505.h ****     uint32_t noiseState_ = 0x505BEEF;
 153:synth/tr505.h **** };
 154:synth/tr505.h **** 
 155:synth/tr505.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 156:synth/tr505.h ****  *  CLAP 505
 157:synth/tr505.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 158:synth/tr505.h **** class Clap {
 159:synth/tr505.h **** public:
 160:synth/tr505.h ****     float decay  = 0.2f;
 161:synth/tr505.h ****     float lofi   = 0.15f;
 162:synth/tr505.h ****     float volume = 1.0f;
 163:synth/tr505.h **** 
 164:synth/tr505.h ****     void Init(float sampleRate) {
 165:synth/tr505.h ****         sr_ = sampleRate;
 166:synth/tr505.h ****         dt_ = 1.0f / sr_;
 167:synth/tr505.h ****         active_ = false;
 168:synth/tr505.h ****         noiseState_ = 0x505C1A9;
 169:synth/tr505.h ****     }
 170:synth/tr505.h **** 
 171:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 172:synth/tr505.h ****         active_ = true;
 173:synth/tr505.h ****         time_ = 0.0f;
 174:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 175:synth/tr505.h ****     }
 176:synth/tr505.h **** 
 177:synth/tr505.h ****     float Process() {
 178:synth/tr505.h ****         if (!active_) return 0.0f;
 179:synth/tr505.h **** 
 180:synth/tr505.h ****         float n = Noise(noiseState_);
 181:synth/tr505.h **** 
 182:synth/tr505.h ****         /* 3 r├Īfagas (simpler que 808/909) */
 183:synth/tr505.h ****         float burstT = 0.008f;
 184:synth/tr505.h ****         float env = 0.0f;
 185:synth/tr505.h ****         for (int i = 0; i < 3; i++) {
 186:synth/tr505.h ****             float t = time_ - i * burstT;
 187:synth/tr505.h ****             if (t >= 0.0f && t < burstT)
 188:synth/tr505.h ****                 env += expf(-t / 0.002f) * 0.5f;
 189:synth/tr505.h ****         }
 190:synth/tr505.h ****         float tailStart = 3.0f * burstT;
 191:synth/tr505.h ****         if (time_ >= tailStart)
 192:synth/tr505.h ****             env += expf(-(time_ - tailStart) / decay);
 193:synth/tr505.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 335


 194:synth/tr505.h ****         float output = n * env;
 195:synth/tr505.h ****         output = tanhf(output * 1.8f);
 196:synth/tr505.h ****         output = LoFi(output, lofi);
 197:synth/tr505.h **** 
 198:synth/tr505.h ****         time_ += dt_;
 199:synth/tr505.h ****         if (time_ > decay + 0.05f && env < 0.001f) active_ = false;
 200:synth/tr505.h **** 
 201:synth/tr505.h ****         return output * volume * vel_;
 202:synth/tr505.h ****     }
 203:synth/tr505.h **** 
 204:synth/tr505.h ****     bool IsActive() const { return active_; }
 205:synth/tr505.h **** 
 206:synth/tr505.h **** private:
 207:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 208:synth/tr505.h ****     bool  active_ = false;
 209:synth/tr505.h ****     float time_ = 0.0f, vel_ = 1.0f;
 210:synth/tr505.h ****     uint32_t noiseState_ = 0x505C1A9;
 211:synth/tr505.h **** };
