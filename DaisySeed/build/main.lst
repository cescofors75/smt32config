3723:main.cpp      **** /* ŌöĆŌöĆ Helper: case-insensitive substring match ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
3724:main.cpp      **** static bool containsCI(const char* haystack, const char* needle)
3725:main.cpp      **** {
3726:main.cpp      ****     for(const char* h = haystack; *h; h++){
3727:main.cpp      ****         const char* hp = h;
3728:main.cpp      ****         const char* np = needle;
3729:main.cpp      ****         while(*np && *hp && (toupper((uint8_t)*hp) == toupper((uint8_t)*np))){
3730:main.cpp      ****             hp++; np++;
3731:main.cpp      ****         }
3732:main.cpp      ****         if(!*np) return true;
3733:main.cpp      ****     }
3734:main.cpp      ****     return false;
3735:main.cpp      **** }
