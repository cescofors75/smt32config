3940:main.cpp      **** /* ŌöĆŌöĆ Helper: guess pad index from a filename using keyword table ŌöĆŌöĆ */
3941:main.cpp      **** static int GuessPadFromFilename(const char* fname)
3942:main.cpp      **** {
3943:main.cpp      ****     /* Try each keyword ŌĆö longer keywords checked implicitly because
3944:main.cpp      ****        the table is ordered from most-specific to least-specific */
3945:main.cpp      ****     for(int k = 0; k < NUM_INSTR_KEYWORDS; k++){
3946:main.cpp      ****         if(containsCI(fname, INSTR_KEYWORDS[k].keyword))
3947:main.cpp      ****             return INSTR_KEYWORDS[k].pad;
3948:main.cpp      ****     }
3949:main.cpp      ****     return -1;
3950:main.cpp      **** }
