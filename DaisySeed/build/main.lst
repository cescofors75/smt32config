 386:main.cpp      ****  *  10. BiquadEQ  (Audio EQ Cookbook ŌĆō LP/HP/BP/Notch/Peak/Shelf)
 387:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 388:main.cpp      **** struct BiquadEQ {
 389:main.cpp      ****     float b0=1,b1=0,b2=0,a1=0,a2=0;
 390:main.cpp      ****     float z1=0,z2=0;
 391:main.cpp      **** 
 392:main.cpp      ****     float Process(float in){
 393:main.cpp      ****         float out = b0*in + z1;
 394:main.cpp      ****         z1 = b1*in - a1*out + z2;
 395:main.cpp      ****         z2 = b2*in - a2*out;
 396:main.cpp      ****         return out;
 397:main.cpp      ****     }
 398:main.cpp      ****     void Reset(){ z1=z2=0; }
 399:main.cpp      **** 
 400:main.cpp      ****     void SetType(uint8_t t, float freq, float q, float sr, float gainDb=0.f){
 401:main.cpp      ****         if(freq<20.f) freq=20.f;
 402:main.cpp      ****         if(freq>sr*0.45f) freq=sr*0.45f;
 403:main.cpp      ****         if(q<0.3f) q=0.3f;
 404:main.cpp      ****         float w = 2.f*(float)M_PI*freq/sr;
 405:main.cpp      ****         float s_ = sinf(w), c_ = cosf(w);
 406:main.cpp      ****         float a  = s_/(2.f*q);
 407:main.cpp      ****         float a0i;
 408:main.cpp      ****         switch(t){
 409:main.cpp      ****             case FTYPE_LOWPASS:
 410:main.cpp      ****                 a0i = 1.f/(1.f+a);
 411:main.cpp      ****                 b0 = ((1.f-c_)*0.5f)*a0i;
 412:main.cpp      ****                 b1 = (1.f-c_)*a0i;
 413:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 414:main.cpp      ****                 break;
 415:main.cpp      ****             case FTYPE_HIGHPASS:
 416:main.cpp      ****                 a0i = 1.f/(1.f+a);
 417:main.cpp      ****                 b0 = ((1.f+c_)*0.5f)*a0i;
 418:main.cpp      ****                 b1 = -(1.f+c_)*a0i;
 419:main.cpp      ****                 b2 = b0; a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 420:main.cpp      ****                 break;
 421:main.cpp      ****             case FTYPE_BANDPASS:
 422:main.cpp      ****                 a0i = 1.f/(1.f+a);
 423:main.cpp      ****                 b0 = a*a0i; b1=0; b2=-b0;
 424:main.cpp      ****                 a1=(-2.f*c_)*a0i; a2=(1.f-a)*a0i;
 425:main.cpp      ****                 break;
 426:main.cpp      ****             case FTYPE_NOTCH:
 427:main.cpp      ****                 a0i = 1.f/(1.f+a);
 428:main.cpp      ****                 b0 = a0i; b1=(-2.f*c_)*a0i; b2=a0i;
 429:main.cpp      ****                 a1=b1; a2=(1.f-a)*a0i;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccnWEBq0.s 			page 27


 430:main.cpp      ****                 break;
 431:main.cpp      ****             case FTYPE_PEAKING: {
 432:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 433:main.cpp      ****                 a0i = 1.f/(1.f + a/A);
 434:main.cpp      ****                 b0 = (1.f + a*A)*a0i;
 435:main.cpp      ****                 b1 = (-2.f*c_)*a0i;
 436:main.cpp      ****                 b2 = (1.f - a*A)*a0i;
 437:main.cpp      ****                 a1 = b1; a2 = (1.f - a/A)*a0i;
 438:main.cpp      ****                 break;
 439:main.cpp      ****             }
 440:main.cpp      ****             case FTYPE_LOWSHELF: {
 441:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 442:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 443:main.cpp      ****                 a0i = 1.f/((A+1.f)+(A-1.f)*c_+sq);
 444:main.cpp      ****                 b0 = A*((A+1.f)-(A-1.f)*c_+sq)*a0i;
 445:main.cpp      ****                 b1 = 2.f*A*((A-1.f)-(A+1.f)*c_)*a0i;
 446:main.cpp      ****                 b2 = A*((A+1.f)-(A-1.f)*c_-sq)*a0i;
 447:main.cpp      ****                 a1 = -2.f*((A-1.f)+(A+1.f)*c_)*a0i;
 448:main.cpp      ****                 a2 = ((A+1.f)+(A-1.f)*c_-sq)*a0i;
 449:main.cpp      ****                 break;
 450:main.cpp      ****             }
 451:main.cpp      ****             case FTYPE_HIGHSHELF: {
 452:main.cpp      ****                 float A = powf(10.f, gainDb/40.f);
 453:main.cpp      ****                 float sq = 2.f*sqrtf(A)*a;
 454:main.cpp      ****                 a0i = 1.f/((A+1.f)-(A-1.f)*c_+sq);
 455:main.cpp      ****                 b0 = A*((A+1.f)+(A-1.f)*c_+sq)*a0i;
 456:main.cpp      ****                 b1 = -2.f*A*((A-1.f)+(A+1.f)*c_)*a0i;
 457:main.cpp      ****                 b2 = A*((A+1.f)+(A-1.f)*c_-sq)*a0i;
 458:main.cpp      ****                 a1 = 2.f*((A-1.f)-(A+1.f)*c_)*a0i;
 459:main.cpp      ****                 a2 = ((A+1.f)-(A-1.f)*c_+sq)*a0i;
 460:main.cpp      ****                 break;
 461:main.cpp      ****             }
 462:main.cpp      ****             default: b0=1;b1=b2=a1=a2=0; break;
 463:main.cpp      ****         }
 464:main.cpp      ****     }
 465:main.cpp      **** };
