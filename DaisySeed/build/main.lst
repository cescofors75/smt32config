3828:main.cpp      **** /* ŌĢÉŌĢÉŌĢÉ SPI1 RX ring buffer (TIM6 ISR escribe, main loop lee) ŌĢÉŌĢÉŌĢÉ
3829:main.cpp      ****  * 2048 bytes = ~128 paquetes TRIG_SEQ (16B c/u).
3830:main.cpp      ****  * TIM6 ISR drena RXFIFO cada ~100┬Ąs, previniendo OVR incluso
3831:main.cpp      ****  * durante el audio callback (~2.7ms con AUDIO_BLOCK=128).         */
3832:main.cpp      **** #define SPI_RING_BITS  11
3833:main.cpp      **** #define SPI_RING_SIZE  (1 << SPI_RING_BITS)   /* 2048 */
3834:main.cpp      **** #define SPI_RING_MASK  (SPI_RING_SIZE - 1)
3835:main.cpp      **** static volatile uint8_t  spiRing[SPI_RING_SIZE];
3836:main.cpp      **** static volatile uint16_t spiRingHead = 0;   /* escrito por ISR o AudioCB */
3837:main.cpp      **** static volatile uint16_t spiRingTail = 0;   /* escrito SOLO por main     */
3838:main.cpp      **** static volatile bool     spiDrainBusy = false; /* anti-reentrada */
