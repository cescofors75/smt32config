 193:synth/tb303.h ****     bool IsActive() const { return active_; }
 194:synth/tb303.h ****     bool IsGateOn() const { return gateOn_; }
 195:synth/tb303.h **** 
 196:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ Setters para control en vivo ŌöĆŌöĆŌöĆ */
 197:synth/tb303.h ****     void SetCutoff(float c)     { cutoff = Clamp(c, 20.0f, 20000.0f); }
 198:synth/tb303.h ****     void SetResonance(float r)  { resonance = Clamp(r, 0.0f, 0.95f); }
 199:synth/tb303.h ****     void SetEnvMod(float e)     { envMod = Clamp(e, 0.0f, 1.0f); }
 200:synth/tb303.h ****     void SetDecay(float d)      { decay = Clamp(d, 0.02f, 3.0f); }
 201:synth/tb303.h ****     void SetAccent(float a)     { accentAmt = Clamp(a, 0.0f, 1.0f); }
 202:synth/tb303.h ****     void SetSlide(float s)      { slideTime = Clamp(s, 0.01f, 0.5f); }
 203:synth/tb303.h ****     void SetWaveform(Waveform w){ waveform = w; }
