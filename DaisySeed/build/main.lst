 368:synth/tr505.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 369:synth/tr505.h ****     bool  active_ = false;
 370:synth/tr505.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 371:synth/tr505.h **** };
