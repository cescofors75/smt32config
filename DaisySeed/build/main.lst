 365:synth/tr909.h **** 
 366:synth/tr909.h ****         float metal = MetallicNoise();
 367:synth/tr909.h ****         float hp = Highpass(metal);
 368:synth/tr909.h ****         float env = expf(-time_ / decay);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 285


 369:synth/tr909.h **** 
 370:synth/tr909.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 371:synth/tr909.h ****         output = tanhf(output * 2.5f);
 372:synth/tr909.h **** 
 373:synth/tr909.h ****         time_ += dt_;
 374:synth/tr909.h ****         if (env < 0.001f) active_ = false;
 375:synth/tr909.h **** 
 376:synth/tr909.h ****         return output * volume * vel_;
 377:synth/tr909.h ****     }
 378:synth/tr909.h **** 
 379:synth/tr909.h ****     bool IsActive() const { return active_; }
 380:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 2.0f); }
 381:synth/tr909.h **** };
