3651:main.cpp      **** /* ŌöĆŌöĆ Helper: case-insensitive substring match ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
3652:main.cpp      **** static bool containsCI(const char* haystack, const char* needle)
3653:main.cpp      **** {
3654:main.cpp      ****     for(const char* h = haystack; *h; h++){
3655:main.cpp      ****         const char* hp = h;
3656:main.cpp      ****         const char* np = needle;
3657:main.cpp      ****         while(*np && *hp && (toupper((uint8_t)*hp) == toupper((uint8_t)*np))){
3658:main.cpp      ****             hp++; np++;
3659:main.cpp      ****         }
3660:main.cpp      ****         if(!*np) return true;
3661:main.cpp      ****     }
3662:main.cpp      ****     return false;
3663:main.cpp      **** }
3664:main.cpp      **** 
3665:main.cpp      **** /* ŌöĆŌöĆ Helper: guess pad index from a filename using keyword table ŌöĆŌöĆ */
3666:main.cpp      **** static int GuessPadFromFilename(const char* fname)
3667:main.cpp      **** {
3668:main.cpp      ****     /* Try each keyword ŌĆö longer keywords checked implicitly because
3669:main.cpp      ****        the table is ordered from most-specific to least-specific */
3670:main.cpp      ****     for(int k = 0; k < NUM_INSTR_KEYWORDS; k++){
3671:main.cpp      ****         if(containsCI(fname, INSTR_KEYWORDS[k].keyword))
3672:main.cpp      ****             return INSTR_KEYWORDS[k].pad;
3673:main.cpp      ****     }
3674:main.cpp      ****     return -1;
3675:main.cpp      **** }
