 285:synth/tr808.h **** 
 286:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 287:synth/tr808.h ****  *  HIHAT BASE (compartido entre Closed y Open)
 288:synth/tr808.h ****  *  6 ondas cuadradas met├Īlicas con frecuencias no arm├│nicas
 289:synth/tr808.h ****  *  Estas frecuencias son las del circuito original Roland
 290:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 291:synth/tr808.h **** class HiHatBase {
 292:synth/tr808.h **** protected:
 293:synth/tr808.h ****     /* Frecuencias met├Īlicas originales del 808 */
 294:synth/tr808.h ****     static constexpr float METAL_FREQS[6] = {
 295:synth/tr808.h ****         204.0f, 298.5f, 366.5f, 522.0f, 540.0f, 800.0f
 296:synth/tr808.h ****     };
 297:synth/tr808.h **** 
 298:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 299:synth/tr808.h ****     bool  active_ = false;
 300:synth/tr808.h ****     float time_ = 0.0f;
 301:synth/tr808.h ****     float vel_ = 1.0f;
 302:synth/tr808.h ****     float phase_[6] = {};
 303:synth/tr808.h ****     uint32_t noiseState_ = 0xBAADF00D;
 304:synth/tr808.h ****     /* Filtro highpass state */
 305:synth/tr808.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 306:synth/tr808.h **** 
 307:synth/tr808.h ****     float MetallicNoise() {
 308:synth/tr808.h ****         float sum = 0.0f;
 309:synth/tr808.h ****         for (int i = 0; i < 6; i++) {
 310:synth/tr808.h ****             phase_[i] += METAL_FREQS[i] * dt_;
 311:synth/tr808.h ****             if (phase_[i] >= 1.0f) phase_[i] -= 1.0f;
 312:synth/tr808.h ****             /* Square wave */
 313:synth/tr808.h ****             sum += (phase_[i] < 0.5f) ? 1.0f : -1.0f;
 314:synth/tr808.h ****         }
 315:synth/tr808.h ****         /* Mezclar con un poco de ruido real */
 316:synth/tr808.h ****         float n = Noise(noiseState_) * 0.15f;
 317:synth/tr808.h ****         return (sum / 6.0f + n);
 318:synth/tr808.h ****     }
 319:synth/tr808.h **** 
 320:synth/tr808.h ****     /* Highpass simple ~6kHz para brillo met├Īlico */
 321:synth/tr808.h ****     float Highpass(float in) {
 322:synth/tr808.h ****         float rc = 1.0f / (TWOPI_F * 6000.0f);
 323:synth/tr808.h ****         float alpha = rc / (rc + dt_);
 324:synth/tr808.h ****         hpOut_ = alpha * (hpOut_ + in - hpZ1_);
 325:synth/tr808.h ****         hpZ1_ = in;
 326:synth/tr808.h ****         return hpOut_;
 327:synth/tr808.h ****     }
 328:synth/tr808.h **** };
 329:synth/tr808.h **** 
 330:synth/tr808.h **** constexpr float HiHatBase::METAL_FREQS[6];
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 145


 331:synth/tr808.h **** 
 332:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 333:synth/tr808.h ****  *  HIHAT CLOSED
 334:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 335:synth/tr808.h **** class HiHatClosed : public HiHatBase {
 336:synth/tr808.h **** public:
 337:synth/tr808.h ****     float decay  = 0.04f;   /* 0.02 - 0.15 s  (corto) */
 338:synth/tr808.h ****     float tone   = 0.5f;    /* 0.0 - 1.0 */
 339:synth/tr808.h ****     float volume = 1.0f;
 340:synth/tr808.h **** 
 341:synth/tr808.h ****     void Init(float sampleRate) {
 342:synth/tr808.h ****         sr_ = sampleRate;
 343:synth/tr808.h ****         dt_ = 1.0f / sr_;
 344:synth/tr808.h ****         active_ = false;
 345:synth/tr808.h ****     }
 346:synth/tr808.h **** 
 347:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 348:synth/tr808.h ****         active_ = true;
 349:synth/tr808.h ****         time_ = 0.0f;
 350:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 351:synth/tr808.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 352:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 353:synth/tr808.h ****     }
 354:synth/tr808.h **** 
 355:synth/tr808.h ****     float Process() {
 356:synth/tr808.h ****         if (!active_) return 0.0f;
 357:synth/tr808.h **** 
 358:synth/tr808.h ****         float metal = MetallicNoise();
 359:synth/tr808.h ****         float hp = Highpass(metal);
 360:synth/tr808.h ****         float env = expf(-time_ / decay);
 361:synth/tr808.h **** 
 362:synth/tr808.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 363:synth/tr808.h ****         output = tanhf(output * 2.0f);
 364:synth/tr808.h **** 
 365:synth/tr808.h ****         time_ += dt_;
 366:synth/tr808.h ****         if (env < 0.001f) active_ = false;
 367:synth/tr808.h **** 
 368:synth/tr808.h ****         return output * volume * vel_;
 369:synth/tr808.h ****     }
 370:synth/tr808.h **** 
 371:synth/tr808.h ****     bool IsActive() const { return active_; }
 372:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.01f, 0.3f); }
 373:synth/tr808.h **** };
 374:synth/tr808.h **** 
 375:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 376:synth/tr808.h ****  *  HIHAT OPEN
 377:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 378:synth/tr808.h **** class HiHatOpen : public HiHatBase {
 379:synth/tr808.h **** public:
 380:synth/tr808.h ****     float decay  = 0.25f;   /* 0.1 - 0.8 s (largo) */
 381:synth/tr808.h ****     float tone   = 0.5f;
 382:synth/tr808.h ****     float volume = 1.0f;
 383:synth/tr808.h **** 
 384:synth/tr808.h ****     void Init(float sampleRate) {
 385:synth/tr808.h ****         sr_ = sampleRate;
 386:synth/tr808.h ****         dt_ = 1.0f / sr_;
 387:synth/tr808.h ****         active_ = false;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 146


 388:synth/tr808.h ****     }
 389:synth/tr808.h **** 
 390:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 391:synth/tr808.h ****         active_ = true;
 392:synth/tr808.h ****         time_ = 0.0f;
 393:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 394:synth/tr808.h ****         for (int i = 0; i < 6; i++) phase_[i] = 0.0f;
 395:synth/tr808.h ****         hpZ1_ = hpOut_ = 0.0f;
 396:synth/tr808.h ****     }
 397:synth/tr808.h **** 
 398:synth/tr808.h ****     /* Choke: cerrar el hihat abierto */
 399:synth/tr808.h ****     void Choke() { active_ = false; }
 400:synth/tr808.h **** 
 401:synth/tr808.h ****     float Process() {
 402:synth/tr808.h ****         if (!active_) return 0.0f;
 403:synth/tr808.h **** 
 404:synth/tr808.h ****         float metal = MetallicNoise();
 405:synth/tr808.h ****         float hp = Highpass(metal);
 406:synth/tr808.h ****         float env = expf(-time_ / decay);
 407:synth/tr808.h **** 
 408:synth/tr808.h ****         float output = hp * env * (0.5f + tone * 0.5f);
 409:synth/tr808.h ****         output = tanhf(output * 2.0f);
 410:synth/tr808.h **** 
 411:synth/tr808.h ****         time_ += dt_;
 412:synth/tr808.h ****         if (env < 0.001f) active_ = false;
 413:synth/tr808.h **** 
 414:synth/tr808.h ****         return output * volume * vel_;
 415:synth/tr808.h ****     }
 416:synth/tr808.h **** 
 417:synth/tr808.h ****     bool IsActive() const { return active_; }
 418:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 2.0f); }
 419:synth/tr808.h **** };
 420:synth/tr808.h **** 
 421:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 422:synth/tr808.h ****  *  TOM BASE (compartido entre Low, Mid, Hi Tom)
 423:synth/tr808.h ****  *  Sine con pitch envelope ŌĆö como el kick pero m├Īs corto
 424:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 425:synth/tr808.h **** class TomBase {
 426:synth/tr808.h **** public:
 427:synth/tr808.h ****     float decay      = 0.25f;
 428:synth/tr808.h ****     float pitch      = 100.0f;
 429:synth/tr808.h ****     float pitchDecay = 0.05f;
 430:synth/tr808.h ****     float volume     = 1.0f;
 431:synth/tr808.h **** 
 432:synth/tr808.h ****     void Init(float sampleRate) {
 433:synth/tr808.h ****         sr_ = sampleRate;
 434:synth/tr808.h ****         dt_ = 1.0f / sr_;
 435:synth/tr808.h ****         active_ = false;
 436:synth/tr808.h ****     }
 437:synth/tr808.h **** 
 438:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 439:synth/tr808.h ****         active_ = true;
 440:synth/tr808.h ****         time_ = 0.0f;
 441:synth/tr808.h ****         phase_ = 0.0f;
 442:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 443:synth/tr808.h ****     }
 444:synth/tr808.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 147


 445:synth/tr808.h ****     float Process() {
 446:synth/tr808.h ****         if (!active_) return 0.0f;
 447:synth/tr808.h **** 
 448:synth/tr808.h ****         float cp = pitch + pitch * 2.0f * expf(-time_ / pitchDecay);
 449:synth/tr808.h ****         phase_ += cp * dt_;
 450:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 451:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
 452:synth/tr808.h **** 
 453:synth/tr808.h ****         float amp = expf(-time_ / decay);
 454:synth/tr808.h ****         float output = tanhf(sine * 1.2f) * amp;
 455:synth/tr808.h **** 
 456:synth/tr808.h ****         time_ += dt_;
 457:synth/tr808.h ****         if (amp < 0.001f) active_ = false;
 458:synth/tr808.h **** 
 459:synth/tr808.h ****         return output * volume * vel_;
 460:synth/tr808.h ****     }
 461:synth/tr808.h **** 
 462:synth/tr808.h ****     bool IsActive() const { return active_; }
 463:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 1.0f); }
 464:synth/tr808.h ****     void SetPitch(float p) { pitch = Clamp(p, 40.0f, 500.0f); }
 465:synth/tr808.h **** 
 466:synth/tr808.h **** protected:
 467:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 468:synth/tr808.h ****     bool  active_ = false;
 469:synth/tr808.h ****     float time_ = 0.0f;
 470:synth/tr808.h ****     float phase_ = 0.0f;
 471:synth/tr808.h ****     float vel_ = 1.0f;
 472:synth/tr808.h **** };
 473:synth/tr808.h **** 
 474:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 475:synth/tr808.h **** class LowTom : public TomBase {
 476:synth/tr808.h **** public:
 477:synth/tr808.h ****     LowTom() { pitch = 80.0f; decay = 0.3f; pitchDecay = 0.06f; }
 478:synth/tr808.h **** };
 479:synth/tr808.h **** 
 480:synth/tr808.h **** class MidTom : public TomBase {
 481:synth/tr808.h **** public:
 482:synth/tr808.h ****     MidTom() { pitch = 120.0f; decay = 0.25f; pitchDecay = 0.05f; }
 483:synth/tr808.h **** };
 484:synth/tr808.h **** 
 485:synth/tr808.h **** class HiTom : public TomBase {
 486:synth/tr808.h **** public:
 487:synth/tr808.h ****     HiTom() { pitch = 180.0f; decay = 0.2f; pitchDecay = 0.04f; }
 488:synth/tr808.h **** };
 489:synth/tr808.h **** 
 490:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 491:synth/tr808.h ****  *  CONGA BASE (sine corto, m├Īs "seco" que los toms)
 492:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 493:synth/tr808.h **** class CongaBase {
 494:synth/tr808.h **** public:
 495:synth/tr808.h ****     float decay  = 0.15f;
 496:synth/tr808.h ****     float pitch  = 200.0f;
 497:synth/tr808.h ****     float volume = 1.0f;
 498:synth/tr808.h **** 
 499:synth/tr808.h ****     void Init(float sampleRate) {
 500:synth/tr808.h ****         sr_ = sampleRate;
 501:synth/tr808.h ****         dt_ = 1.0f / sr_;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 148


 502:synth/tr808.h ****         active_ = false;
 503:synth/tr808.h ****     }
 504:synth/tr808.h **** 
 505:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 506:synth/tr808.h ****         active_ = true;
 507:synth/tr808.h ****         time_ = 0.0f;
 508:synth/tr808.h ****         phase_ = 0.0f;
 509:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 510:synth/tr808.h ****     }
 511:synth/tr808.h **** 
 512:synth/tr808.h ****     float Process() {
 513:synth/tr808.h ****         if (!active_) return 0.0f;
 514:synth/tr808.h **** 
 515:synth/tr808.h ****         /* Pitch drop corto */
 516:synth/tr808.h ****         float cp = pitch + pitch * 1.5f * expf(-time_ / 0.015f);
 517:synth/tr808.h ****         phase_ += cp * dt_;
 518:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 519:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
 520:synth/tr808.h **** 
 521:synth/tr808.h ****         float amp = expf(-time_ / decay);
 522:synth/tr808.h ****         float output = tanhf(sine * 1.1f) * amp;
 523:synth/tr808.h **** 
 524:synth/tr808.h ****         time_ += dt_;
 525:synth/tr808.h ****         if (amp < 0.001f) active_ = false;
 526:synth/tr808.h **** 
 527:synth/tr808.h ****         return output * volume * vel_;
 528:synth/tr808.h ****     }
 529:synth/tr808.h **** 
 530:synth/tr808.h ****     bool IsActive() const { return active_; }
 531:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.03f, 0.5f); }
 532:synth/tr808.h **** 
 533:synth/tr808.h **** protected:
 534:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 535:synth/tr808.h ****     bool  active_ = false;
 536:synth/tr808.h ****     float time_ = 0.0f;
 537:synth/tr808.h ****     float phase_ = 0.0f;
 538:synth/tr808.h ****     float vel_ = 1.0f;
 539:synth/tr808.h **** };
 540:synth/tr808.h **** 
