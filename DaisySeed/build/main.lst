3713:main.cpp      ****             }
3714:main.cpp      ****         }
3715:main.cpp      ****         sampleLength[padIdx] = frames;
3716:main.cpp      ****     }
3717:main.cpp      **** 
3718:main.cpp      ****     sampleLoaded[padIdx] = (sampleLength[padIdx] > 0);
