 490:synth/tr808.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 491:synth/tr808.h ****  *  CONGA BASE (sine corto, m├Īs "seco" que los toms)
 492:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 493:synth/tr808.h **** class CongaBase {
 494:synth/tr808.h **** public:
 495:synth/tr808.h ****     float decay  = 0.15f;
 496:synth/tr808.h ****     float pitch  = 200.0f;
 497:synth/tr808.h ****     float volume = 1.0f;
 498:synth/tr808.h **** 
 499:synth/tr808.h ****     void Init(float sampleRate) {
 500:synth/tr808.h ****         sr_ = sampleRate;
 501:synth/tr808.h ****         dt_ = 1.0f / sr_;
 502:synth/tr808.h ****         active_ = false;
 503:synth/tr808.h ****     }
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccOskMVA.s 			page 165


 504:synth/tr808.h **** 
 505:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 506:synth/tr808.h ****         active_ = true;
 507:synth/tr808.h ****         time_ = 0.0f;
 508:synth/tr808.h ****         phase_ = 0.0f;
 509:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 510:synth/tr808.h ****     }
 511:synth/tr808.h **** 
 512:synth/tr808.h ****     float Process() {
 513:synth/tr808.h ****         if (!active_) return 0.0f;
 514:synth/tr808.h **** 
 515:synth/tr808.h ****         /* Pitch drop corto */
 516:synth/tr808.h ****         float cp = pitch + pitch * 1.5f * expf(-time_ / 0.015f);
 517:synth/tr808.h ****         phase_ += cp * dt_;
 518:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 519:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
 520:synth/tr808.h **** 
 521:synth/tr808.h ****         float amp = expf(-time_ / decay);
 522:synth/tr808.h ****         float output = tanhf(sine * 1.1f) * amp;
 523:synth/tr808.h **** 
 524:synth/tr808.h ****         time_ += dt_;
 525:synth/tr808.h ****         if (amp < 0.001f) active_ = false;
 526:synth/tr808.h **** 
 527:synth/tr808.h ****         return output * volume * vel_;
 528:synth/tr808.h ****     }
 529:synth/tr808.h **** 
 530:synth/tr808.h ****     bool IsActive() const { return active_; }
 531:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.03f, 0.5f); }
 532:synth/tr808.h **** 
 533:synth/tr808.h **** protected:
 534:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 535:synth/tr808.h ****     bool  active_ = false;
 536:synth/tr808.h ****     float time_ = 0.0f;
 537:synth/tr808.h ****     float phase_ = 0.0f;
 538:synth/tr808.h ****     float vel_ = 1.0f;
 539:synth/tr808.h **** };
