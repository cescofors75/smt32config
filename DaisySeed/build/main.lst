1117:main.cpp      ****  *  18. CRC16 MODBUS
1118:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
1119:main.cpp      **** static uint16_t crc16(const uint8_t* d, uint16_t len){
1120:main.cpp      ****     uint16_t crc = 0xFFFF;
1121:main.cpp      ****     for(uint16_t i = 0; i < len; i++){
1122:main.cpp      ****         crc ^= d[i];
1123:main.cpp      ****         for(uint8_t j = 0; j < 8; j++)
1124:main.cpp      ****             crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : (crc >> 1);
1125:main.cpp      ****     }
1126:main.cpp      ****     return crc;
1127:main.cpp      **** }
1128:main.cpp      **** 
1129:main.cpp      **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
1130:main.cpp      ****  *  19. DSP HELPERS
1131:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
1132:main.cpp      **** static inline float clampF(float v, float lo, float hi){
1133:main.cpp      ****     return v < lo ? lo : (v > hi ? hi : v);
1134:main.cpp      **** }
1135:main.cpp      **** 
1136:main.cpp      **** static inline float VolumeByteToGain(uint8_t volumePct)
1137:main.cpp      **** {
1138:main.cpp      ****     return clampF((float)volumePct, 0.0f, 150.0f) / 100.0f;
1139:main.cpp      **** }
1140:main.cpp      **** 
1141:main.cpp      **** static inline float SoftClipKnee(float x)
1142:main.cpp      **** {
1143:main.cpp      ****     const float knee = 0.9f;
1144:main.cpp      ****     if(x > knee)
1145:main.cpp      ****     {
1146:main.cpp      ****         float t = x - knee;
1147:main.cpp      ****         return knee + t / (1.0f + t * t);
1148:main.cpp      ****     }
1149:main.cpp      ****     if(x < -knee)
1150:main.cpp      ****     {
1151:main.cpp      ****         float t = x + knee;
1152:main.cpp      ****         return -knee + t / (1.0f + t * t);
1153:main.cpp      ****     }
1154:main.cpp      ****     return x;
1155:main.cpp      **** }
1156:main.cpp      **** 
1157:main.cpp      **** static inline float TriFromPhase(float ph)
1158:main.cpp      **** {
1159:main.cpp      ****     /* 0..1 -> -1..+1 */
1160:main.cpp      ****     float t = ph < 0.5f ? (ph * 2.0f) : (2.0f - ph * 2.0f);
1161:main.cpp      ****     return t * 2.0f - 1.0f;
1162:main.cpp      **** }
1163:main.cpp      **** 
1164:main.cpp      **** static inline float AdDecayCoefFromMs(float decayMs)
1165:main.cpp      **** {
1166:main.cpp      ****     float samples = clampF(decayMs, 1.0f, 8000.0f) * (float)SAMPLE_RATE * 0.001f;
1167:main.cpp      ****     return expf(-1.0f / samples);
1168:main.cpp      **** }
