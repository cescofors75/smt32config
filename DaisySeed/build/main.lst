3869:main.cpp      **** static void InitSpiDrainTimer()
3870:main.cpp      **** {
3871:main.cpp      ****     /* TIM6: basic timer, 10kHz (100┬Ąs period)
3872:main.cpp      ****      * APB1 timer clock = 200MHz (STM32H750 @ 400MHz)
3873:main.cpp      ****      * A 1MHz SPI, 16-byte FIFO se llena en ~128┬Ąs.
3874:main.cpp      ****      * 100┬Ąs period + drain inline en AudioCallback cubre todos los casos.
3875:main.cpp      ****      * Prioridad 1 ŌåÆ puede preemptar DMA audio (prio 2 tras override). */
3876:main.cpp      ****     __HAL_RCC_TIM6_CLK_ENABLE();
3877:main.cpp      ****     TIM6->CR1  = 0;
3878:main.cpp      ****     TIM6->PSC  = 1;                        /* /2 ŌåÆ 100MHz             */
3879:main.cpp      ****     TIM6->ARR  = 10000 - 1;                /* 100MHz / 10000 = 10kHz   */
3880:main.cpp      ****     TIM6->DIER = TIM_DIER_UIE;             /* update interrupt enable   */
3881:main.cpp      ****     NVIC_SetPriority(TIM6_DAC_IRQn, 1);    /* ENCIMA de audio DMA(2)    */
3882:main.cpp      ****     NVIC_EnableIRQ(TIM6_DAC_IRQn);
3883:main.cpp      ****     TIM6->CR1  = TIM_CR1_CEN;              /* start                     */
3884:main.cpp      **** }
