 881:main.cpp      **** #define EVT_SD_KIT_LOADED      0x02  /* Kit loaded by CMD_SD_LOAD_KIT     */
 882:main.cpp      **** #define EVT_SD_SAMPLE_LOADED   0x03  /* Sample cargado por CMD_SD_LOAD_SAMPLE */
 883:main.cpp      **** #define EVT_SD_KIT_UNLOADED    0x04  /* Kit descargado                    */
 884:main.cpp      **** #define EVT_SD_ERROR           0x05  /* Error de SD                       */
 885:main.cpp      **** #define EVT_SD_XTRA_LOADED     0x06  /* XTRA PADS cargados al boot        */
