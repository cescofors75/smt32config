1207:main.cpp      **** static uint16_t crc16(const uint8_t* d, uint16_t len){
1208:main.cpp      ****     uint16_t crc = 0xFFFF;
1209:main.cpp      ****     for(uint16_t i = 0; i < len; i++){
1210:main.cpp      ****         crc ^= d[i];
1211:main.cpp      ****         for(uint8_t j = 0; j < 8; j++)
1212:main.cpp      ****             crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : (crc >> 1);
1213:main.cpp      ****     }
1214:main.cpp      ****     return crc;
1215:main.cpp      **** }
1216:main.cpp      **** 
