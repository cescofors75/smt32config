 877:main.cpp      ****  *  16b. EVENT NOTIFICATION SYSTEM
 878:main.cpp      ****  *  La Daisy es SPI esclava ŌåÆ no puede empujar datos al Master.
 879:main.cpp      ****  *  Soluci├│n: cola circular de eventos. El Master descubre que hay
 880:main.cpp      ****  *  eventos pendientes al ver eventCount > 0 en CMD_GET_STATUS,
 881:main.cpp      ****  *  y luego llama CMD_GET_EVENTS para drenarlos.
 882:main.cpp      ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 883:main.cpp      **** #define EVT_SD_BOOT_DONE       0x01  /* Boot loading complete             */
 884:main.cpp      **** #define EVT_SD_KIT_LOADED      0x02  /* Kit loaded by CMD_SD_LOAD_KIT     */
 885:main.cpp      **** #define EVT_SD_SAMPLE_LOADED   0x03  /* Sample cargado por CMD_SD_LOAD_SAMPLE */
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 35


 886:main.cpp      **** #define EVT_SD_KIT_UNLOADED    0x04  /* Kit descargado                    */
 887:main.cpp      **** #define EVT_SD_ERROR           0x05  /* Error de SD                       */
 888:main.cpp      **** #define EVT_SD_XTRA_LOADED     0x06  /* XTRA PADS cargados al boot        */
