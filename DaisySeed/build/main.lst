3843:main.cpp      ****     spiDrainBusy = true;
3844:main.cpp      **** 
3845:main.cpp      ****     while(SPI1->SR & SPI_SR_RXP) {
3846:main.cpp      ****         uint8_t b = *(volatile uint8_t*)&SPI1->RXDR;
3847:main.cpp      ****         uint16_t next = (spiRingHead + 1) & SPI_RING_MASK;
3848:main.cpp      ****         if(next != spiRingTail) {
3849:main.cpp      ****             spiRing[spiRingHead] = b;
3850:main.cpp      ****             spiRingHead = next;
3851:main.cpp      ****         } else {
3852:main.cpp      ****             spiRingDrops++;  /* ring lleno ŌĆö byte perdido */
3853:main.cpp      ****         }
3854:main.cpp      ****     }
3855:main.cpp      ****     if(SPI1->SR & SPI_SR_OVR) {
3856:main.cpp      ****         SPI1->IFCR = SPI_IFCR_OVRC;
3857:main.cpp      ****         spiErrCnt++;
3858:main.cpp      ****     }
3859:main.cpp      **** 
3860:main.cpp      ****     spiDrainBusy = false;
3861:main.cpp      **** }
