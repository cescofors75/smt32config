3538:main.cpp      **** /* ŌĢÉŌĢÉŌĢÉ SPI1 RX ring buffer (TIM6 ISR escribe, main loop lee) ŌĢÉŌĢÉŌĢÉ
3539:main.cpp      ****  * 2048 bytes = ~128 paquetes TRIG_SEQ (16B c/u).
3540:main.cpp      ****  * TIM6 ISR drena RXFIFO cada ~100┬Ąs, previniendo OVR incluso
3541:main.cpp      ****  * durante el audio callback (~2.7ms con AUDIO_BLOCK=128).         */
3542:main.cpp      **** #define SPI_RING_BITS  11
3543:main.cpp      **** #define SPI_RING_SIZE  (1 << SPI_RING_BITS)   /* 2048 */
3544:main.cpp      **** #define SPI_RING_MASK  (SPI_RING_SIZE - 1)
3545:main.cpp      **** static volatile uint8_t  spiRing[SPI_RING_SIZE];
3546:main.cpp      **** static volatile uint16_t spiRingHead = 0;   /* escrito por ISR o AudioCB */
3547:main.cpp      **** static volatile uint16_t spiRingTail = 0;   /* escrito SOLO por main     */
3548:main.cpp      **** static volatile bool     spiDrainBusy = false; /* anti-reentrada */
3549:main.cpp      **** 
3550:main.cpp      **** static void SpiDrainRxToRing()
3551:main.cpp      **** {
3552:main.cpp      ****     if(spiDrainBusy) return;        /* reentrada ŌåÆ salir */
3553:main.cpp      ****     spiDrainBusy = true;
3554:main.cpp      **** 
3555:main.cpp      ****     while(SPI1->SR & SPI_SR_RXP) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 97


3556:main.cpp      ****         uint8_t b = *(volatile uint8_t*)&SPI1->RXDR;
3557:main.cpp      ****         uint16_t next = (spiRingHead + 1) & SPI_RING_MASK;
3558:main.cpp      ****         if(next != spiRingTail) {
3559:main.cpp      ****             spiRing[spiRingHead] = b;
3560:main.cpp      ****             spiRingHead = next;
3561:main.cpp      ****         } else {
3562:main.cpp      ****             spiRingDrops++;  /* ring lleno ŌĆö byte perdido */
3563:main.cpp      ****         }
3564:main.cpp      ****     }
3565:main.cpp      ****     if(SPI1->SR & SPI_SR_OVR) {
3566:main.cpp      ****         SPI1->IFCR = SPI_IFCR_OVRC;
3567:main.cpp      ****         spiErrCnt++;
3568:main.cpp      ****     }
3569:main.cpp      **** 
3570:main.cpp      ****     spiDrainBusy = false;
3571:main.cpp      **** }
