 443:synth/tr505.h **** class Cymbal {
 444:synth/tr505.h **** public:
 445:synth/tr505.h ****     float decay  = 0.6f;
 446:synth/tr505.h ****     float lofi   = 0.2f;
 447:synth/tr505.h ****     float volume = 1.0f;
 448:synth/tr505.h **** 
 449:synth/tr505.h ****     void Init(float sampleRate) {
 450:synth/tr505.h ****         sr_ = sampleRate;
 451:synth/tr505.h ****         dt_ = 1.0f / sr_;
 452:synth/tr505.h ****         active_ = false;
 453:synth/tr505.h ****         noiseState_ = 0x505CC03;
 454:synth/tr505.h ****     }
 455:synth/tr505.h **** 
 456:synth/tr505.h ****     void Trigger(float velocity = 1.0f) {
 457:synth/tr505.h ****         active_ = true;
 458:synth/tr505.h ****         time_ = 0.0f;
 459:synth/tr505.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 460:synth/tr505.h ****         hpZ1_ = hpOut_ = 0.0f;
 461:synth/tr505.h ****     }
 462:synth/tr505.h **** 
 463:synth/tr505.h ****     float Process() {
 464:synth/tr505.h ****         if (!active_) return 0.0f;
 465:synth/tr505.h **** 
 466:synth/tr505.h ****         float n = Noise(noiseState_);
 467:synth/tr505.h **** 
 468:synth/tr505.h ****         float rc = 1.0f / (TWOPI_F * 5000.0f);
 469:synth/tr505.h ****         float alpha = rc / (rc + dt_);
 470:synth/tr505.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 471:synth/tr505.h ****         hpZ1_ = n;
 472:synth/tr505.h **** 
 473:synth/tr505.h ****         float attack = 1.0f - expf(-time_ / 0.003f);
 474:synth/tr505.h ****         float env = expf(-time_ / decay);
 475:synth/tr505.h **** 
 476:synth/tr505.h ****         float output = hpOut_ * env * attack;
