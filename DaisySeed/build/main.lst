   2:synth/tr909.h ****  *  TR909 ŌĆö Roland TR-909 Drum Synthesis Library
   3:synth/tr909.h ****  * ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
   4:synth/tr909.h ****  *  M├Īs agresiva que la 808: kick con m├Īs punch, snare m├Īs brillante,
   5:synth/tr909.h ****  *  hihats con sampleo digital real (aqu├Ł sintetizado), clap m├Īs denso.
   6:synth/tr909.h ****  *  La 909 es el sonido del techno, house y trance.
   7:synth/tr909.h ****  *
   8:synth/tr909.h ****  *  48 kHz ┬Ę float32 ┬Ę header-only
   9:synth/tr909.h ****  *
  10:synth/tr909.h ****  *  Instrumentos:
  11:synth/tr909.h ****  *    Kick, Snare, Clap, HiHatClosed, HiHatOpen,
  12:synth/tr909.h ****  *    LowTom, MidTom, HiTom, Ride, Crash, RimShot
  13:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  14:synth/tr909.h **** #pragma once
  15:synth/tr909.h **** 
  16:synth/tr909.h **** #include <math.h>
  17:synth/tr909.h **** #include <stdint.h>
  18:synth/tr909.h **** 
  19:synth/tr909.h **** #ifndef TWOPI_F
  20:synth/tr909.h **** #define TWOPI_F 6.283185307f
  21:synth/tr909.h **** #endif
  22:synth/tr909.h **** 
  23:synth/tr909.h **** namespace TR909 {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 220


  24:synth/tr909.h **** 
  25:synth/tr909.h **** static inline float Noise(uint32_t& state) {
  26:synth/tr909.h ****     state ^= state << 13;
  27:synth/tr909.h ****     state ^= state >> 17;
  28:synth/tr909.h ****     state ^= state << 5;
  29:synth/tr909.h ****     return ((float)(int32_t)state) / 2147483648.0f;
  30:synth/tr909.h **** }
  31:synth/tr909.h **** 
  32:synth/tr909.h **** static inline float Clamp(float v, float lo, float hi) {
  33:synth/tr909.h ****     return v < lo ? lo : (v > hi ? hi : v);
  34:synth/tr909.h **** }
  35:synth/tr909.h **** 
  36:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  37:synth/tr909.h ****  *  KICK 909
  38:synth/tr909.h ****  *  M├Īs punch que la 808: click transitorio m├Īs fuerte,
  39:synth/tr909.h ****  *  pitch envelope m├Īs agresivo, compresi├│n interna
  40:synth/tr909.h ****  *  El kick del techno por excelencia
  41:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
  42:synth/tr909.h **** class Kick {
  43:synth/tr909.h **** public:
  44:synth/tr909.h ****     float decay      = 0.5f;    /* 0.15 - 1.2 s */
  45:synth/tr909.h ****     float pitch      = 50.0f;   /* 35 - 90 Hz   */
  46:synth/tr909.h ****     float pitchDecay = 0.04f;   /* m├Īs r├Īpido que 808 */
  47:synth/tr909.h ****     float attack     = 0.3f;    /* 0.0 - 1.0 click amount */
  48:synth/tr909.h ****     float compression= 0.5f;    /* 0.0 - 1.0 punch */
  49:synth/tr909.h ****     float volume     = 1.0f;
  50:synth/tr909.h **** 
  51:synth/tr909.h ****     void Init(float sampleRate) {
  52:synth/tr909.h ****         sr_ = sampleRate;
  53:synth/tr909.h ****         dt_ = 1.0f / sr_;
  54:synth/tr909.h ****         active_ = false;
  55:synth/tr909.h ****     }
  56:synth/tr909.h **** 
  57:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
  58:synth/tr909.h ****         active_ = true;
  59:synth/tr909.h ****         time_ = 0.0f;
  60:synth/tr909.h ****         phase_ = 0.0f;
  61:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
  62:synth/tr909.h ****     }
  63:synth/tr909.h **** 
  64:synth/tr909.h ****     float Process() {
  65:synth/tr909.h ****         if (!active_) return 0.0f;
  66:synth/tr909.h **** 
  67:synth/tr909.h ****         /* Pitch sweep m├Īs agresivo que 808 */
  68:synth/tr909.h ****         float sweep = pitch * 12.0f * expf(-time_ / pitchDecay);
  69:synth/tr909.h ****         float cp = pitch + sweep;
  70:synth/tr909.h **** 
  71:synth/tr909.h ****         phase_ += cp * dt_;
  72:synth/tr909.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
  73:synth/tr909.h ****         float sine = sinf(TWOPI_F * phase_);
  74:synth/tr909.h **** 
  75:synth/tr909.h ****         /* Click transitorio punchy */
  76:synth/tr909.h ****         float clickEnv = expf(-time_ / 0.001f);
  77:synth/tr909.h ****         float click = clickEnv * sinf(TWOPI_F * 3000.0f * time_) * attack;
  78:synth/tr909.h **** 
  79:synth/tr909.h ****         /* Amp envelope con knee de compresi├│n */
  80:synth/tr909.h ****         float env = expf(-time_ / decay);
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 221


  81:synth/tr909.h ****         /* Compresi├│n: mantiene el cuerpo durante m├Īs tiempo */
  82:synth/tr909.h ****         if (compression > 0.01f) {
  83:synth/tr909.h ****             float sustain = expf(-time_ / (decay * 3.0f));
  84:synth/tr909.h ****             env = env * (1.0f - compression * 0.5f) + sustain * compression * 0.5f;
  85:synth/tr909.h ****         }
  86:synth/tr909.h **** 
  87:synth/tr909.h ****         float output = sine + click;
  88:synth/tr909.h ****         /* Saturaci├│n m├Īs fuerte que 808 */
  89:synth/tr909.h ****         output = tanhf(output * 1.8f);
  90:synth/tr909.h **** 
  91:synth/tr909.h ****         time_ += dt_;
  92:synth/tr909.h ****         if (env < 0.001f) active_ = false;
  93:synth/tr909.h **** 
  94:synth/tr909.h ****         return output * env * volume * vel_;
  95:synth/tr909.h ****     }
  96:synth/tr909.h **** 
  97:synth/tr909.h ****     bool IsActive() const { return active_; }
  98:synth/tr909.h ****     void SetDecay(float d) { decay = Clamp(d, 0.1f, 2.0f); }
  99:synth/tr909.h ****     void SetPitch(float p) { pitch = Clamp(p, 30.0f, 120.0f); }
 100:synth/tr909.h **** 
 101:synth/tr909.h **** private:
 102:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 103:synth/tr909.h ****     bool  active_ = false;
 104:synth/tr909.h ****     float time_ = 0.0f, phase_ = 0.0f, vel_ = 1.0f;
 105:synth/tr909.h **** };
 106:synth/tr909.h **** 
 107:synth/tr909.h **** /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 108:synth/tr909.h ****  *  SNARE 909
 109:synth/tr909.h ****  *  M├Īs brillante que 808: componente tonal m├Īs agudo,
 110:synth/tr909.h ****  *  noise m├Īs presente, dos modos de decay
 111:synth/tr909.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 112:synth/tr909.h **** class Snare {
 113:synth/tr909.h **** public:
 114:synth/tr909.h ****     float decay   = 0.18f;
 115:synth/tr909.h ****     float tone    = 0.6f;      /* mezcla tono/ruido */
 116:synth/tr909.h ****     float snappy  = 0.7f;      /* cantidad de noise */
 117:synth/tr909.h ****     float pitch   = 200.0f;    /* Hz tono base */
 118:synth/tr909.h ****     float volume  = 1.0f;
 119:synth/tr909.h **** 
 120:synth/tr909.h ****     void Init(float sampleRate) {
 121:synth/tr909.h ****         sr_ = sampleRate;
 122:synth/tr909.h ****         dt_ = 1.0f / sr_;
 123:synth/tr909.h ****         active_ = false;
 124:synth/tr909.h ****         noiseState_ = 0x909BEEF;
 125:synth/tr909.h ****     }
 126:synth/tr909.h **** 
 127:synth/tr909.h ****     void Trigger(float velocity = 1.0f) {
 128:synth/tr909.h ****         active_ = true;
 129:synth/tr909.h ****         time_ = 0.0f;
 130:synth/tr909.h ****         phase1_ = phase2_ = 0.0f;
 131:synth/tr909.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 132:synth/tr909.h ****         hpZ1_ = hpOut_ = 0.0f;
 133:synth/tr909.h ****     }
 134:synth/tr909.h **** 
 135:synth/tr909.h ****     float Process() {
 136:synth/tr909.h ****         if (!active_) return 0.0f;
 137:synth/tr909.h **** 
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccQ72LAe.s 			page 222


 138:synth/tr909.h ****         /* Dos tonos: fundamental + arm├│nico */
 139:synth/tr909.h ****         phase1_ += pitch * dt_;
 140:synth/tr909.h ****         if (phase1_ >= 1.0f) phase1_ -= 1.0f;
 141:synth/tr909.h ****         float t1 = sinf(TWOPI_F * phase1_);
 142:synth/tr909.h **** 
 143:synth/tr909.h ****         phase2_ += pitch * 1.6f * dt_;
 144:synth/tr909.h ****         if (phase2_ >= 1.0f) phase2_ -= 1.0f;
 145:synth/tr909.h ****         float t2 = sinf(TWOPI_F * phase2_);
 146:synth/tr909.h **** 
 147:synth/tr909.h ****         float toneEnv = expf(-time_ / (decay * 0.4f));
 148:synth/tr909.h ****         float toneOut = (t1 * 0.7f + t2 * 0.3f) * toneEnv * tone;
 149:synth/tr909.h **** 
 150:synth/tr909.h ****         /* Ruido m├Īs blanco y brillante que 808 */
 151:synth/tr909.h ****         float n = Noise(noiseState_);
 152:synth/tr909.h ****         /* High-pass para m├Īs "snap" */
 153:synth/tr909.h ****         float rc = 1.0f / (TWOPI_F * 3000.0f);
 154:synth/tr909.h ****         float alpha = rc / (rc + dt_);
 155:synth/tr909.h ****         hpOut_ = alpha * (hpOut_ + n - hpZ1_);
 156:synth/tr909.h ****         hpZ1_ = n;
 157:synth/tr909.h **** 
 158:synth/tr909.h ****         float noiseEnv = expf(-time_ / decay);
 159:synth/tr909.h ****         float noiseOut = hpOut_ * noiseEnv * snappy * 1.5f;
 160:synth/tr909.h **** 
 161:synth/tr909.h ****         float output = toneOut + noiseOut;
 162:synth/tr909.h ****         output = tanhf(output * 2.0f);
 163:synth/tr909.h **** 
 164:synth/tr909.h ****         time_ += dt_;
 165:synth/tr909.h ****         if (noiseEnv < 0.001f) active_ = false;
 166:synth/tr909.h **** 
 167:synth/tr909.h ****         return output * volume * vel_;
 168:synth/tr909.h ****     }
 169:synth/tr909.h **** 
 170:synth/tr909.h ****     bool IsActive() const { return active_; }
 171:synth/tr909.h ****     void SetDecay(float d)  { decay = Clamp(d, 0.05f, 0.8f); }
 172:synth/tr909.h ****     void SetTone(float t)   { tone = Clamp(t, 0.0f, 1.0f); }
 173:synth/tr909.h ****     void SetSnappy(float s) { snappy = Clamp(s, 0.0f, 1.0f); }
 174:synth/tr909.h **** 
 175:synth/tr909.h **** private:
 176:synth/tr909.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 177:synth/tr909.h ****     bool  active_ = false;
 178:synth/tr909.h ****     float time_ = 0.0f;
 179:synth/tr909.h ****     float phase1_ = 0.0f, phase2_ = 0.0f;
 180:synth/tr909.h ****     float vel_ = 1.0f;
 181:synth/tr909.h ****     uint32_t noiseState_ = 0x909BEEF;
 182:synth/tr909.h ****     float hpZ1_ = 0.0f, hpOut_ = 0.0f;
 183:synth/tr909.h **** };
