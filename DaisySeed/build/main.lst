 150:synth/tb303.h **** 
 151:synth/tb303.h ****         /* ŌöĆŌöĆ 3. ENVELOPES ŌöĆŌöĆ */
 152:synth/tb303.h ****         /* Filter envelope: decay exponencial */
 153:synth/tb303.h ****         float envDecay = accent_ ? decay * 0.7f : decay;
 154:synth/tb303.h ****         filterEnv_ *= expf(-dt_ / envDecay);
 155:synth/tb303.h **** 
 156:synth/tb303.h ****         /* Amp envelope */
 157:synth/tb303.h ****         if (gateOn_) {
 158:synth/tb303.h ****             /* Attack r├Īpido */
 159:synth/tb303.h ****             ampEnv_ += (1.0f - ampEnv_) * 0.05f;
 160:synth/tb303.h ****         } else {
 161:synth/tb303.h ****             /* Release */
 162:synth/tb303.h ****             float relTime = accent_ ? 0.01f : 0.005f;
 163:synth/tb303.h ****             ampEnv_ *= expf(-dt_ / relTime);
 164:synth/tb303.h ****             if (ampEnv_ < 0.001f) {
 165:synth/tb303.h ****                 active_ = false;
 166:synth/tb303.h ****                 return 0.0f;
 167:synth/tb303.h ****             }
 168:synth/tb303.h ****         }
 169:synth/tb303.h **** 
 170:synth/tb303.h ****         /* ŌöĆŌöĆ 4. FILTRO LADDER (el coraz├│n del acid) ŌöĆŌöĆ */
 171:synth/tb303.h ****         /* Calcular cutoff modulado por envelope */
 172:synth/tb303.h ****         float accentBoost = accent_ ? accentAmt * 6000.0f : 0.0f;
 173:synth/tb303.h ****         float envAmount = envMod * 10000.0f * filterEnv_;
 174:synth/tb303.h ****         float fc = cutoff + envAmount + accentBoost;
 175:synth/tb303.h ****         fc = Clamp(fc, 20.0f, sr_ * 0.45f);
 176:synth/tb303.h **** 
 177:synth/tb303.h ****         /* Resonancia: accent la aumenta */
 178:synth/tb303.h ****         float res = resonance;
 179:synth/tb303.h ****         if (accent_) res = Clamp(res + accentAmt * 0.3f, 0.0f, 0.95f);
 180:synth/tb303.h **** 
 181:synth/tb303.h ****         float filtered = LadderFilter(osc, fc, res);
 182:synth/tb303.h **** 
 183:synth/tb303.h ****         /* ŌöĆŌöĆ 5. VCA ŌöĆŌöĆ */
 184:synth/tb303.h ****         float accentGain = accent_ ? 1.0f + accentAmt * 0.4f : 1.0f;
 185:synth/tb303.h ****         float output = filtered * ampEnv_ * volume * accentGain;
 186:synth/tb303.h **** 
 187:synth/tb303.h ****         /* Soft clip final */
 188:synth/tb303.h ****         output = tanhf(output * 1.5f);
 189:synth/tb303.h **** 
 190:synth/tb303.h ****         return output;
 191:synth/tb303.h ****     }
 192:synth/tb303.h **** 
 193:synth/tb303.h ****     bool IsActive() const { return active_; }
 194:synth/tb303.h ****     bool IsGateOn() const { return gateOn_; }
 195:synth/tb303.h **** 
 196:synth/tb303.h ****     /* ŌöĆŌöĆŌöĆ Setters para control en vivo ŌöĆŌöĆŌöĆ */
 197:synth/tb303.h ****     void SetCutoff(float c)     { cutoff = Clamp(c, 20.0f, 20000.0f); }
 198:synth/tb303.h ****     void SetResonance(float r)  { resonance = Clamp(r, 0.0f, 0.95f); }
 199:synth/tb303.h ****     void SetEnvMod(float e)     { envMod = Clamp(e, 0.0f, 1.0f); }
 200:synth/tb303.h ****     void SetDecay(float d)      { decay = Clamp(d, 0.02f, 3.0f); }
 201:synth/tb303.h ****     void SetAccent(float a)     { accentAmt = Clamp(a, 0.0f, 1.0f); }
 202:synth/tb303.h ****     void SetSlide(float s)      { slideTime = Clamp(s, 0.01f, 0.5f); }
 203:synth/tb303.h ****     void SetWaveform(Waveform w){ waveform = w; }
 204:synth/tb303.h **** 
 205:synth/tb303.h **** private:
 206:synth/tb303.h ****     float sr_ = 48000.0f;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 413


 207:synth/tb303.h ****     float dt_ = 1.0f / 48000.0f;
 208:synth/tb303.h **** 
 209:synth/tb303.h ****     /* Estado del oscilador */
 210:synth/tb303.h ****     float phase_ = 0.0f;
 211:synth/tb303.h ****     float currentFreq_ = 220.0f;
 212:synth/tb303.h ****     float targetFreq_ = 220.0f;
 213:synth/tb303.h **** 
 214:synth/tb303.h ****     /* Estado activo */
 215:synth/tb303.h ****     bool  active_ = false;
 216:synth/tb303.h ****     bool  gateOn_ = false;
 217:synth/tb303.h ****     bool  accent_ = false;
 218:synth/tb303.h ****     bool  sliding_ = false;
 219:synth/tb303.h **** 
 220:synth/tb303.h ****     /* Envelopes */
 221:synth/tb303.h ****     float filterEnv_ = 0.0f;
 222:synth/tb303.h ****     float ampEnv_ = 0.0f;
 223:synth/tb303.h **** 
 224:synth/tb303.h ****     /* Filtro ladder: 4 stages */
 225:synth/tb303.h ****     float stage_[4] = {};
 226:synth/tb303.h ****     float delay_[4] = {};
 227:synth/tb303.h **** 
 228:synth/tb303.h ****     /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
 229:synth/tb303.h ****      *  LADDER FILTER ŌĆö 4 polos en cascada (24 dB/octava)
 230:synth/tb303.h ****      *  ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 231:synth/tb303.h ****      *  Cada stage = filtro de 1 polo (6dB/oct)
 232:synth/tb303.h ****      *  4 stages en cascada = 24dB/oct
 233:synth/tb303.h ****      *  Retroalimentaci├│n de la salida = resonancia
 234:synth/tb303.h ****      *  
 235:synth/tb303.h ****      *  Es la misma topolog├Ła del Moog ladder original,
 236:synth/tb303.h ****      *  adaptada para la 303 (diode ladder).
 237:synth/tb303.h ****      *  La diferencia es que la 303 usa diodos en vez de
 238:synth/tb303.h ****      *  transistores, dando un car├Īcter m├Īs "chirpy".
 239:synth/tb303.h ****      * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
 240:synth/tb303.h ****     float LadderFilter(float input, float fc, float res) {
 241:synth/tb303.h ****         /* Frecuencia normalizada */
 242:synth/tb303.h ****         float f = 2.0f * fc / sr_;
 243:synth/tb303.h ****         if (f > 0.99f) f = 0.99f;
 244:synth/tb303.h **** 
 245:synth/tb303.h ****         /* Coeficiente del filtro (tuning) */
 246:synth/tb303.h ****         /* Aproximaci├│n: compensar la desviaci├│n no-lineal */
 247:synth/tb303.h ****         float g = f * (1.0f + f * (-0.25f));
 248:synth/tb303.h **** 
 249:synth/tb303.h ****         /* Retroalimentaci├│n = resonancia ├Ś 4 (4 polos) */
 250:synth/tb303.h ****         float fb = res * 4.0f;
 251:synth/tb303.h **** 
 252:synth/tb303.h ****         /* Compensaci├│n de ganancia para resonancia alta */
 253:synth/tb303.h ****         float comp = 1.0f / (1.0f + fb * 0.25f);
 254:synth/tb303.h **** 
 255:synth/tb303.h ****         /* Entrada con retroalimentaci├│n */
 256:synth/tb303.h ****         float fbSig = delay_[3];
 257:synth/tb303.h ****         float in = (input - fb * fbSig) * comp;
 258:synth/tb303.h **** 
 259:synth/tb303.h ****         /* Saturaci├│n suave en la entrada (car├Īcter diodo 303) */
 260:synth/tb303.h ****         in = tanhf(in);
 261:synth/tb303.h **** 
 262:synth/tb303.h ****         /* 4 stages de filtro en cascada */
 263:synth/tb303.h ****         for (int i = 0; i < 4; i++) {
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 414


 264:synth/tb303.h ****             float prev = (i == 0) ? in : stage_[i - 1];
 265:synth/tb303.h ****             stage_[i] = delay_[i] + g * (tanhf(prev) - tanhf(delay_[i]));
 266:synth/tb303.h ****             delay_[i] = stage_[i];
 267:synth/tb303.h ****         }
 268:synth/tb303.h **** 
 269:synth/tb303.h ****         return stage_[3];
 270:synth/tb303.h ****     }
 271:synth/tb303.h **** 
 272:synth/tb303.h ****     /* ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢ
