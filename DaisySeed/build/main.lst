1780:main.cpp      **** static float BitCrush(float s, uint8_t bits){
1781:main.cpp      ****     if(bits >= 16) return s;
1782:main.cpp      ****     float levels = (float)(1 << bits);
1783:main.cpp      ****     return roundf(s * levels) / levels;
1784:main.cpp      **** }
