 424:synth/tr808.h ****  * ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 425:synth/tr808.h **** class TomBase {
 426:synth/tr808.h **** public:
 427:synth/tr808.h ****     float decay      = 0.25f;
 428:synth/tr808.h ****     float pitch      = 100.0f;
 429:synth/tr808.h ****     float pitchDecay = 0.05f;
 430:synth/tr808.h ****     float volume     = 1.0f;
 431:synth/tr808.h **** 
 432:synth/tr808.h ****     void Init(float sampleRate) {
 433:synth/tr808.h ****         sr_ = sampleRate;
 434:synth/tr808.h ****         dt_ = 1.0f / sr_;
 435:synth/tr808.h ****         active_ = false;
 436:synth/tr808.h ****     }
 437:synth/tr808.h **** 
 438:synth/tr808.h ****     void Trigger(float velocity = 1.0f) {
 439:synth/tr808.h ****         active_ = true;
 440:synth/tr808.h ****         time_ = 0.0f;
 441:synth/tr808.h ****         phase_ = 0.0f;
 442:synth/tr808.h ****         vel_ = Clamp(velocity, 0.0f, 1.0f);
 443:synth/tr808.h ****     }
 444:synth/tr808.h **** 
 445:synth/tr808.h ****     float Process() {
 446:synth/tr808.h ****         if (!active_) return 0.0f;
 447:synth/tr808.h **** 
 448:synth/tr808.h ****         float cp = pitch + pitch * 2.0f * expf(-time_ / pitchDecay);
 449:synth/tr808.h ****         phase_ += cp * dt_;
 450:synth/tr808.h ****         if (phase_ >= 1.0f) phase_ -= 1.0f;
 451:synth/tr808.h ****         float sine = sinf(TWOPI_F * phase_);
 452:synth/tr808.h **** 
 453:synth/tr808.h ****         float amp = expf(-time_ / decay);
 454:synth/tr808.h ****         float output = tanhf(sine * 1.2f) * amp;
 455:synth/tr808.h **** 
 456:synth/tr808.h ****         time_ += dt_;
 457:synth/tr808.h ****         if (amp < 0.001f) active_ = false;
 458:synth/tr808.h **** 
 459:synth/tr808.h ****         return output * volume * vel_;
 460:synth/tr808.h ****     }
