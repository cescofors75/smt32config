1111:main.cpp      **** static uint16_t crc16(const uint8_t* d, uint16_t len){
1112:main.cpp      ****     uint16_t crc = 0xFFFF;
1113:main.cpp      ****     for(uint16_t i = 0; i < len; i++){
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccaqCzI7.s 			page 39


1114:main.cpp      ****         crc ^= d[i];
1115:main.cpp      ****         for(uint8_t j = 0; j < 8; j++)
1116:main.cpp      ****             crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : (crc >> 1);
1117:main.cpp      ****     }
1118:main.cpp      ****     return crc;
1119:main.cpp      **** }
