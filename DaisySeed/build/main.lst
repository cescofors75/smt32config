3737:main.cpp      **** /* ŌöĆŌöĆ Helper: guess pad index from a filename using keyword table ŌöĆŌöĆ */
3738:main.cpp      **** static int GuessPadFromFilename(const char* fname)
3739:main.cpp      **** {
3740:main.cpp      ****     /* Try each keyword ŌĆö longer keywords checked implicitly because
3741:main.cpp      ****        the table is ordered from most-specific to least-specific */
3742:main.cpp      ****     for(int k = 0; k < NUM_INSTR_KEYWORDS; k++){
3743:main.cpp      ****         if(containsCI(fname, INSTR_KEYWORDS[k].keyword))
3744:main.cpp      ****             return INSTR_KEYWORDS[k].pad;
3745:main.cpp      ****     }
3746:main.cpp      ****     return -1;
3747:main.cpp      **** }
