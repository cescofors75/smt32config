 897:main.cpp      **** static volatile uint8_t evtTail = 0;  /* next read  position  */
 898:main.cpp      **** static volatile uint8_t evtCount = 0; /* events in queue      */
 899:main.cpp      **** 
 900:main.cpp      **** static void PushEvent(uint8_t type, uint8_t padCount,
 901:main.cpp      ****                       uint32_t padMask24, const char* name)
 902:main.cpp      **** {
 903:main.cpp      ****     if(evtCount >= EVT_QUEUE_SIZE){
 904:main.cpp      ****         /* Queue full ŌĆö overwrite oldest */
 905:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 906:main.cpp      ****         evtCount--;
 907:main.cpp      ****     }
 908:main.cpp      ****     NotifyEvent& e = evtQueue[evtHead];
 909:main.cpp      ****     memset(&e, 0, sizeof(e));
 910:main.cpp      ****     e.type       = type;
 911:main.cpp      ****     e.padCount   = padCount;
 912:main.cpp      ****     e.padMaskLo  = (uint8_t)(padMask24 & 0xFF);
 913:main.cpp      ****     e.padMaskHi  = (uint8_t)((padMask24 >> 8) & 0xFF);
 914:main.cpp      ****     e.padMaskXtra= (uint8_t)((padMask24 >> 16) & 0xFF);
 915:main.cpp      ****     if(name) strncpy(e.name, name, 23);
 916:main.cpp      ****     evtHead = (evtHead + 1) % EVT_QUEUE_SIZE;
 917:main.cpp      ****     evtCount++;
 918:main.cpp      **** }
 919:main.cpp      **** 
 920:main.cpp      **** static uint8_t PopEvents(NotifyEvent* dst, uint8_t maxEvents)
 921:main.cpp      **** {
 922:main.cpp      ****     uint8_t count = 0;
 923:main.cpp      ****     while(evtCount > 0 && count < maxEvents){
 924:main.cpp      ****         dst[count++] = evtQueue[evtTail];
 925:main.cpp      ****         evtTail = (evtTail + 1) % EVT_QUEUE_SIZE;
 926:main.cpp      ****         evtCount--;
 927:main.cpp      ****     }
 928:main.cpp      ****     return count;
 929:main.cpp      **** }
