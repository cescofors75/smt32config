 190:synth/tr808.h **** 
 191:synth/tr808.h ****     bool IsActive() const { return active_; }
 192:synth/tr808.h ****     void SetDecay(float d) { decay = Clamp(d, 0.05f, 1.0f); }
 193:synth/tr808.h ****     void SetTone(float t)  { tone = Clamp(t, 0.0f, 1.0f); }
 194:synth/tr808.h ****     void SetSnappy(float s){ snappy = Clamp(s, 0.0f, 1.0f); }
 195:synth/tr808.h **** 
 196:synth/tr808.h **** private:
 197:synth/tr808.h ****     float sr_ = 48000.0f, dt_ = 1.0f / 48000.0f;
 198:synth/tr808.h ****     bool  active_ = false;
 199:synth/tr808.h ****     float time_ = 0.0f;
