3926:main.cpp      **** /* ŌöĆŌöĆ Helper: case-insensitive substring match ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
3927:main.cpp      **** static bool containsCI(const char* haystack, const char* needle)
3928:main.cpp      **** {
3929:main.cpp      ****     for(const char* h = haystack; *h; h++){
3930:main.cpp      ****         const char* hp = h;
3931:main.cpp      ****         const char* np = needle;
3932:main.cpp      ****         while(*np && *hp && (toupper((uint8_t)*hp) == toupper((uint8_t)*np))){
3933:main.cpp      ****             hp++; np++;
3934:main.cpp      ****         }
3935:main.cpp      ****         if(!*np) return true;
3936:main.cpp      ****     }
3937:main.cpp      ****     return false;
3938:main.cpp      **** }
