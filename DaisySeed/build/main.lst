 891:synth/tr808.h ****     void Trigger(uint8_t instrument, float velocity = 1.0f) {
 892:synth/tr808.h ****         switch (instrument) {
 893:synth/tr808.h ****             case INST_KICK:       kick.Trigger(velocity); break;
 894:synth/tr808.h ****             case INST_SNARE:      snare.Trigger(velocity); break;
 895:synth/tr808.h ****             case INST_CLAP:       clap.Trigger(velocity); break;
 896:synth/tr808.h ****             case INST_HIHAT_C:
 897:synth/tr808.h ****                 hihatO.Choke();  /* cerrar el open al tocar closed */
 898:synth/tr808.h ****                 hihatC.Trigger(velocity);
 899:synth/tr808.h ****                 break;
 900:synth/tr808.h ****             case INST_HIHAT_O:   hihatO.Trigger(velocity); break;
 901:synth/tr808.h ****             case INST_LOW_TOM:   lowTom.Trigger(velocity); break;
 902:synth/tr808.h ****             case INST_MID_TOM:   midTom.Trigger(velocity); break;
 903:synth/tr808.h ****             case INST_HI_TOM:    hiTom.Trigger(velocity); break;
 904:synth/tr808.h ****             case INST_LOW_CONGA: lowConga.Trigger(velocity); break;
 905:synth/tr808.h ****             case INST_MID_CONGA: midConga.Trigger(velocity); break;
 906:synth/tr808.h ****             case INST_HI_CONGA:  hiConga.Trigger(velocity); break;
 907:synth/tr808.h ****             case INST_CLAVES:    claves.Trigger(velocity); break;
ARM GAS  C:\Users\cesco\AppData\Local\Temp\ccBUvn29.s 			page 167


 908:synth/tr808.h ****             case INST_MARACAS:   maracas.Trigger(velocity); break;
 909:synth/tr808.h ****             case INST_RIMSHOT:   rimshot.Trigger(velocity); break;
 910:synth/tr808.h ****             case INST_COWBELL:   cowbell.Trigger(velocity); break;
 911:synth/tr808.h ****             case INST_CYMBAL:    cymbal.Trigger(velocity); break;
 912:synth/tr808.h ****         }
 913:synth/tr808.h ****     }
